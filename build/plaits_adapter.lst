  26:mi/plaits/dsp/engine2/wave_terrain_engine.h **** //
  27:mi/plaits/dsp/engine2/wave_terrain_engine.h **** // Wave terrain synthesis - a 2D function evaluated along an elliptical path of
  28:mi/plaits/dsp/engine2/wave_terrain_engine.h **** // adjustable center and excentricity.
  29:mi/plaits/dsp/engine2/wave_terrain_engine.h **** //
  30:mi/plaits/dsp/engine2/wave_terrain_engine.h **** // This implementation initially used pre-computed terrains stored in flash
  31:mi/plaits/dsp/engine2/wave_terrain_engine.h **** // memory, but even at a poor resolution of 64x64 with 8-bit samples, this
  32:mi/plaits/dsp/engine2/wave_terrain_engine.h **** // takes 4kb per terrain! It turned out that directly evaluating the terrain
  33:mi/plaits/dsp/engine2/wave_terrain_engine.h **** // function on the fly uses less flash, but is also faster than bicubic
  34:mi/plaits/dsp/engine2/wave_terrain_engine.h **** // interpolation of the terrain data.
  35:mi/plaits/dsp/engine2/wave_terrain_engine.h **** 
