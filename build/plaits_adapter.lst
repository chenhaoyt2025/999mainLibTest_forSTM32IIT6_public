 116:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****   inline void GetWordBoundaries(float address, int* start, int* end) {
 117:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****     if (num_words_ == 0) {
 118:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****       *start = *end = -1;
 119:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****     } else {
 120:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****       int word = static_cast<int>(address * static_cast<float>(num_words_));
 121:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****       if (word >= num_words_) {
 122:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****         word = num_words_ - 1;
 123:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****       }
 124:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****       *start = word_boundaries_[word];
 125:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****       *end = word_boundaries_[word + 1] - 1;
 126:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****     }
 127:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****   }
