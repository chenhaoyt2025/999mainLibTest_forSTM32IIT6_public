  42:mi/plaits/dsp/drums/synthetic_bass_drum.h **** class SyntheticBassDrumClick {
  43:mi/plaits/dsp/drums/synthetic_bass_drum.h ****  public:
  44:mi/plaits/dsp/drums/synthetic_bass_drum.h ****   SyntheticBassDrumClick() { }
  45:mi/plaits/dsp/drums/synthetic_bass_drum.h ****   ~SyntheticBassDrumClick() { }
  46:mi/plaits/dsp/drums/synthetic_bass_drum.h ****   
  47:mi/plaits/dsp/drums/synthetic_bass_drum.h ****   void Init() {
  48:mi/plaits/dsp/drums/synthetic_bass_drum.h ****     lp_ = 0.0f;
  49:mi/plaits/dsp/drums/synthetic_bass_drum.h ****     hp_ = 0.0f;
  50:mi/plaits/dsp/drums/synthetic_bass_drum.h ****     filter_.Init();
  51:mi/plaits/dsp/drums/synthetic_bass_drum.h ****     filter_.set_f_q<stmlib::FREQUENCY_FAST>(5000.0f / kSampleRate, 2.0f);
ARM GAS  /var/folders/9k/zk1mgrrd7wg4__6zvxvr9w8m0000gn/T//cczqcbrU.s 			page 46


  52:mi/plaits/dsp/drums/synthetic_bass_drum.h ****   }
  53:mi/plaits/dsp/drums/synthetic_bass_drum.h ****   
  54:mi/plaits/dsp/drums/synthetic_bass_drum.h ****   float Process(float in) {
  55:mi/plaits/dsp/drums/synthetic_bass_drum.h ****     SLOPE(lp_, in, 0.5f, 0.1f);
  56:mi/plaits/dsp/drums/synthetic_bass_drum.h ****     ONE_POLE(hp_, lp_, 0.04f);
  57:mi/plaits/dsp/drums/synthetic_bass_drum.h ****     return filter_.Process<stmlib::FILTER_MODE_LOW_PASS>(lp_ - hp_);
  58:mi/plaits/dsp/drums/synthetic_bass_drum.h ****   }
  59:mi/plaits/dsp/drums/synthetic_bass_drum.h ****   
  60:mi/plaits/dsp/drums/synthetic_bass_drum.h ****  private:
  61:mi/plaits/dsp/drums/synthetic_bass_drum.h ****   float lp_;
  62:mi/plaits/dsp/drums/synthetic_bass_drum.h ****   float hp_;
  63:mi/plaits/dsp/drums/synthetic_bass_drum.h ****   stmlib::Svf filter_;
  64:mi/plaits/dsp/drums/synthetic_bass_drum.h ****   
  65:mi/plaits/dsp/drums/synthetic_bass_drum.h ****   DISALLOW_COPY_AND_ASSIGN(SyntheticBassDrumClick);
  66:mi/plaits/dsp/drums/synthetic_bass_drum.h **** };
