 129:mi/plaits/dsp/engine/swarm_engine.h **** class AdditiveSawOscillator {
 130:mi/plaits/dsp/engine/swarm_engine.h ****  public:
 131:mi/plaits/dsp/engine/swarm_engine.h ****   AdditiveSawOscillator() { }
 132:mi/plaits/dsp/engine/swarm_engine.h ****   ~AdditiveSawOscillator() { }
 133:mi/plaits/dsp/engine/swarm_engine.h **** 
 134:mi/plaits/dsp/engine/swarm_engine.h ****   inline void Init() {
 135:mi/plaits/dsp/engine/swarm_engine.h ****     phase_ = 0.0f;
 136:mi/plaits/dsp/engine/swarm_engine.h ****     next_sample_ = 0.0f;
 137:mi/plaits/dsp/engine/swarm_engine.h ****     frequency_ = 0.01f;
 138:mi/plaits/dsp/engine/swarm_engine.h ****     gain_ = 0.0f;
 139:mi/plaits/dsp/engine/swarm_engine.h ****   }
 140:mi/plaits/dsp/engine/swarm_engine.h **** 
 141:mi/plaits/dsp/engine/swarm_engine.h ****   inline void Render(
 142:mi/plaits/dsp/engine/swarm_engine.h ****       float frequency,
 143:mi/plaits/dsp/engine/swarm_engine.h ****       float level,
 144:mi/plaits/dsp/engine/swarm_engine.h ****       float* out,
 145:mi/plaits/dsp/engine/swarm_engine.h ****       size_t size) {
 146:mi/plaits/dsp/engine/swarm_engine.h ****     if (frequency >= kMaxFrequency) {
 147:mi/plaits/dsp/engine/swarm_engine.h ****       frequency = kMaxFrequency;
 148:mi/plaits/dsp/engine/swarm_engine.h ****     }
 149:mi/plaits/dsp/engine/swarm_engine.h ****     stmlib::ParameterInterpolator fm(&frequency_, frequency, size);
 150:mi/plaits/dsp/engine/swarm_engine.h ****     stmlib::ParameterInterpolator gain(&gain_, level, size);
ARM GAS  /var/folders/9k/zk1mgrrd7wg4__6zvxvr9w8m0000gn/T//cczqcbrU.s 			page 59


 151:mi/plaits/dsp/engine/swarm_engine.h **** 
 152:mi/plaits/dsp/engine/swarm_engine.h ****     float next_sample = next_sample_;
 153:mi/plaits/dsp/engine/swarm_engine.h ****     float phase = phase_;
 154:mi/plaits/dsp/engine/swarm_engine.h **** 
 155:mi/plaits/dsp/engine/swarm_engine.h ****     while (size--) {
 156:mi/plaits/dsp/engine/swarm_engine.h ****       float this_sample = next_sample;
 157:mi/plaits/dsp/engine/swarm_engine.h ****       next_sample = 0.0f;
 158:mi/plaits/dsp/engine/swarm_engine.h **** 
 159:mi/plaits/dsp/engine/swarm_engine.h ****       const float frequency = fm.Next();
 160:mi/plaits/dsp/engine/swarm_engine.h **** 
 161:mi/plaits/dsp/engine/swarm_engine.h ****       phase += frequency;
 162:mi/plaits/dsp/engine/swarm_engine.h ****   
 163:mi/plaits/dsp/engine/swarm_engine.h ****       if (phase >= 1.0f) {
 164:mi/plaits/dsp/engine/swarm_engine.h ****         phase -= 1.0f;
 165:mi/plaits/dsp/engine/swarm_engine.h ****         float t = phase / frequency;
 166:mi/plaits/dsp/engine/swarm_engine.h ****         this_sample -= stmlib::ThisBlepSample(t);
 167:mi/plaits/dsp/engine/swarm_engine.h ****         next_sample -= stmlib::NextBlepSample(t);
 168:mi/plaits/dsp/engine/swarm_engine.h ****       }
 169:mi/plaits/dsp/engine/swarm_engine.h **** 
 170:mi/plaits/dsp/engine/swarm_engine.h ****       next_sample += phase;
 171:mi/plaits/dsp/engine/swarm_engine.h ****       *out++ += (2.0f * this_sample - 1.0f) * gain.Next();
 172:mi/plaits/dsp/engine/swarm_engine.h ****     }
 173:mi/plaits/dsp/engine/swarm_engine.h ****     phase_ = phase;
 174:mi/plaits/dsp/engine/swarm_engine.h ****     next_sample_ = next_sample;
 175:mi/plaits/dsp/engine/swarm_engine.h ****   }
 176:mi/plaits/dsp/engine/swarm_engine.h **** 
 177:mi/plaits/dsp/engine/swarm_engine.h ****  private:
 178:mi/plaits/dsp/engine/swarm_engine.h ****   // Oscillator state.
 179:mi/plaits/dsp/engine/swarm_engine.h ****   float phase_;
 180:mi/plaits/dsp/engine/swarm_engine.h ****   float next_sample_;
 181:mi/plaits/dsp/engine/swarm_engine.h **** 
 182:mi/plaits/dsp/engine/swarm_engine.h ****   // For interpolation of parameters.
 183:mi/plaits/dsp/engine/swarm_engine.h ****   float frequency_;
 184:mi/plaits/dsp/engine/swarm_engine.h ****   float gain_;
 185:mi/plaits/dsp/engine/swarm_engine.h **** 
 186:mi/plaits/dsp/engine/swarm_engine.h ****   DISALLOW_COPY_AND_ASSIGN(AdditiveSawOscillator);
 187:mi/plaits/dsp/engine/swarm_engine.h **** };
