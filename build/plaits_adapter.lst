  26:mi/plaits/dsp/physical_modelling/resonator.h **** //
  27:mi/plaits/dsp/physical_modelling/resonator.h **** // Resonator, taken from Rings' code but with fixed position.
  28:mi/plaits/dsp/physical_modelling/resonator.h **** 
  29:mi/plaits/dsp/physical_modelling/resonator.h **** #ifndef PLAITS_DSP_PHYSICAL_MODELLING_RESONATOR_H_
  30:mi/plaits/dsp/physical_modelling/resonator.h **** #define PLAITS_DSP_PHYSICAL_MODELLING_RESONATOR_H_
  31:mi/plaits/dsp/physical_modelling/resonator.h **** 
  32:mi/plaits/dsp/physical_modelling/resonator.h **** #include "stmlib/dsp/filter.h"
  33:mi/plaits/dsp/physical_modelling/resonator.h **** 
  34:mi/plaits/dsp/physical_modelling/resonator.h **** namespace plaits {
  35:mi/plaits/dsp/physical_modelling/resonator.h **** 
  36:mi/plaits/dsp/physical_modelling/resonator.h **** const int kMaxNumModes = 24;
  37:mi/plaits/dsp/physical_modelling/resonator.h **** const int kModeBatchSize = 4;
  38:mi/plaits/dsp/physical_modelling/resonator.h **** 
  39:mi/plaits/dsp/physical_modelling/resonator.h **** // We render 4 modes simultaneously since there are enough registers to hold
  40:mi/plaits/dsp/physical_modelling/resonator.h **** // all state variables.
  41:mi/plaits/dsp/physical_modelling/resonator.h **** template<int batch_size>
  42:mi/plaits/dsp/physical_modelling/resonator.h **** class ResonatorSvf {
  43:mi/plaits/dsp/physical_modelling/resonator.h ****  public:
  44:mi/plaits/dsp/physical_modelling/resonator.h ****   ResonatorSvf() { }
  45:mi/plaits/dsp/physical_modelling/resonator.h ****   ~ResonatorSvf() { }
  46:mi/plaits/dsp/physical_modelling/resonator.h ****   
  47:mi/plaits/dsp/physical_modelling/resonator.h ****   void Init() {
  48:mi/plaits/dsp/physical_modelling/resonator.h ****     for (int i = 0; i < batch_size; ++i) {
  49:mi/plaits/dsp/physical_modelling/resonator.h ****       state_1_[i] = state_2_[i] = 0.0f;
  50:mi/plaits/dsp/physical_modelling/resonator.h ****     }
  51:mi/plaits/dsp/physical_modelling/resonator.h ****   }
  52:mi/plaits/dsp/physical_modelling/resonator.h ****   
  53:mi/plaits/dsp/physical_modelling/resonator.h ****   template<stmlib::FilterMode mode, bool add>
  54:mi/plaits/dsp/physical_modelling/resonator.h ****   void Process(
  55:mi/plaits/dsp/physical_modelling/resonator.h ****       const float* f,
  56:mi/plaits/dsp/physical_modelling/resonator.h ****       const float* q,
ARM GAS  /var/folders/9k/zk1mgrrd7wg4__6zvxvr9w8m0000gn/T//cczqcbrU.s 			page 51


  57:mi/plaits/dsp/physical_modelling/resonator.h ****       const float* gain,
  58:mi/plaits/dsp/physical_modelling/resonator.h ****       const float* in,
  59:mi/plaits/dsp/physical_modelling/resonator.h ****       float* out,
  60:mi/plaits/dsp/physical_modelling/resonator.h ****       size_t size) {
  61:mi/plaits/dsp/physical_modelling/resonator.h ****     float g[batch_size];
  62:mi/plaits/dsp/physical_modelling/resonator.h ****     float r[batch_size];
  63:mi/plaits/dsp/physical_modelling/resonator.h ****     float r_plus_g[batch_size];
  64:mi/plaits/dsp/physical_modelling/resonator.h ****     float h[batch_size];
  65:mi/plaits/dsp/physical_modelling/resonator.h ****     float state_1[batch_size];
  66:mi/plaits/dsp/physical_modelling/resonator.h ****     float state_2[batch_size];
  67:mi/plaits/dsp/physical_modelling/resonator.h ****     float gains[batch_size];
  68:mi/plaits/dsp/physical_modelling/resonator.h ****     for (int i = 0; i < batch_size; ++i) {
  69:mi/plaits/dsp/physical_modelling/resonator.h ****       g[i] = stmlib::OnePole::tan<stmlib::FREQUENCY_FAST>(f[i]);
  70:mi/plaits/dsp/physical_modelling/resonator.h ****       r[i] = 1.0f / q[i];
  71:mi/plaits/dsp/physical_modelling/resonator.h ****       h[i] = 1.0f / (1.0f + r[i] * g[i] + g[i] * g[i]);
  72:mi/plaits/dsp/physical_modelling/resonator.h ****       r_plus_g[i] = r[i] + g[i];
  73:mi/plaits/dsp/physical_modelling/resonator.h ****       state_1[i] = state_1_[i];
  74:mi/plaits/dsp/physical_modelling/resonator.h ****       state_2[i] = state_2_[i];
  75:mi/plaits/dsp/physical_modelling/resonator.h ****       gains[i] = gain[i];
  76:mi/plaits/dsp/physical_modelling/resonator.h ****     }
  77:mi/plaits/dsp/physical_modelling/resonator.h ****     
  78:mi/plaits/dsp/physical_modelling/resonator.h ****     while (size--) {
  79:mi/plaits/dsp/physical_modelling/resonator.h ****       float s_in = *in++;
  80:mi/plaits/dsp/physical_modelling/resonator.h ****       float s_out = 0.0f;
  81:mi/plaits/dsp/physical_modelling/resonator.h ****       for (int i = 0; i < batch_size; ++i) {
  82:mi/plaits/dsp/physical_modelling/resonator.h ****         const float hp = (s_in - r_plus_g[i] * state_1[i] - state_2[i]) * h[i];
  83:mi/plaits/dsp/physical_modelling/resonator.h ****         const float bp = g[i] * hp + state_1[i];
  84:mi/plaits/dsp/physical_modelling/resonator.h ****         state_1[i] = g[i] * hp + bp;
  85:mi/plaits/dsp/physical_modelling/resonator.h ****         const float lp = g[i] * bp + state_2[i];
  86:mi/plaits/dsp/physical_modelling/resonator.h ****         state_2[i] = g[i] * bp + lp;
  87:mi/plaits/dsp/physical_modelling/resonator.h ****         s_out += gains[i] * ((mode == stmlib::FILTER_MODE_LOW_PASS) ? lp : bp);
  88:mi/plaits/dsp/physical_modelling/resonator.h ****       }
  89:mi/plaits/dsp/physical_modelling/resonator.h ****       if (add) {
