  36:mi/plaits/dsp/speech/lpc_speech_synth_controller.h **** namespace plaits {
  37:mi/plaits/dsp/speech/lpc_speech_synth_controller.h **** 
  38:mi/plaits/dsp/speech/lpc_speech_synth_controller.h **** class BitStream {
  39:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****  public:
  40:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****   BitStream() { }
  41:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****   ~BitStream() { }
  42:mi/plaits/dsp/speech/lpc_speech_synth_controller.h **** 
  43:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****   inline void Init(const uint8_t* p) {
  44:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****     p_ = p;
  45:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****     available_ = 0;
  46:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****     bits_ = 0;
  47:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****   }
  48:mi/plaits/dsp/speech/lpc_speech_synth_controller.h **** 
  49:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****   inline void Flush() {
  50:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****     while (available_) {
  51:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****       GetBits(1);
  52:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****     }
  53:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****   }
  54:mi/plaits/dsp/speech/lpc_speech_synth_controller.h **** 
  55:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****   inline uint8_t GetBits(int num_bits) {
  56:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****     int shift = num_bits;
  57:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****     if (num_bits > available_) {
  58:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****       bits_ <<= available_;
  59:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****       shift -= available_;
  60:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****       bits_ |= Reverse(*p_++);
  61:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****       available_ += 8;
  62:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****     }
  63:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****     bits_ <<= shift;
  64:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****     uint8_t result = bits_ >> 8;
  65:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****     bits_ &= 0xff;
  66:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****     available_ -= num_bits;
  67:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****     return result;
  68:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****   }
  69:mi/plaits/dsp/speech/lpc_speech_synth_controller.h **** 
  70:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****   inline const uint8_t* ptr() const { return p_; }
  71:mi/plaits/dsp/speech/lpc_speech_synth_controller.h **** 
  72:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****  private:
  73:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****   inline uint8_t Reverse(uint8_t b) const {
  74:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****     b = (b >> 4) | (b << 4);
  75:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****   	b = ((b & 0xcc) >> 2) | ((b & 0x33) << 2);
  76:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****   	b = ((b & 0xaa) >> 1) | ((b & 0x55) << 1);
  77:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****     return b;
  78:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****   }
  79:mi/plaits/dsp/speech/lpc_speech_synth_controller.h **** 
  80:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****   const uint8_t* p_;
  81:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****   int available_;
ARM GAS  /var/folders/9k/zk1mgrrd7wg4__6zvxvr9w8m0000gn/T//cczqcbrU.s 			page 63


  82:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****   uint16_t bits_;
  83:mi/plaits/dsp/speech/lpc_speech_synth_controller.h **** 
  84:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****   DISALLOW_COPY_AND_ASSIGN(BitStream);
  85:mi/plaits/dsp/speech/lpc_speech_synth_controller.h **** };
