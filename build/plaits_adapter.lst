  44:mi/plaits/dsp/drums/hi_hat.h **** 
  45:mi/plaits/dsp/drums/hi_hat.h **** namespace plaits {
  46:mi/plaits/dsp/drums/hi_hat.h **** 
  47:mi/plaits/dsp/drums/hi_hat.h **** // 808 style "metallic noise" with 6 square oscillators.
  48:mi/plaits/dsp/drums/hi_hat.h **** class SquareNoise {
  49:mi/plaits/dsp/drums/hi_hat.h ****  public:
  50:mi/plaits/dsp/drums/hi_hat.h ****   SquareNoise() { }
  51:mi/plaits/dsp/drums/hi_hat.h ****   ~SquareNoise() { }
  52:mi/plaits/dsp/drums/hi_hat.h **** 
  53:mi/plaits/dsp/drums/hi_hat.h ****   void Init() {
  54:mi/plaits/dsp/drums/hi_hat.h ****     std::fill(&phase_[0], &phase_[6], 0);
  55:mi/plaits/dsp/drums/hi_hat.h ****   }
  56:mi/plaits/dsp/drums/hi_hat.h ****     
  57:mi/plaits/dsp/drums/hi_hat.h ****   void Render(float f0, float* temp_1, float* temp_2, float* out, size_t size) {
  58:mi/plaits/dsp/drums/hi_hat.h ****     const float ratios[6] = {
  59:mi/plaits/dsp/drums/hi_hat.h ****         // Nominal f0: 414 Hz
  60:mi/plaits/dsp/drums/hi_hat.h ****         1.0f, 1.304f, 1.466f, 1.787f, 1.932f, 2.536f
  61:mi/plaits/dsp/drums/hi_hat.h ****     };
  62:mi/plaits/dsp/drums/hi_hat.h ****   
  63:mi/plaits/dsp/drums/hi_hat.h ****     uint32_t increment[6];
  64:mi/plaits/dsp/drums/hi_hat.h ****     uint32_t phase[6];
  65:mi/plaits/dsp/drums/hi_hat.h ****     for (int i = 0; i < 6; ++i) {
  66:mi/plaits/dsp/drums/hi_hat.h ****       float f = f0 * ratios[i];
  67:mi/plaits/dsp/drums/hi_hat.h ****       if (f >= 0.499f) f = 0.499f;
  68:mi/plaits/dsp/drums/hi_hat.h ****       increment[i] = static_cast<uint32_t>(f * 4294967296.0f);
  69:mi/plaits/dsp/drums/hi_hat.h ****       phase[i] = phase_[i];
  70:mi/plaits/dsp/drums/hi_hat.h ****     }
  71:mi/plaits/dsp/drums/hi_hat.h **** 
  72:mi/plaits/dsp/drums/hi_hat.h ****     while (size--) {
  73:mi/plaits/dsp/drums/hi_hat.h ****       phase[0] += increment[0];
  74:mi/plaits/dsp/drums/hi_hat.h ****       phase[1] += increment[1];
  75:mi/plaits/dsp/drums/hi_hat.h ****       phase[2] += increment[2];
  76:mi/plaits/dsp/drums/hi_hat.h ****       phase[3] += increment[3];
  77:mi/plaits/dsp/drums/hi_hat.h ****       phase[4] += increment[4];
  78:mi/plaits/dsp/drums/hi_hat.h ****       phase[5] += increment[5];
  79:mi/plaits/dsp/drums/hi_hat.h ****       uint32_t noise = 0;
  80:mi/plaits/dsp/drums/hi_hat.h ****       noise += (phase[0] >> 31);
  81:mi/plaits/dsp/drums/hi_hat.h ****       noise += (phase[1] >> 31);
  82:mi/plaits/dsp/drums/hi_hat.h ****       noise += (phase[2] >> 31);
  83:mi/plaits/dsp/drums/hi_hat.h ****       noise += (phase[3] >> 31);
  84:mi/plaits/dsp/drums/hi_hat.h ****       noise += (phase[4] >> 31);
  85:mi/plaits/dsp/drums/hi_hat.h ****       noise += (phase[5] >> 31);
  86:mi/plaits/dsp/drums/hi_hat.h ****       *out++ = 0.33f * static_cast<float>(noise) - 1.0f;
  87:mi/plaits/dsp/drums/hi_hat.h ****     }
  88:mi/plaits/dsp/drums/hi_hat.h ****   
  89:mi/plaits/dsp/drums/hi_hat.h ****     for (int i = 0; i < 6; ++i) {
  90:mi/plaits/dsp/drums/hi_hat.h ****       phase_[i] = phase[i];
  91:mi/plaits/dsp/drums/hi_hat.h ****     }
  92:mi/plaits/dsp/drums/hi_hat.h ****   }
  93:mi/plaits/dsp/drums/hi_hat.h **** 
  94:mi/plaits/dsp/drums/hi_hat.h ****  private:
  95:mi/plaits/dsp/drums/hi_hat.h ****   uint32_t phase_[6];
  96:mi/plaits/dsp/drums/hi_hat.h **** 
ARM GAS  /var/folders/9k/zk1mgrrd7wg4__6zvxvr9w8m0000gn/T//cczqcbrU.s 			page 38


  97:mi/plaits/dsp/drums/hi_hat.h ****   DISALLOW_COPY_AND_ASSIGN(SquareNoise);
  98:mi/plaits/dsp/drums/hi_hat.h **** };
  99:mi/plaits/dsp/drums/hi_hat.h **** 
 100:mi/plaits/dsp/drums/hi_hat.h **** class RingModNoise {
 101:mi/plaits/dsp/drums/hi_hat.h ****  public:
 102:mi/plaits/dsp/drums/hi_hat.h ****   RingModNoise() { }
 103:mi/plaits/dsp/drums/hi_hat.h ****   ~RingModNoise() { }
 104:mi/plaits/dsp/drums/hi_hat.h **** 
 105:mi/plaits/dsp/drums/hi_hat.h ****   void Init() {
 106:mi/plaits/dsp/drums/hi_hat.h ****     for (int i = 0; i < 6; ++i) {
 107:mi/plaits/dsp/drums/hi_hat.h ****       oscillator_[i].Init();
 108:mi/plaits/dsp/drums/hi_hat.h ****     }
 109:mi/plaits/dsp/drums/hi_hat.h ****   }
 110:mi/plaits/dsp/drums/hi_hat.h ****   
 111:mi/plaits/dsp/drums/hi_hat.h ****   void Render(float f0, float* temp_1, float* temp_2, float* out, size_t size) {
 112:mi/plaits/dsp/drums/hi_hat.h ****     const float ratio = f0 / (0.01f + f0);
 113:mi/plaits/dsp/drums/hi_hat.h ****     const float f1a = 200.0f / kSampleRate * ratio;
 114:mi/plaits/dsp/drums/hi_hat.h ****     const float f1b = 7530.0f / kSampleRate * ratio;
 115:mi/plaits/dsp/drums/hi_hat.h ****     const float f2a = 510.0f / kSampleRate * ratio;
 116:mi/plaits/dsp/drums/hi_hat.h ****     const float f2b = 8075.0f / kSampleRate * ratio;
 117:mi/plaits/dsp/drums/hi_hat.h ****     const float f3a = 730.0f / kSampleRate * ratio;
 118:mi/plaits/dsp/drums/hi_hat.h ****     const float f3b = 10500.0f / kSampleRate * ratio;
 119:mi/plaits/dsp/drums/hi_hat.h ****     const float f[3][2] = { { f1a, f1b }, { f2a, f2b }, { f3a, f3b } };
 120:mi/plaits/dsp/drums/hi_hat.h ****     
 121:mi/plaits/dsp/drums/hi_hat.h ****     std::fill(&out[0], &out[size], 0.0f);
 122:mi/plaits/dsp/drums/hi_hat.h ****     
 123:mi/plaits/dsp/drums/hi_hat.h ****     for (int i = 0; i < 3; ++i) {
 124:mi/plaits/dsp/drums/hi_hat.h ****       RenderPair(&oscillator_[2 * i], f[i], temp_1, temp_2, out, size);
 125:mi/plaits/dsp/drums/hi_hat.h ****     }
 126:mi/plaits/dsp/drums/hi_hat.h ****   }
 127:mi/plaits/dsp/drums/hi_hat.h **** 
 128:mi/plaits/dsp/drums/hi_hat.h ****  private:
 129:mi/plaits/dsp/drums/hi_hat.h ****   void RenderPair(
 130:mi/plaits/dsp/drums/hi_hat.h ****       Oscillator* osc,
 131:mi/plaits/dsp/drums/hi_hat.h ****       const float* f,
 132:mi/plaits/dsp/drums/hi_hat.h ****       float* temp_1,
 133:mi/plaits/dsp/drums/hi_hat.h ****       float* temp_2,
 134:mi/plaits/dsp/drums/hi_hat.h ****       float* out,
 135:mi/plaits/dsp/drums/hi_hat.h ****       size_t size) {
 136:mi/plaits/dsp/drums/hi_hat.h ****     osc[0].Render<OSCILLATOR_SHAPE_SQUARE>(f[0], 0.5f, temp_1, size);
 137:mi/plaits/dsp/drums/hi_hat.h ****     osc[1].Render<OSCILLATOR_SHAPE_SAW>(f[1], 0.5f, temp_2, size);
 138:mi/plaits/dsp/drums/hi_hat.h ****     while (size--) {
 139:mi/plaits/dsp/drums/hi_hat.h ****       *out++ += *temp_1++ * *temp_2++;
 140:mi/plaits/dsp/drums/hi_hat.h ****     }
 141:mi/plaits/dsp/drums/hi_hat.h ****   }
 142:mi/plaits/dsp/drums/hi_hat.h ****   Oscillator oscillator_[6];
 143:mi/plaits/dsp/drums/hi_hat.h ****   
 144:mi/plaits/dsp/drums/hi_hat.h ****   DISALLOW_COPY_AND_ASSIGN(RingModNoise);
 145:mi/plaits/dsp/drums/hi_hat.h **** };
 146:mi/plaits/dsp/drums/hi_hat.h **** 
 147:mi/plaits/dsp/drums/hi_hat.h **** class SwingVCA {
 148:mi/plaits/dsp/drums/hi_hat.h ****  public:
 149:mi/plaits/dsp/drums/hi_hat.h ****   float operator()(float s, float gain) {
 150:mi/plaits/dsp/drums/hi_hat.h ****    s *= s > 0.0f ? 4.0f : 0.1f;
 151:mi/plaits/dsp/drums/hi_hat.h ****    s = s / (1.0f + fabsf(s));
 152:mi/plaits/dsp/drums/hi_hat.h ****    return (s + 0.1f) * gain;
 153:mi/plaits/dsp/drums/hi_hat.h ****   }
ARM GAS  /var/folders/9k/zk1mgrrd7wg4__6zvxvr9w8m0000gn/T//cczqcbrU.s 			page 39


 154:mi/plaits/dsp/drums/hi_hat.h **** };
 155:mi/plaits/dsp/drums/hi_hat.h **** 
 156:mi/plaits/dsp/drums/hi_hat.h **** class LinearVCA {
 157:mi/plaits/dsp/drums/hi_hat.h ****  public:
 158:mi/plaits/dsp/drums/hi_hat.h ****   float operator()(float s, float gain) {
 159:mi/plaits/dsp/drums/hi_hat.h ****    return s * gain;
 160:mi/plaits/dsp/drums/hi_hat.h ****   }
 161:mi/plaits/dsp/drums/hi_hat.h **** };
