  39:mi/plaits/dsp/engine/engine.h **** inline float NoteToFrequency(float midi_note) {
  40:mi/plaits/dsp/engine/engine.h ****   midi_note -= 9.0f;
  41:mi/plaits/dsp/engine/engine.h ****   CONSTRAIN(midi_note, -128.0f, 127.0f);
