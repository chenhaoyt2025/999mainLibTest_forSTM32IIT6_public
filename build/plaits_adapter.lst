  40:mi/plaits/dsp/envelope.h ****   
  41:mi/plaits/dsp/envelope.h ****   inline void Init() {
  42:mi/plaits/dsp/envelope.h ****     vactrol_state_ = 0.0f;
  43:mi/plaits/dsp/envelope.h ****     gain_ = 1.0f;
  44:mi/plaits/dsp/envelope.h ****     frequency_ = 0.5f;
  45:mi/plaits/dsp/envelope.h ****     hf_bleed_ = 0.0f;
  46:mi/plaits/dsp/envelope.h ****     ramp_up_ = false;
  47:mi/plaits/dsp/envelope.h ****   }
  48:mi/plaits/dsp/envelope.h ****   
  49:mi/plaits/dsp/envelope.h ****   inline void Trigger() {
  50:mi/plaits/dsp/envelope.h ****     ramp_up_ = true;
  51:mi/plaits/dsp/envelope.h ****   }
  52:mi/plaits/dsp/envelope.h ****   
  53:mi/plaits/dsp/envelope.h ****   inline void ProcessPing(
  54:mi/plaits/dsp/envelope.h ****       float attack,
  55:mi/plaits/dsp/envelope.h ****       float short_decay,
  56:mi/plaits/dsp/envelope.h ****       float decay_tail,
  57:mi/plaits/dsp/envelope.h ****       float hf) {
  58:mi/plaits/dsp/envelope.h ****     if (ramp_up_) {
  59:mi/plaits/dsp/envelope.h ****       vactrol_state_ += attack;
  60:mi/plaits/dsp/envelope.h ****       if (vactrol_state_ >= 1.0f) {
  61:mi/plaits/dsp/envelope.h ****         vactrol_state_ = 1.0f;
  62:mi/plaits/dsp/envelope.h ****         ramp_up_ = false;
  63:mi/plaits/dsp/envelope.h ****       }
  64:mi/plaits/dsp/envelope.h ****     }
  65:mi/plaits/dsp/envelope.h ****     ProcessLP(ramp_up_ ? vactrol_state_ : 0.0f, short_decay, decay_tail, hf);
  66:mi/plaits/dsp/envelope.h ****   }
  67:mi/plaits/dsp/envelope.h ****   
  68:mi/plaits/dsp/envelope.h ****   inline void ProcessLP(
  69:mi/plaits/dsp/envelope.h ****       float level,
  70:mi/plaits/dsp/envelope.h ****       float short_decay,
  71:mi/plaits/dsp/envelope.h ****       float decay_tail,
  72:mi/plaits/dsp/envelope.h ****       float hf) {
  73:mi/plaits/dsp/envelope.h ****     float vactrol_input = level;
  74:mi/plaits/dsp/envelope.h ****     float vactrol_error = (vactrol_input - vactrol_state_);
ARM GAS  /var/folders/9k/zk1mgrrd7wg4__6zvxvr9w8m0000gn/T//cczqcbrU.s 			page 15


  75:mi/plaits/dsp/envelope.h ****     float vactrol_state_2 = vactrol_state_ * vactrol_state_;
  76:mi/plaits/dsp/envelope.h ****     float vactrol_state_4 = vactrol_state_2 * vactrol_state_2;
  77:mi/plaits/dsp/envelope.h ****     float tail = 1.0f - vactrol_state_;
  78:mi/plaits/dsp/envelope.h ****     float tail_2 = tail * tail;
  79:mi/plaits/dsp/envelope.h ****     float vactrol_coefficient = (vactrol_error > 0.0f)
  80:mi/plaits/dsp/envelope.h ****         ? 0.6f
  81:mi/plaits/dsp/envelope.h ****         : short_decay + (1.0f - vactrol_state_4) * decay_tail;
  82:mi/plaits/dsp/envelope.h ****     vactrol_state_ += vactrol_coefficient * vactrol_error;
  83:mi/plaits/dsp/envelope.h ****     
  84:mi/plaits/dsp/envelope.h ****     gain_ = vactrol_state_;
  85:mi/plaits/dsp/envelope.h ****     frequency_ = 0.003f + 0.3f * vactrol_state_4 + hf * 0.04f;
  86:mi/plaits/dsp/envelope.h ****     hf_bleed_ = (tail_2 + (1.0f - tail_2) * hf) * hf * hf;
  87:mi/plaits/dsp/envelope.h ****   }
  88:mi/plaits/dsp/envelope.h ****   
  89:mi/plaits/dsp/envelope.h ****   inline float gain() const { return gain_; }
  90:mi/plaits/dsp/envelope.h ****   inline float frequency() const { return frequency_; }
  91:mi/plaits/dsp/envelope.h ****   inline float hf_bleed() const { return hf_bleed_; }
  92:mi/plaits/dsp/envelope.h ****   
  93:mi/plaits/dsp/envelope.h ****  private:
  94:mi/plaits/dsp/envelope.h ****   float vactrol_state_;
  95:mi/plaits/dsp/envelope.h ****   float gain_;
  96:mi/plaits/dsp/envelope.h ****   float frequency_;
  97:mi/plaits/dsp/envelope.h ****   float hf_bleed_;
  98:mi/plaits/dsp/envelope.h ****   bool ramp_up_;
  99:mi/plaits/dsp/envelope.h ****   
 100:mi/plaits/dsp/envelope.h ****   DISALLOW_COPY_AND_ASSIGN(LPGEnvelope);
 101:mi/plaits/dsp/envelope.h **** };
