  91:mi/plaits/dsp/speech/lpc_speech_synth_controller.h **** const int kLPCSpeechSynthNumPhonemes = \
  92:mi/plaits/dsp/speech/lpc_speech_synth_controller.h ****     kLPCSpeechSynthNumVowels + kLPCSpeechSynthNumConsonants;
  93:mi/plaits/dsp/speech/lpc_speech_synth_controller.h **** const float kLPCSpeechSynthFPS = 40.0f;
