  89:mi/plaits/dsp/drums/synthetic_bass_drum.h ****   DISALLOW_COPY_AND_ASSIGN(SyntheticBassDrumAttackNoise);
  90:mi/plaits/dsp/drums/synthetic_bass_drum.h **** };
