  73:mi/plaits/dsp/drums/synthetic_bass_drum.h ****   void Init() {
  74:mi/plaits/dsp/drums/synthetic_bass_drum.h ****     lp_ = 0.0f;
  75:mi/plaits/dsp/drums/synthetic_bass_drum.h ****     hp_ = 0.0f;
  76:mi/plaits/dsp/drums/synthetic_bass_drum.h ****   }
  77:mi/plaits/dsp/drums/synthetic_bass_drum.h ****   
  78:mi/plaits/dsp/drums/synthetic_bass_drum.h ****   float Render() {
  79:mi/plaits/dsp/drums/synthetic_bass_drum.h ****     float sample = stmlib::Random::GetFloat();
  80:mi/plaits/dsp/drums/synthetic_bass_drum.h ****     ONE_POLE(lp_, sample, 0.05f);
  81:mi/plaits/dsp/drums/synthetic_bass_drum.h ****     ONE_POLE(hp_, lp_, 0.005f);
  82:mi/plaits/dsp/drums/synthetic_bass_drum.h ****     return lp_ - hp_;
  83:mi/plaits/dsp/drums/synthetic_bass_drum.h ****   }
