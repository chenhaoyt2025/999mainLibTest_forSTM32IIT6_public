  90:mi/plaits/dsp/voice.h ****   
  91:mi/plaits/dsp/voice.h ****   void Process(
  92:mi/plaits/dsp/voice.h ****       float gain,
  93:mi/plaits/dsp/voice.h ****       bool bypass_lpg,
  94:mi/plaits/dsp/voice.h ****       float low_pass_gate_gain,
  95:mi/plaits/dsp/voice.h ****       float low_pass_gate_frequency,
  96:mi/plaits/dsp/voice.h ****       float low_pass_gate_hf_bleed,
  97:mi/plaits/dsp/voice.h ****       float dj_eq,
  98:mi/plaits/dsp/voice.h ****       float* in,
  99:mi/plaits/dsp/voice.h ****       short* out,
 100:mi/plaits/dsp/voice.h ****       size_t size,
 101:mi/plaits/dsp/voice.h ****       size_t stride) {
 102:mi/plaits/dsp/voice.h ****     if (gain < 0.0f) {
 103:mi/plaits/dsp/voice.h ****       limiter_.Process(-gain, in, size);
 104:mi/plaits/dsp/voice.h ****     }
 105:mi/plaits/dsp/voice.h ****     
 106:mi/plaits/dsp/voice.h ****     // DJ EQ implementation: 0.45..0.55 Deadband
 107:mi/plaits/dsp/voice.h ****     // Left (0.0..0.45): LP 120Hz to Flat
 108:mi/plaits/dsp/voice.h ****     // Right (0.55..1.0): HP Flat to 8kHz
 109:mi/plaits/dsp/voice.h ****     // Increased Q to 2.0f for sharp filtering
 110:mi/plaits/dsp/voice.h ****     float lp_f = 0.5f;
 111:mi/plaits/dsp/voice.h ****     float hp_f = 0.0f;
 112:mi/plaits/dsp/voice.h ****     float q = 2.0f; 
 113:mi/plaits/dsp/voice.h **** 
 114:mi/plaits/dsp/voice.h ****     if (dj_eq < 0.45f) {
 115:mi/plaits/dsp/voice.h ****       // Exponential mapping for LP using stmlib's lookup table
 116:mi/plaits/dsp/voice.h ****       // 0.0 -> 0.45 maps to ~120Hz -> 16kHz (approx 7 octaves/84 semitones)
 117:mi/plaits/dsp/voice.h ****       float ratio = dj_eq / 0.45f;
 118:mi/plaits/dsp/voice.h ****       lp_f = 0.00375f * stmlib::SemitonesToRatio(84.7f * ratio);
 119:mi/plaits/dsp/voice.h ****     } else if (dj_eq > 0.55f) {
 120:mi/plaits/dsp/voice.h ****       // Cubic mapping for HP: Smooth transition from 0Hz (Bypass) to 8kHz
 121:mi/plaits/dsp/voice.h ****       // 8000 / 32000 = 0.25f
 122:mi/plaits/dsp/voice.h ****       float ratio = (dj_eq - 0.55f) / 0.45f;
 123:mi/plaits/dsp/voice.h ****       hp_f = (ratio * ratio * ratio) * 0.25f;
 124:mi/plaits/dsp/voice.h ****     }
 125:mi/plaits/dsp/voice.h ****     
 126:mi/plaits/dsp/voice.h ****     lp_.set_f_q<stmlib::FREQUENCY_DIRTY>(lp_f, q);
 127:mi/plaits/dsp/voice.h ****     hp_.set_f_q<stmlib::FREQUENCY_DIRTY>(hp_f, q);
 128:mi/plaits/dsp/voice.h **** 
 129:mi/plaits/dsp/voice.h ****     for (size_t i = 0; i < size; ++i) {
 130:mi/plaits/dsp/voice.h ****       float s = in[i];
 131:mi/plaits/dsp/voice.h ****       s = lp_.Process<stmlib::FILTER_MODE_LOW_PASS>(s);
 132:mi/plaits/dsp/voice.h ****       s = hp_.Process<stmlib::FILTER_MODE_HIGH_PASS>(s);
 133:mi/plaits/dsp/voice.h ****       in[i] = s;
 134:mi/plaits/dsp/voice.h ****     }
 135:mi/plaits/dsp/voice.h **** 
 136:mi/plaits/dsp/voice.h ****     const float post_gain = (gain < 0.0f ? 1.0f : gain) * -32767.0f;
 137:mi/plaits/dsp/voice.h ****     if (!bypass_lpg) {
 138:mi/plaits/dsp/voice.h ****       lpg_.Process(
 139:mi/plaits/dsp/voice.h ****           post_gain * low_pass_gate_gain,
 140:mi/plaits/dsp/voice.h ****           low_pass_gate_frequency,
 141:mi/plaits/dsp/voice.h ****           low_pass_gate_hf_bleed,
 142:mi/plaits/dsp/voice.h ****           in,
 143:mi/plaits/dsp/voice.h ****           out,
ARM GAS  /var/folders/9k/zk1mgrrd7wg4__6zvxvr9w8m0000gn/T//cczqcbrU.s 			page 4


 144:mi/plaits/dsp/voice.h ****           size,
 145:mi/plaits/dsp/voice.h ****           stride);
 146:mi/plaits/dsp/voice.h ****     } else {
 147:mi/plaits/dsp/voice.h ****       while (size--) {
 148:mi/plaits/dsp/voice.h ****         *out = stmlib::Clip16(1 + static_cast<int32_t>(*in++ * post_gain));
 149:mi/plaits/dsp/voice.h ****         out += stride;
 150:mi/plaits/dsp/voice.h ****       }
 151:mi/plaits/dsp/voice.h ****     }
 152:mi/plaits/dsp/voice.h ****   }
 153:mi/plaits/dsp/voice.h ****   
 154:mi/plaits/dsp/voice.h ****  private:
 155:mi/plaits/dsp/voice.h ****   stmlib::Limiter limiter_;
 156:mi/plaits/dsp/voice.h ****   LowPassGate lpg_;
 157:mi/plaits/dsp/voice.h ****   stmlib::Svf lp_;
 158:mi/plaits/dsp/voice.h ****   stmlib::Svf hp_;
 159:mi/plaits/dsp/voice.h ****   
 160:mi/plaits/dsp/voice.h ****   DISALLOW_COPY_AND_ASSIGN(ChannelPostProcessor);
 161:mi/plaits/dsp/voice.h **** };
