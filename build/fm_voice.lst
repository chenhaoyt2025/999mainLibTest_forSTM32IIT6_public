 406:mi/stmlib/dsp/filter.h ****     float state_1 = state_1_;
 407:mi/stmlib/dsp/filter.h ****     float state_2 = state_2_;
 408:mi/stmlib/dsp/filter.h ****     float hp_gain = std::min(-mode * 2.0f + 1.0f, 0.0f);
 409:mi/stmlib/dsp/filter.h ****     float bp_gain = 1.0f - 2.0f * fabsf(mode - 0.5f);
 410:mi/stmlib/dsp/filter.h ****     float lp_gain = std::max(1.0f - mode * 2.0f, 0.0f);
 411:mi/stmlib/dsp/filter.h ****     while (size--) {
 412:mi/stmlib/dsp/filter.h ****       hp = (*in - r_ * state_1 - g_ * state_1 - state_2) * h_;
 413:mi/stmlib/dsp/filter.h ****       bp = g_ * hp + state_1;
 414:mi/stmlib/dsp/filter.h ****       state_1 = g_ * hp + bp;
 415:mi/stmlib/dsp/filter.h ****       lp = g_ * bp + state_2;
 416:mi/stmlib/dsp/filter.h ****       state_2 = g_ * bp + lp;
 417:mi/stmlib/dsp/filter.h ****       *out = hp_gain * hp + bp_gain * bp + lp_gain * lp;
 418:mi/stmlib/dsp/filter.h ****       ++in;
 419:mi/stmlib/dsp/filter.h ****       ++out;
 420:mi/stmlib/dsp/filter.h ****     }
 421:mi/stmlib/dsp/filter.h ****     state_1_ = state_1;
 422:mi/stmlib/dsp/filter.h ****     state_2_ = state_2;
 423:mi/stmlib/dsp/filter.h ****   }
 424:mi/stmlib/dsp/filter.h ****   
 425:mi/stmlib/dsp/filter.h ****   template<FilterMode mode>
 426:mi/stmlib/dsp/filter.h ****   inline void Process(
 427:mi/stmlib/dsp/filter.h ****       const float* in, float* out_1, float* out_2, size_t size,
 428:mi/stmlib/dsp/filter.h ****       float gain_1, float gain_2) {
 429:mi/stmlib/dsp/filter.h ****     float hp, bp, lp;
 430:mi/stmlib/dsp/filter.h ****     float state_1 = state_1_;
 431:mi/stmlib/dsp/filter.h ****     float state_2 = state_2_;
 432:mi/stmlib/dsp/filter.h ****     
 433:mi/stmlib/dsp/filter.h ****     while (size--) {
 434:mi/stmlib/dsp/filter.h ****       hp = (*in - r_ * state_1 - g_ * state_1 - state_2) * h_;
ARM GAS  /var/folders/9k/zk1mgrrd7wg4__6zvxvr9w8m0000gn/T//ccqMM9yh.s 			page 12


 435:mi/stmlib/dsp/filter.h ****       bp = g_ * hp + state_1;
 436:mi/stmlib/dsp/filter.h ****       state_1 = g_ * hp + bp;
 437:mi/stmlib/dsp/filter.h ****       lp = g_ * bp + state_2;
 438:mi/stmlib/dsp/filter.h ****       state_2 = g_ * bp + lp;
 439:mi/stmlib/dsp/filter.h ****     
 440:mi/stmlib/dsp/filter.h ****       float value;
 441:mi/stmlib/dsp/filter.h ****       if (mode == FILTER_MODE_LOW_PASS) {
 442:mi/stmlib/dsp/filter.h ****         value = lp;
 443:mi/stmlib/dsp/filter.h ****       } else if (mode == FILTER_MODE_BAND_PASS) {
 444:mi/stmlib/dsp/filter.h ****         value = bp;
 445:mi/stmlib/dsp/filter.h ****       } else if (mode == FILTER_MODE_BAND_PASS_NORMALIZED) {
 446:mi/stmlib/dsp/filter.h ****         value = bp * r_;
 447:mi/stmlib/dsp/filter.h ****       } else if (mode == FILTER_MODE_HIGH_PASS) {
 448:mi/stmlib/dsp/filter.h ****         value = hp;
 449:mi/stmlib/dsp/filter.h ****       }
 450:mi/stmlib/dsp/filter.h ****       
 451:mi/stmlib/dsp/filter.h ****       *out_1 += value * gain_1;
 452:mi/stmlib/dsp/filter.h ****       *out_2 += value * gain_2;
 453:mi/stmlib/dsp/filter.h ****       ++out_1;
 454:mi/stmlib/dsp/filter.h ****       ++out_2;
 455:mi/stmlib/dsp/filter.h ****       ++in;
 456:mi/stmlib/dsp/filter.h ****     }
 457:mi/stmlib/dsp/filter.h ****     state_1_ = state_1;
 458:mi/stmlib/dsp/filter.h ****     state_2_ = state_2;
 459:mi/stmlib/dsp/filter.h ****   }
 460:mi/stmlib/dsp/filter.h ****   
 461:mi/stmlib/dsp/filter.h ****   inline float g() const { return g_; }
 462:mi/stmlib/dsp/filter.h ****   inline float r() const { return r_; }
 463:mi/stmlib/dsp/filter.h ****   inline float h() const { return h_; }
 464:mi/stmlib/dsp/filter.h ****   
 465:mi/stmlib/dsp/filter.h ****  private:
 466:mi/stmlib/dsp/filter.h ****   float g_;
 467:mi/stmlib/dsp/filter.h ****   float r_;
 468:mi/stmlib/dsp/filter.h ****   float h_;
 469:mi/stmlib/dsp/filter.h **** 
 470:mi/stmlib/dsp/filter.h ****   float state_1_;
 471:mi/stmlib/dsp/filter.h ****   float state_2_;
