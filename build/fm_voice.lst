  92:mi/stmlib/dsp/filter.h **** class OnePole {
ARM GAS  /var/folders/9k/zk1mgrrd7wg4__6zvxvr9w8m0000gn/T//ccqMM9yh.s 			page 6


  93:mi/stmlib/dsp/filter.h ****  public:
  94:mi/stmlib/dsp/filter.h ****   OnePole() { }
  95:mi/stmlib/dsp/filter.h ****   ~OnePole() { }
  96:mi/stmlib/dsp/filter.h ****   
  97:mi/stmlib/dsp/filter.h ****   void Init() {
  98:mi/stmlib/dsp/filter.h ****     set_f<FREQUENCY_DIRTY>(0.01f);
  99:mi/stmlib/dsp/filter.h ****     Reset();
 100:mi/stmlib/dsp/filter.h ****   }
 101:mi/stmlib/dsp/filter.h ****   
 102:mi/stmlib/dsp/filter.h ****   void Reset() {
 103:mi/stmlib/dsp/filter.h ****     state_ = 0.0f;
 104:mi/stmlib/dsp/filter.h ****   }
 105:mi/stmlib/dsp/filter.h ****   
 106:mi/stmlib/dsp/filter.h ****   template<FrequencyApproximation approximation>
 107:mi/stmlib/dsp/filter.h ****   static inline float tan(float f) {
 108:mi/stmlib/dsp/filter.h ****     if (approximation == FREQUENCY_EXACT) {
 109:mi/stmlib/dsp/filter.h ****       // Clip coefficient to about 100.
 110:mi/stmlib/dsp/filter.h ****       f = f < 0.497f ? f : 0.497f;
 111:mi/stmlib/dsp/filter.h ****       return tanf(M_PI_F * f);
 112:mi/stmlib/dsp/filter.h ****     } else if (approximation == FREQUENCY_DIRTY) {
 113:mi/stmlib/dsp/filter.h ****       // Optimized for frequencies below 8kHz.
 114:mi/stmlib/dsp/filter.h ****       const float a = 3.736e-01f * M_PI_POW_3;
 115:mi/stmlib/dsp/filter.h ****       return f * (M_PI_F + a * f * f);
 116:mi/stmlib/dsp/filter.h ****     } else if (approximation == FREQUENCY_FAST) {
 117:mi/stmlib/dsp/filter.h ****       // The usual tangent approximation uses 3.1755e-01 and 2.033e-01, but
 118:mi/stmlib/dsp/filter.h ****       // the coefficients used here are optimized to minimize error for the
 119:mi/stmlib/dsp/filter.h ****       // 16Hz to 16kHz range, with a sample rate of 48kHz.
 120:mi/stmlib/dsp/filter.h ****       const float a = 3.260e-01f * M_PI_POW_3;
 121:mi/stmlib/dsp/filter.h ****       const float b = 1.823e-01f * M_PI_POW_5;
 122:mi/stmlib/dsp/filter.h ****       float f2 = f * f;
 123:mi/stmlib/dsp/filter.h ****       return f * (M_PI_F + f2 * (a + b * f2));
 124:mi/stmlib/dsp/filter.h ****     } else if (approximation == FREQUENCY_ACCURATE) {
 125:mi/stmlib/dsp/filter.h ****       // These coefficients don't need to be tweaked for the audio range.
 126:mi/stmlib/dsp/filter.h ****       const float a = 3.333314036e-01f * M_PI_POW_3;
 127:mi/stmlib/dsp/filter.h ****       const float b = 1.333923995e-01f * M_PI_POW_5;
 128:mi/stmlib/dsp/filter.h ****       const float c = 5.33740603e-02f * M_PI_POW_7;
 129:mi/stmlib/dsp/filter.h ****       const float d = 2.900525e-03f * M_PI_POW_9;
 130:mi/stmlib/dsp/filter.h ****       const float e = 9.5168091e-03f * M_PI_POW_11;
 131:mi/stmlib/dsp/filter.h ****       float f2 = f * f;
 132:mi/stmlib/dsp/filter.h ****       return f * (M_PI_F + f2 * (a + f2 * (b + f2 * (c + f2 * (d + f2 * e)))));
 133:mi/stmlib/dsp/filter.h ****     }
 134:mi/stmlib/dsp/filter.h ****   }
 135:mi/stmlib/dsp/filter.h ****   
 136:mi/stmlib/dsp/filter.h ****   // Set frequency and resonance from true units. Various approximations
 137:mi/stmlib/dsp/filter.h ****   // are available to avoid the cost of tanf.
 138:mi/stmlib/dsp/filter.h ****   template<FrequencyApproximation approximation>
 139:mi/stmlib/dsp/filter.h ****   inline void set_f(float f) {
 140:mi/stmlib/dsp/filter.h ****     g_ = tan<approximation>(f);
 141:mi/stmlib/dsp/filter.h ****     gi_ = 1.0f / (1.0f + g_);
 142:mi/stmlib/dsp/filter.h ****   }
 143:mi/stmlib/dsp/filter.h ****   
 144:mi/stmlib/dsp/filter.h ****   template<FilterMode mode>
 145:mi/stmlib/dsp/filter.h ****   inline float Process(float in) {
 146:mi/stmlib/dsp/filter.h ****     float lp;
 147:mi/stmlib/dsp/filter.h ****     lp = (g_ * in + state_) * gi_;
