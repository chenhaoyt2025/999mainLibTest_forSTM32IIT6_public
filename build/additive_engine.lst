  27:mi/plaits/dsp/oscillator/harmonic_oscillator.h **** // Harmonic oscillator based on Chebyshev polynomials.
  28:mi/plaits/dsp/oscillator/harmonic_oscillator.h **** // Works well for a small number of harmonics. For the higher order harmonics,
  29:mi/plaits/dsp/oscillator/harmonic_oscillator.h **** // we need to reinitialize the recurrence by computing two high harmonics.
