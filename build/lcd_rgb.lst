 723:BSP/LTDC/lcd_rgb.c **** 		else if(LCD.Direction == Direction_V)	//ДЙжБЗНЯђ
 724:BSP/LTDC/lcd_rgb.c **** 		{
 725:BSP/LTDC/lcd_rgb.c **** 			*(__IO uint16_t*)( LCD.LayerMemoryAdd + 2*((LCD_Height - x - 1)*LCD_Width + y) ) = color ;
