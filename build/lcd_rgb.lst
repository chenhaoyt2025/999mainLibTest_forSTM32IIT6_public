 642:BSP/LTDC/lcd_rgb.c **** void LCD_ClearRect(uint16_t x, uint16_t y, uint16_t width, uint16_t height)
 643:BSP/LTDC/lcd_rgb.c **** {
 644:BSP/LTDC/lcd_rgb.c **** 
 645:BSP/LTDC/lcd_rgb.c **** 	DMA2D->CR	  &=	~(DMA2D_CR_START);				//	ЭЃжЙDMA2D
 646:BSP/LTDC/lcd_rgb.c **** 	DMA2D->CR		=	DMA2D_R2M;							//	МФДцЦїЕНSDRAM
 647:BSP/LTDC/lcd_rgb.c **** 	DMA2D->OPFCCR	=	LCD.ColorMode;						//	ЩшжУбеЩЋИёЪН
 648:BSP/LTDC/lcd_rgb.c **** 	DMA2D->OCOLR	=	LCD.BackColor ;					//	беЩЋ
 649:BSP/LTDC/lcd_rgb.c **** 	
 650:BSP/LTDC/lcd_rgb.c **** 	if(LCD.Direction == Direction_H)  //КсЦСЬюГф
 651:BSP/LTDC/lcd_rgb.c **** 	{		
 652:BSP/LTDC/lcd_rgb.c **** 		DMA2D->OOR		=	LCD_Width - width;				//	ЩшжУааЦЋвЦ 
 653:BSP/LTDC/lcd_rgb.c **** 		DMA2D->OMAR		=	LCD.LayerMemoryAdd + LCD.BytesPerPixel*(LCD_Width * y + x);	// ЕижЗ;
 654:BSP/LTDC/lcd_rgb.c **** 		DMA2D->NLR		=	(width<<16)|(height);			//	ЩшЖЈГЄЖШКЭПэЖШ		
 655:BSP/LTDC/lcd_rgb.c **** 	}
 656:BSP/LTDC/lcd_rgb.c **** 	else	//ЪњЦСЬюГф
 657:BSP/LTDC/lcd_rgb.c **** 	{		
 658:BSP/LTDC/lcd_rgb.c **** 		DMA2D->OOR		=	LCD_Width - height;		//	ЩшжУааЦЋвЦ 
 659:BSP/LTDC/lcd_rgb.c **** 		DMA2D->OMAR		=	LCD.LayerMemoryAdd + LCD.BytesPerPixel*((LCD_Height - x - 1 - width)*LCD_Width + y
 660:BSP/LTDC/lcd_rgb.c **** 		DMA2D->NLR		=	(width)|(height<<16);	//	ЩшЖЈГЄЖШКЭПэЖШ		
 661:BSP/LTDC/lcd_rgb.c **** 	}		
 662:BSP/LTDC/lcd_rgb.c **** 
 663:BSP/LTDC/lcd_rgb.c **** 	DMA2D->CR	  |=	DMA2D_CR_START;					//	ЦєЖЏDMA2D
 664:BSP/LTDC/lcd_rgb.c **** 		
 665:BSP/LTDC/lcd_rgb.c **** 	while (DMA2D->CR & DMA2D_CR_START) ;			//	ЕШД§ДЋЪфЭъГЩ
 666:BSP/LTDC/lcd_rgb.c **** 
 667:BSP/LTDC/lcd_rgb.c **** }
 668:BSP/LTDC/lcd_rgb.c **** 
