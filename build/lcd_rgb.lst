 693:BSP/LTDC/lcd_rgb.c **** 			*(__IO uint32_t*)( LCD.LayerMemoryAdd + 4*(x + y*LCD_Width) ) = color ; 	
 694:BSP/LTDC/lcd_rgb.c **** 		}
 695:BSP/LTDC/lcd_rgb.c **** 		else if(LCD.Direction == Direction_V)	//ДЙжБЗНЯђ
