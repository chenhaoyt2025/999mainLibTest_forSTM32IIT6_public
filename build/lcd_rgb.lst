 707:BSP/LTDC/lcd_rgb.c **** 			*(__IO uint8_t*)( LCD.LayerMemoryAdd + 3*(x + y*LCD_Width) + 2 ) = color>>16 ; 	
 708:BSP/LTDC/lcd_rgb.c **** 		}
 709:BSP/LTDC/lcd_rgb.c **** 		else if(LCD.Direction == Direction_V)	//ДЙжБЗНЯђ
 710:BSP/LTDC/lcd_rgb.c **** 		{
 711:BSP/LTDC/lcd_rgb.c **** 			*(__IO uint16_t*)( LCD.LayerMemoryAdd + 3*((LCD_Height - x - 1)*LCD_Width + y) ) = color ; 
 712:BSP/LTDC/lcd_rgb.c **** 			*(__IO uint8_t*)( LCD.LayerMemoryAdd + 3*((LCD_Height - x - 1)*LCD_Width + y) +2) = color>>16 ; 
 713:BSP/LTDC/lcd_rgb.c **** 		}	
 714:BSP/LTDC/lcd_rgb.c **** 	}
 715:BSP/LTDC/lcd_rgb.c **** 
 716:BSP/LTDC/lcd_rgb.c **** /*----------------------- 16ЮЛЩЋ ARGB1555ЁЂRGB565ЛђепARGB4444 ФЃЪН ----------------------*/	
 717:BSP/LTDC/lcd_rgb.c **** 	else		
 718:BSP/LTDC/lcd_rgb.c **** 	{
