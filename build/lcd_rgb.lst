 779:BSP/LTDC/lcd_rgb.c **** 		{
 780:BSP/LTDC/lcd_rgb.c **** 			color = *(__IO uint16_t*)( LCD.LayerMemoryAdd + 2*(x + y*LCD_Width) ); 	
 781:BSP/LTDC/lcd_rgb.c **** 		}
 782:BSP/LTDC/lcd_rgb.c **** 		else if(LCD.Direction == Direction_V)	//ДЙжБЗНЯђ
 783:BSP/LTDC/lcd_rgb.c **** 		{
 784:BSP/LTDC/lcd_rgb.c **** 			color = *(__IO uint16_t*)( LCD.LayerMemoryAdd + 2*((LCD_Height - x - 1)*LCD_Width + y) );
 785:BSP/LTDC/lcd_rgb.c **** 		}	
 786:BSP/LTDC/lcd_rgb.c **** 	}
 787:BSP/LTDC/lcd_rgb.c **** 	return color;
 788:BSP/LTDC/lcd_rgb.c **** }  
