 806:BSP/LTDC/lcd_rgb.c **** void LCD_DisplayChar(uint16_t x, uint16_t y,uint8_t c)
 807:BSP/LTDC/lcd_rgb.c **** {
 808:BSP/LTDC/lcd_rgb.c **** 	uint16_t  index = 0, counter = 0;		// МЦЪ§БфСП
 809:BSP/LTDC/lcd_rgb.c ****    uint8_t   disChar;		//ДцДЂзжЗћЕФЕижЗ
 810:BSP/LTDC/lcd_rgb.c **** 	uint16_t  Xaddress = x; //ЫЎЦНзјБъ
 811:BSP/LTDC/lcd_rgb.c **** 	
 812:BSP/LTDC/lcd_rgb.c **** 	c = c - 32; 	// МЦЫуASCIIзжЗћЕФЦЋвЦ
 813:BSP/LTDC/lcd_rgb.c **** 	
 814:BSP/LTDC/lcd_rgb.c **** 	for(index = 0; index < LCD_Fonts->Sizes; index++)	
 815:BSP/LTDC/lcd_rgb.c **** 	{
 816:BSP/LTDC/lcd_rgb.c **** 		disChar = LCD_Fonts->pTable[c*LCD_Fonts->Sizes + index]; //ЛёШЁзжЗћЕФФЃжЕ
 817:BSP/LTDC/lcd_rgb.c **** 		for(counter = 0; counter < 8; counter++)
 818:BSP/LTDC/lcd_rgb.c **** 		{ 
 819:BSP/LTDC/lcd_rgb.c **** 			if(disChar & 0x01)	
 820:BSP/LTDC/lcd_rgb.c **** 			{		
 821:BSP/LTDC/lcd_rgb.c **** 				LCD_DrawPoint(Xaddress,y,LCD.Color);		//ЕБЧАФЃжЕВЛЮЊ0ЪБЃЌЪЙгУЛ­БЪЩЋЛцЕу
 822:BSP/LTDC/lcd_rgb.c **** 			}
 823:BSP/LTDC/lcd_rgb.c **** 			else		
 824:BSP/LTDC/lcd_rgb.c **** 			{		
 825:BSP/LTDC/lcd_rgb.c **** 				LCD_DrawPoint(Xaddress,y,LCD.BackColor);	//ЗёдђЪЙгУБГОАЩЋЛцжЦЕу
 826:BSP/LTDC/lcd_rgb.c **** 			}
 827:BSP/LTDC/lcd_rgb.c **** 			disChar >>= 1;
 828:BSP/LTDC/lcd_rgb.c **** 			Xaddress++;  //ЫЎЦНзјБъздМг
 829:BSP/LTDC/lcd_rgb.c **** 			
 830:BSP/LTDC/lcd_rgb.c **** 			if( (Xaddress - x)==LCD_Fonts->Width ) //ШчЙћЫЎЦНзјБъДяЕНСЫзжЗћПэЖШЃЌдђЭЫГіЕБЧАб­ЛЗ
 831:BSP/LTDC/lcd_rgb.c **** 			{													//НјШыЯТвЛааЕФЛцжЦ
 832:BSP/LTDC/lcd_rgb.c **** 				Xaddress = x;
 833:BSP/LTDC/lcd_rgb.c **** 				y++;
 834:BSP/LTDC/lcd_rgb.c **** 				break;
 835:BSP/LTDC/lcd_rgb.c **** 			}
 836:BSP/LTDC/lcd_rgb.c **** 		}	
 837:BSP/LTDC/lcd_rgb.c **** 	}
 838:BSP/LTDC/lcd_rgb.c **** }
