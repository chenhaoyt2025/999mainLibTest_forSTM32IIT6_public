 137:mi/stmlib/dsp/filter.h ****   // are available to avoid the cost of tanf.
 138:mi/stmlib/dsp/filter.h ****   template<FrequencyApproximation approximation>
 139:mi/stmlib/dsp/filter.h ****   inline void set_f(float f) {
 140:mi/stmlib/dsp/filter.h ****     g_ = tan<approximation>(f);
