  26:mi/stmlib/dsp/cosine_oscillator.h **** //
  27:mi/stmlib/dsp/cosine_oscillator.h **** // Cosine oscillator. Generates a cosine between 0.0 and 1.0 with minimal
  28:mi/stmlib/dsp/cosine_oscillator.h **** // CPU use.
  29:mi/stmlib/dsp/cosine_oscillator.h **** 
  30:mi/stmlib/dsp/cosine_oscillator.h **** #ifndef STMLIB_DSP_COSINE_OSCILLATOR_H_
  31:mi/stmlib/dsp/cosine_oscillator.h **** #define STMLIB_DSP_COSINE_OSCILLATOR_H_
  32:mi/stmlib/dsp/cosine_oscillator.h **** 
  33:mi/stmlib/dsp/cosine_oscillator.h **** #include "stmlib/stmlib.h"
  34:mi/stmlib/dsp/cosine_oscillator.h **** 
  35:mi/stmlib/dsp/cosine_oscillator.h **** #include <cmath>
  36:mi/stmlib/dsp/cosine_oscillator.h **** 
  37:mi/stmlib/dsp/cosine_oscillator.h **** namespace stmlib {
  38:mi/stmlib/dsp/cosine_oscillator.h **** 
  39:mi/stmlib/dsp/cosine_oscillator.h **** enum CosineOscillatorMode {
ARM GAS  /var/folders/9k/zk1mgrrd7wg4__6zvxvr9w8m0000gn/T//ccVlS6UW.s 			page 72


  40:mi/stmlib/dsp/cosine_oscillator.h ****   COSINE_OSCILLATOR_APPROXIMATE,
  41:mi/stmlib/dsp/cosine_oscillator.h ****   COSINE_OSCILLATOR_EXACT
  42:mi/stmlib/dsp/cosine_oscillator.h **** };
  43:mi/stmlib/dsp/cosine_oscillator.h **** 
  44:mi/stmlib/dsp/cosine_oscillator.h **** class CosineOscillator {
  45:mi/stmlib/dsp/cosine_oscillator.h ****  public:
  46:mi/stmlib/dsp/cosine_oscillator.h ****   CosineOscillator() { }
  47:mi/stmlib/dsp/cosine_oscillator.h ****   ~CosineOscillator() { }
  48:mi/stmlib/dsp/cosine_oscillator.h **** 
  49:mi/stmlib/dsp/cosine_oscillator.h ****   template<CosineOscillatorMode mode>
  50:mi/stmlib/dsp/cosine_oscillator.h ****   inline void Init(float frequency) {
  51:mi/stmlib/dsp/cosine_oscillator.h ****     if (mode == COSINE_OSCILLATOR_APPROXIMATE) {
  52:mi/stmlib/dsp/cosine_oscillator.h ****       InitApproximate(frequency);
  53:mi/stmlib/dsp/cosine_oscillator.h ****     } else {
  54:mi/stmlib/dsp/cosine_oscillator.h ****       iir_coefficient_ = 2.0f * cosf(2.0f * float(M_PI) * frequency);
  55:mi/stmlib/dsp/cosine_oscillator.h ****       initial_amplitude_ = iir_coefficient_ * 0.25f;
  56:mi/stmlib/dsp/cosine_oscillator.h ****     }
  57:mi/stmlib/dsp/cosine_oscillator.h ****     Start();
  58:mi/stmlib/dsp/cosine_oscillator.h ****   }
  59:mi/stmlib/dsp/cosine_oscillator.h ****   
  60:mi/stmlib/dsp/cosine_oscillator.h ****   inline void InitApproximate(float frequency) {
  61:mi/stmlib/dsp/cosine_oscillator.h ****     float sign = 16.0f;
  62:mi/stmlib/dsp/cosine_oscillator.h ****     frequency -= 0.25f;
  63:mi/stmlib/dsp/cosine_oscillator.h ****     if (frequency < 0.0f) {
  64:mi/stmlib/dsp/cosine_oscillator.h ****       frequency = -frequency;
  65:mi/stmlib/dsp/cosine_oscillator.h ****     } else {
  66:mi/stmlib/dsp/cosine_oscillator.h ****       if (frequency > 0.5f) {
  67:mi/stmlib/dsp/cosine_oscillator.h ****         frequency -= 0.5f;
  68:mi/stmlib/dsp/cosine_oscillator.h ****       } else {
  69:mi/stmlib/dsp/cosine_oscillator.h ****         sign = -16.0f;
  70:mi/stmlib/dsp/cosine_oscillator.h ****       }
  71:mi/stmlib/dsp/cosine_oscillator.h ****     }
  72:mi/stmlib/dsp/cosine_oscillator.h ****     iir_coefficient_ = sign * frequency * (1.0f - 2.0f * frequency);
  73:mi/stmlib/dsp/cosine_oscillator.h ****     initial_amplitude_ = iir_coefficient_ * 0.25f;
  74:mi/stmlib/dsp/cosine_oscillator.h ****   }
  75:mi/stmlib/dsp/cosine_oscillator.h ****   
  76:mi/stmlib/dsp/cosine_oscillator.h ****   inline void Start() {
  77:mi/stmlib/dsp/cosine_oscillator.h ****     y1_ = initial_amplitude_;
  78:mi/stmlib/dsp/cosine_oscillator.h ****     y0_ = 0.5f;
  79:mi/stmlib/dsp/cosine_oscillator.h ****   }
  80:mi/stmlib/dsp/cosine_oscillator.h ****   
  81:mi/stmlib/dsp/cosine_oscillator.h ****   inline float value() const {
  82:mi/stmlib/dsp/cosine_oscillator.h ****     return y1_ + 0.5f;
  83:mi/stmlib/dsp/cosine_oscillator.h ****   }
