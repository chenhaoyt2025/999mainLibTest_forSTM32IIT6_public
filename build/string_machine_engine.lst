 493:mi/stmlib/dsp/filter.h ****   // Set frequency and resonance from true units. Various approximations
 494:mi/stmlib/dsp/filter.h ****   // are available to avoid the cost of sinf.
 495:mi/stmlib/dsp/filter.h ****   template<FrequencyApproximation approximation>
 496:mi/stmlib/dsp/filter.h ****   inline void set_f_q(float f, float resonance) {
 497:mi/stmlib/dsp/filter.h ****     if (approximation == FREQUENCY_EXACT) {
