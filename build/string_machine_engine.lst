 239:mi/plaits/dsp/fx/fx_engine.h ****     template<typename D>
 240:mi/plaits/dsp/fx/fx_engine.h ****     inline void Interpolate(
 241:mi/plaits/dsp/fx/fx_engine.h ****         D& d, float offset, LFOIndex index, float amplitude, float scale) {
 242:mi/plaits/dsp/fx/fx_engine.h ****       STATIC_ASSERT(D::base + D::length <= size, delay_memory_full);
 243:mi/plaits/dsp/fx/fx_engine.h ****       offset += amplitude * lfo_value_[index];
