 400:mi/stmlib/dsp/filter.h ****   inline void ProcessMultimodeLPtoHP(
 401:mi/stmlib/dsp/filter.h ****       const float* in,
 402:mi/stmlib/dsp/filter.h ****       float* out,
 403:mi/stmlib/dsp/filter.h ****       size_t size,
 404:mi/stmlib/dsp/filter.h ****       float mode) {
 405:mi/stmlib/dsp/filter.h ****     float hp, bp, lp;
 406:mi/stmlib/dsp/filter.h ****     float state_1 = state_1_;
 407:mi/stmlib/dsp/filter.h ****     float state_2 = state_2_;
 408:mi/stmlib/dsp/filter.h ****     float hp_gain = std::min(-mode * 2.0f + 1.0f, 0.0f);
 409:mi/stmlib/dsp/filter.h ****     float bp_gain = 1.0f - 2.0f * fabsf(mode - 0.5f);
 410:mi/stmlib/dsp/filter.h ****     float lp_gain = std::max(1.0f - mode * 2.0f, 0.0f);
 411:mi/stmlib/dsp/filter.h ****     while (size--) {
 412:mi/stmlib/dsp/filter.h ****       hp = (*in - r_ * state_1 - g_ * state_1 - state_2) * h_;
 413:mi/stmlib/dsp/filter.h ****       bp = g_ * hp + state_1;
 414:mi/stmlib/dsp/filter.h ****       state_1 = g_ * hp + bp;
 415:mi/stmlib/dsp/filter.h ****       lp = g_ * bp + state_2;
 416:mi/stmlib/dsp/filter.h ****       state_2 = g_ * bp + lp;
 417:mi/stmlib/dsp/filter.h ****       *out = hp_gain * hp + bp_gain * bp + lp_gain * lp;
 418:mi/stmlib/dsp/filter.h ****       ++in;
 419:mi/stmlib/dsp/filter.h ****       ++out;
 420:mi/stmlib/dsp/filter.h ****     }
 421:mi/stmlib/dsp/filter.h ****     state_1_ = state_1;
 422:mi/stmlib/dsp/filter.h ****     state_2_ = state_2;
 423:mi/stmlib/dsp/filter.h ****   }
