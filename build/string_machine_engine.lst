 358:mi/stmlib/dsp/filter.h ****         value = lp;
 359:mi/stmlib/dsp/filter.h ****       } else if (mode == FILTER_MODE_BAND_PASS) {
 360:mi/stmlib/dsp/filter.h ****         value = bp;
 361:mi/stmlib/dsp/filter.h ****       } else if (mode == FILTER_MODE_BAND_PASS_NORMALIZED) {
