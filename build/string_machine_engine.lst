 279:mi/stmlib/dsp/filter.h ****   template<FilterMode mode>
 280:mi/stmlib/dsp/filter.h ****   inline void Process(const float* in, float* out, size_t size) {
 281:mi/stmlib/dsp/filter.h ****     float hp, bp, lp;
