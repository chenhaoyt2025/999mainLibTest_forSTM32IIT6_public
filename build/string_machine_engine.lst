 245:mi/plaits/dsp/fx/fx_engine.h ****       float a = DataType<format>::Decompress(
 246:mi/plaits/dsp/fx/fx_engine.h ****           buffer_[(write_ptr_ + offset_integral + D::base) & MASK]);
 247:mi/plaits/dsp/fx/fx_engine.h ****       float b = DataType<format>::Decompress(
