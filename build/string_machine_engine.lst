 177:mi/stmlib/dsp/filter.h **** class Svf {
 178:mi/stmlib/dsp/filter.h ****  public:
 179:mi/stmlib/dsp/filter.h ****   Svf() { }
 180:mi/stmlib/dsp/filter.h ****   ~Svf() { }
 181:mi/stmlib/dsp/filter.h ****   
 182:mi/stmlib/dsp/filter.h ****   void Init() {
 183:mi/stmlib/dsp/filter.h ****     set_f_q<FREQUENCY_DIRTY>(0.01f, 100.0f);
 184:mi/stmlib/dsp/filter.h ****     Reset();
 185:mi/stmlib/dsp/filter.h ****   }
 186:mi/stmlib/dsp/filter.h ****   
 187:mi/stmlib/dsp/filter.h ****   void Reset() {
 188:mi/stmlib/dsp/filter.h ****     state_1_ = state_2_ = 0.0f;
 189:mi/stmlib/dsp/filter.h ****   }
 190:mi/stmlib/dsp/filter.h ****   
 191:mi/stmlib/dsp/filter.h ****   // Copy settings from another filter.
 192:mi/stmlib/dsp/filter.h ****   inline void set(const Svf& f) {
 193:mi/stmlib/dsp/filter.h ****     g_ = f.g();
 194:mi/stmlib/dsp/filter.h ****     r_ = f.r();
 195:mi/stmlib/dsp/filter.h ****     h_ = f.h();
 196:mi/stmlib/dsp/filter.h ****   }
 197:mi/stmlib/dsp/filter.h **** 
 198:mi/stmlib/dsp/filter.h ****   // Set all parameters from LUT.
 199:mi/stmlib/dsp/filter.h ****   inline void set_g_r_h(float g, float r, float h) {
 200:mi/stmlib/dsp/filter.h ****     g_ = g;
 201:mi/stmlib/dsp/filter.h ****     r_ = r;
 202:mi/stmlib/dsp/filter.h ****     h_ = h;
 203:mi/stmlib/dsp/filter.h ****   }
 204:mi/stmlib/dsp/filter.h ****   
 205:mi/stmlib/dsp/filter.h ****   // Set frequency and resonance coefficients from LUT, adjust remaining
 206:mi/stmlib/dsp/filter.h ****   // parameter.
 207:mi/stmlib/dsp/filter.h ****   inline void set_g_r(float g, float r) {
ARM GAS  /var/folders/9k/zk1mgrrd7wg4__6zvxvr9w8m0000gn/T//ccVlS6UW.s 			page 10


 208:mi/stmlib/dsp/filter.h ****     g_ = g;
 209:mi/stmlib/dsp/filter.h ****     r_ = r;
 210:mi/stmlib/dsp/filter.h ****     h_ = 1.0f / (1.0f + r_ * g_ + g_ * g_);
 211:mi/stmlib/dsp/filter.h ****   }
 212:mi/stmlib/dsp/filter.h **** 
 213:mi/stmlib/dsp/filter.h ****   // Set frequency from LUT, resonance in true units, adjust the rest.
 214:mi/stmlib/dsp/filter.h ****   inline void set_g_q(float g, float resonance) {
 215:mi/stmlib/dsp/filter.h ****     g_ = g;
 216:mi/stmlib/dsp/filter.h ****     r_ = 1.0f / resonance;
 217:mi/stmlib/dsp/filter.h ****     h_ = 1.0f / (1.0f + r_ * g_ + g_ * g_);
 218:mi/stmlib/dsp/filter.h ****   }
 219:mi/stmlib/dsp/filter.h **** 
 220:mi/stmlib/dsp/filter.h ****   // Set frequency and resonance from true units. Various approximations
 221:mi/stmlib/dsp/filter.h ****   // are available to avoid the cost of tanf.
 222:mi/stmlib/dsp/filter.h ****   template<FrequencyApproximation approximation>
 223:mi/stmlib/dsp/filter.h ****   inline void set_f_q(float f, float resonance) {
 224:mi/stmlib/dsp/filter.h ****     g_ = OnePole::tan<approximation>(f);
 225:mi/stmlib/dsp/filter.h ****     r_ = 1.0f / resonance;
 226:mi/stmlib/dsp/filter.h ****     h_ = 1.0f / (1.0f + r_ * g_ + g_ * g_);
 227:mi/stmlib/dsp/filter.h ****   }
 228:mi/stmlib/dsp/filter.h ****   
 229:mi/stmlib/dsp/filter.h ****   template<FilterMode mode>
 230:mi/stmlib/dsp/filter.h ****   inline float Process(float in) {
 231:mi/stmlib/dsp/filter.h ****     float hp, bp, lp;
 232:mi/stmlib/dsp/filter.h ****     hp = (in - r_ * state_1_ - g_ * state_1_ - state_2_) * h_;
 233:mi/stmlib/dsp/filter.h ****     bp = g_ * hp + state_1_;
 234:mi/stmlib/dsp/filter.h ****     state_1_ = g_ * hp + bp;
 235:mi/stmlib/dsp/filter.h ****     lp = g_ * bp + state_2_;
 236:mi/stmlib/dsp/filter.h ****     state_2_ = g_ * bp + lp;
 237:mi/stmlib/dsp/filter.h ****     
 238:mi/stmlib/dsp/filter.h ****     if (mode == FILTER_MODE_LOW_PASS) {
 239:mi/stmlib/dsp/filter.h ****       return lp;
 240:mi/stmlib/dsp/filter.h ****     } else if (mode == FILTER_MODE_BAND_PASS) {
 241:mi/stmlib/dsp/filter.h ****       return bp;
 242:mi/stmlib/dsp/filter.h ****     } else if (mode == FILTER_MODE_BAND_PASS_NORMALIZED) {
 243:mi/stmlib/dsp/filter.h ****       return bp * r_;
 244:mi/stmlib/dsp/filter.h ****     } else if (mode == FILTER_MODE_HIGH_PASS) {
 245:mi/stmlib/dsp/filter.h ****       return hp;
 246:mi/stmlib/dsp/filter.h ****     }
 247:mi/stmlib/dsp/filter.h ****   }
 248:mi/stmlib/dsp/filter.h ****   
 249:mi/stmlib/dsp/filter.h ****   template<FilterMode mode_1, FilterMode mode_2>
 250:mi/stmlib/dsp/filter.h ****   inline void Process(float in, float* out_1, float* out_2) {
 251:mi/stmlib/dsp/filter.h ****     float hp, bp, lp;
 252:mi/stmlib/dsp/filter.h ****     hp = (in - r_ * state_1_ - g_ * state_1_ - state_2_) * h_;
 253:mi/stmlib/dsp/filter.h ****     bp = g_ * hp + state_1_;
 254:mi/stmlib/dsp/filter.h ****     state_1_ = g_ * hp + bp;
 255:mi/stmlib/dsp/filter.h ****     lp = g_ * bp + state_2_;
 256:mi/stmlib/dsp/filter.h ****     state_2_ = g_ * bp + lp;
 257:mi/stmlib/dsp/filter.h ****     
 258:mi/stmlib/dsp/filter.h ****     if (mode_1 == FILTER_MODE_LOW_PASS) {
 259:mi/stmlib/dsp/filter.h ****       *out_1 = lp;
 260:mi/stmlib/dsp/filter.h ****     } else if (mode_1 == FILTER_MODE_BAND_PASS) {
 261:mi/stmlib/dsp/filter.h ****       *out_1 = bp;
 262:mi/stmlib/dsp/filter.h ****     } else if (mode_1 == FILTER_MODE_BAND_PASS_NORMALIZED) {
 263:mi/stmlib/dsp/filter.h ****       *out_1 = bp * r_;
 264:mi/stmlib/dsp/filter.h ****     } else if (mode_1 == FILTER_MODE_HIGH_PASS) {
ARM GAS  /var/folders/9k/zk1mgrrd7wg4__6zvxvr9w8m0000gn/T//ccVlS6UW.s 			page 11


 265:mi/stmlib/dsp/filter.h ****       *out_1 = hp;
 266:mi/stmlib/dsp/filter.h ****     }
 267:mi/stmlib/dsp/filter.h **** 
