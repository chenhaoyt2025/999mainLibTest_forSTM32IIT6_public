 379:mi/stmlib/dsp/filter.h ****       float mode) {
 380:mi/stmlib/dsp/filter.h ****     float hp, bp, lp;
 381:mi/stmlib/dsp/filter.h ****     float state_1 = state_1_;
 382:mi/stmlib/dsp/filter.h ****     float state_2 = state_2_;
 383:mi/stmlib/dsp/filter.h ****     float hp_gain = mode < 0.5f ? -mode * 2.0f : -2.0f + mode * 2.0f;
 384:mi/stmlib/dsp/filter.h ****     float lp_gain = mode < 0.5f ? 1.0f - mode * 2.0f : 0.0f;
 385:mi/stmlib/dsp/filter.h ****     float bp_gain = mode < 0.5f ? 0.0f : mode * 2.0f - 1.0f;
 386:mi/stmlib/dsp/filter.h ****     while (size--) {
 387:mi/stmlib/dsp/filter.h ****       hp = (*in - r_ * state_1 - g_ * state_1 - state_2) * h_;
 388:mi/stmlib/dsp/filter.h ****       bp = g_ * hp + state_1;
 389:mi/stmlib/dsp/filter.h ****       state_1 = g_ * hp + bp;
 390:mi/stmlib/dsp/filter.h ****       lp = g_ * bp + state_2;
 391:mi/stmlib/dsp/filter.h ****       state_2 = g_ * bp + lp;
 392:mi/stmlib/dsp/filter.h ****       *out = hp_gain * hp + bp_gain * bp + lp_gain * lp;
 393:mi/stmlib/dsp/filter.h ****       ++in;
 394:mi/stmlib/dsp/filter.h ****       ++out;
 395:mi/stmlib/dsp/filter.h ****     }
 396:mi/stmlib/dsp/filter.h ****     state_1_ = state_1;
 397:mi/stmlib/dsp/filter.h ****     state_2_ = state_2;
 398:mi/stmlib/dsp/filter.h ****   }
