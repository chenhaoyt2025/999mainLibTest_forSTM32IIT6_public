  44:mi/stmlib/dsp/cosine_oscillator.h **** class CosineOscillator {
  45:mi/stmlib/dsp/cosine_oscillator.h ****  public:
  46:mi/stmlib/dsp/cosine_oscillator.h ****   CosineOscillator() { }
  47:mi/stmlib/dsp/cosine_oscillator.h ****   ~CosineOscillator() { }
  48:mi/stmlib/dsp/cosine_oscillator.h **** 
  49:mi/stmlib/dsp/cosine_oscillator.h ****   template<CosineOscillatorMode mode>
  50:mi/stmlib/dsp/cosine_oscillator.h ****   inline void Init(float frequency) {
  51:mi/stmlib/dsp/cosine_oscillator.h ****     if (mode == COSINE_OSCILLATOR_APPROXIMATE) {
  52:mi/stmlib/dsp/cosine_oscillator.h ****       InitApproximate(frequency);
  53:mi/stmlib/dsp/cosine_oscillator.h ****     } else {
  54:mi/stmlib/dsp/cosine_oscillator.h ****       iir_coefficient_ = 2.0f * cosf(2.0f * float(M_PI) * frequency);
  55:mi/stmlib/dsp/cosine_oscillator.h ****       initial_amplitude_ = iir_coefficient_ * 0.25f;
  56:mi/stmlib/dsp/cosine_oscillator.h ****     }
  57:mi/stmlib/dsp/cosine_oscillator.h ****     Start();
  58:mi/stmlib/dsp/cosine_oscillator.h ****   }
