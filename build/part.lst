  37:mi/stmlib/dsp/dsp.h **** namespace stmlib {
  38:mi/stmlib/dsp/dsp.h **** 
  39:mi/stmlib/dsp/dsp.h **** #define MAKE_INTEGRAL_FRACTIONAL(x) \
  40:mi/stmlib/dsp/dsp.h ****   int32_t x ## _integral = static_cast<int32_t>(x); \
  41:mi/stmlib/dsp/dsp.h ****   float x ## _fractional = x - static_cast<float>(x ## _integral);
  42:mi/stmlib/dsp/dsp.h **** 
  43:mi/stmlib/dsp/dsp.h **** inline float Interpolate(const float* table, float index, float size) {
  44:mi/stmlib/dsp/dsp.h ****   index *= size;
  45:mi/stmlib/dsp/dsp.h ****   MAKE_INTEGRAL_FRACTIONAL(index)
  46:mi/stmlib/dsp/dsp.h ****   float a = table[index_integral];
  47:mi/stmlib/dsp/dsp.h ****   float b = table[index_integral + 1];
  48:mi/stmlib/dsp/dsp.h ****   return a + (b - a) * index_fractional;
  49:mi/stmlib/dsp/dsp.h **** }
  50:mi/stmlib/dsp/dsp.h **** 
  51:mi/stmlib/dsp/dsp.h **** 
  52:mi/stmlib/dsp/dsp.h **** inline float InterpolateHermite(const float* table, float index, float size) {
  53:mi/stmlib/dsp/dsp.h ****   index *= size;
  54:mi/stmlib/dsp/dsp.h ****   MAKE_INTEGRAL_FRACTIONAL(index)
  55:mi/stmlib/dsp/dsp.h ****   const float xm1 = table[index_integral - 1];
  56:mi/stmlib/dsp/dsp.h ****   const float x0 = table[index_integral + 0];
  57:mi/stmlib/dsp/dsp.h ****   const float x1 = table[index_integral + 1];
  58:mi/stmlib/dsp/dsp.h ****   const float x2 = table[index_integral + 2];
  59:mi/stmlib/dsp/dsp.h ****   const float c = (x1 - xm1) * 0.5f;
  60:mi/stmlib/dsp/dsp.h ****   const float v = x0 - x1;
  61:mi/stmlib/dsp/dsp.h ****   const float w = c + v;
  62:mi/stmlib/dsp/dsp.h ****   const float a = w + v + (x2 - x0) * 0.5f;
  63:mi/stmlib/dsp/dsp.h ****   const float b_neg = w + a;
  64:mi/stmlib/dsp/dsp.h ****   const float f = index_fractional;
  65:mi/stmlib/dsp/dsp.h ****   return (((a * f) - b_neg) * f + c) * f + x0;
  66:mi/stmlib/dsp/dsp.h **** }
  67:mi/stmlib/dsp/dsp.h **** 
  68:mi/stmlib/dsp/dsp.h **** inline float InterpolateWrap(const float* table, float index, float size) {
  69:mi/stmlib/dsp/dsp.h ****   index -= static_cast<float>(static_cast<int32_t>(index));
  70:mi/stmlib/dsp/dsp.h ****   index *= size;
  71:mi/stmlib/dsp/dsp.h ****   MAKE_INTEGRAL_FRACTIONAL(index)
  72:mi/stmlib/dsp/dsp.h ****   float a = table[index_integral];
  73:mi/stmlib/dsp/dsp.h ****   float b = table[index_integral + 1];
ARM GAS  /var/folders/9k/zk1mgrrd7wg4__6zvxvr9w8m0000gn/T//ccVA5vwj.s 			page 129


  74:mi/stmlib/dsp/dsp.h ****   return a + (b - a) * index_fractional;
  75:mi/stmlib/dsp/dsp.h **** }
  76:mi/stmlib/dsp/dsp.h **** 
  77:mi/stmlib/dsp/dsp.h **** inline float SmoothStep(float value) {
  78:mi/stmlib/dsp/dsp.h ****   return value * value * (3.0f - 2.0f * value);
  79:mi/stmlib/dsp/dsp.h **** }
  80:mi/stmlib/dsp/dsp.h **** 
  81:mi/stmlib/dsp/dsp.h **** #define ONE_POLE(out, in, coefficient) out += (coefficient) * ((in) - out);
  82:mi/stmlib/dsp/dsp.h **** #define SLOPE(out, in, positive, negative) { \
  83:mi/stmlib/dsp/dsp.h ****   float error = (in) - out; \
  84:mi/stmlib/dsp/dsp.h ****   out += (error > 0 ? positive : negative) * error; \
  85:mi/stmlib/dsp/dsp.h **** }
  86:mi/stmlib/dsp/dsp.h **** #define SLEW(out, in, delta) { \
  87:mi/stmlib/dsp/dsp.h ****   float error = (in) - out; \
  88:mi/stmlib/dsp/dsp.h ****   float d = (delta); \
  89:mi/stmlib/dsp/dsp.h ****   if (error > d) { \
  90:mi/stmlib/dsp/dsp.h ****     error = d; \
  91:mi/stmlib/dsp/dsp.h ****   } else if (error < -d) { \
  92:mi/stmlib/dsp/dsp.h ****     error = -d; \
  93:mi/stmlib/dsp/dsp.h ****   } \
  94:mi/stmlib/dsp/dsp.h ****   out += error; \
  95:mi/stmlib/dsp/dsp.h **** }
  96:mi/stmlib/dsp/dsp.h **** 
  97:mi/stmlib/dsp/dsp.h **** inline float Crossfade(float a, float b, float fade) {
  98:mi/stmlib/dsp/dsp.h ****   return a + (b - a) * fade;
  99:mi/stmlib/dsp/dsp.h **** }
 100:mi/stmlib/dsp/dsp.h **** 
 101:mi/stmlib/dsp/dsp.h **** inline float SoftLimit(float x) {
 102:mi/stmlib/dsp/dsp.h ****   return x * (27.0f + x * x) / (27.0f + 9.0f * x * x);
 103:mi/stmlib/dsp/dsp.h **** }
 104:mi/stmlib/dsp/dsp.h **** 
 105:mi/stmlib/dsp/dsp.h **** inline float SoftClip(float x) {
 106:mi/stmlib/dsp/dsp.h ****   if (x < -3.0f) {
 107:mi/stmlib/dsp/dsp.h ****     return -1.0f;
 108:mi/stmlib/dsp/dsp.h ****   } else if (x > 3.0f) {
 109:mi/stmlib/dsp/dsp.h ****     return 1.0f;
 110:mi/stmlib/dsp/dsp.h ****   } else {
 111:mi/stmlib/dsp/dsp.h ****     return SoftLimit(x);
 112:mi/stmlib/dsp/dsp.h ****   }
 113:mi/stmlib/dsp/dsp.h **** }
