  38:mi/stmlib/dsp/filter.h **** namespace stmlib {
  39:mi/stmlib/dsp/filter.h **** 
  40:mi/stmlib/dsp/filter.h **** enum FilterMode {
  41:mi/stmlib/dsp/filter.h ****   FILTER_MODE_LOW_PASS,
  42:mi/stmlib/dsp/filter.h ****   FILTER_MODE_BAND_PASS,
  43:mi/stmlib/dsp/filter.h ****   FILTER_MODE_BAND_PASS_NORMALIZED,
  44:mi/stmlib/dsp/filter.h ****   FILTER_MODE_HIGH_PASS
  45:mi/stmlib/dsp/filter.h **** };
  46:mi/stmlib/dsp/filter.h **** 
  47:mi/stmlib/dsp/filter.h **** enum FrequencyApproximation {
  48:mi/stmlib/dsp/filter.h ****   FREQUENCY_EXACT,
  49:mi/stmlib/dsp/filter.h ****   FREQUENCY_ACCURATE,
  50:mi/stmlib/dsp/filter.h ****   FREQUENCY_FAST,
  51:mi/stmlib/dsp/filter.h ****   FREQUENCY_DIRTY
  52:mi/stmlib/dsp/filter.h **** };
  53:mi/stmlib/dsp/filter.h **** 
  54:mi/stmlib/dsp/filter.h **** #define M_PI_F float(M_PI)
  55:mi/stmlib/dsp/filter.h **** #define M_PI_POW_2 M_PI * M_PI
  56:mi/stmlib/dsp/filter.h **** #define M_PI_POW_3 M_PI_POW_2 * M_PI
  57:mi/stmlib/dsp/filter.h **** #define M_PI_POW_5 M_PI_POW_3 * M_PI_POW_2
  58:mi/stmlib/dsp/filter.h **** #define M_PI_POW_7 M_PI_POW_5 * M_PI_POW_2
  59:mi/stmlib/dsp/filter.h **** #define M_PI_POW_9 M_PI_POW_7 * M_PI_POW_2
  60:mi/stmlib/dsp/filter.h **** #define M_PI_POW_11 M_PI_POW_9 * M_PI_POW_2
  61:mi/stmlib/dsp/filter.h **** 
  62:mi/stmlib/dsp/filter.h **** class DCBlocker {
  63:mi/stmlib/dsp/filter.h ****  public:
  64:mi/stmlib/dsp/filter.h ****   DCBlocker() { }
  65:mi/stmlib/dsp/filter.h ****   ~DCBlocker() { }
  66:mi/stmlib/dsp/filter.h ****   
  67:mi/stmlib/dsp/filter.h ****   void Init(float pole) {
  68:mi/stmlib/dsp/filter.h ****     x_ = 0.0f;
  69:mi/stmlib/dsp/filter.h ****     y_ = 0.0f;
  70:mi/stmlib/dsp/filter.h ****     pole_ = pole;
  71:mi/stmlib/dsp/filter.h ****   }
  72:mi/stmlib/dsp/filter.h ****   
  73:mi/stmlib/dsp/filter.h ****   inline void Process(float* in_out, size_t size) {
  74:mi/stmlib/dsp/filter.h ****     float x = x_;
  75:mi/stmlib/dsp/filter.h ****     float y = y_;
  76:mi/stmlib/dsp/filter.h ****     const float pole = pole_;
  77:mi/stmlib/dsp/filter.h ****     while (size--) {
  78:mi/stmlib/dsp/filter.h ****       float old_x = x;
  79:mi/stmlib/dsp/filter.h ****       x = *in_out;
  80:mi/stmlib/dsp/filter.h ****       *in_out++ = y = y * pole + x - old_x;
  81:mi/stmlib/dsp/filter.h ****     }
  82:mi/stmlib/dsp/filter.h ****     x_ = x;
  83:mi/stmlib/dsp/filter.h ****     y_ = y;
  84:mi/stmlib/dsp/filter.h ****   }
  85:mi/stmlib/dsp/filter.h ****   
