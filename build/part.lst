  27:mi/stmlib/dsp/cosine_oscillator.h **** // Cosine oscillator. Generates a cosine between 0.0 and 1.0 with minimal
  28:mi/stmlib/dsp/cosine_oscillator.h **** // CPU use.
  29:mi/stmlib/dsp/cosine_oscillator.h **** 
