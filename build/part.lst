  45:mi/ringsX_MIDI/dsp/string.h **** class DampingFilter {
  46:mi/ringsX_MIDI/dsp/string.h ****  public:
  47:mi/ringsX_MIDI/dsp/string.h ****   DampingFilter() { }
  48:mi/ringsX_MIDI/dsp/string.h ****   ~DampingFilter() { }
  49:mi/ringsX_MIDI/dsp/string.h ****   
  50:mi/ringsX_MIDI/dsp/string.h ****   void Init() {
  51:mi/ringsX_MIDI/dsp/string.h ****     x_ = 0.0f;
  52:mi/ringsX_MIDI/dsp/string.h ****     x__ = 0.0f;
  53:mi/ringsX_MIDI/dsp/string.h ****     brightness_ = 0.0f;
  54:mi/ringsX_MIDI/dsp/string.h ****     brightness_increment_ = 0.0f;
  55:mi/ringsX_MIDI/dsp/string.h ****     damping_ = 0.0f;
ARM GAS  /var/folders/9k/zk1mgrrd7wg4__6zvxvr9w8m0000gn/T//ccVA5vwj.s 			page 266


  56:mi/ringsX_MIDI/dsp/string.h ****     damping_increment_ = 0.0f;
  57:mi/ringsX_MIDI/dsp/string.h ****   }
  58:mi/ringsX_MIDI/dsp/string.h ****    
  59:mi/ringsX_MIDI/dsp/string.h ****   inline void Configure(float damping, float brightness, size_t size) {
  60:mi/ringsX_MIDI/dsp/string.h ****     if (!size) {
  61:mi/ringsX_MIDI/dsp/string.h ****       damping_ = damping;
  62:mi/ringsX_MIDI/dsp/string.h ****       brightness_ = brightness;
  63:mi/ringsX_MIDI/dsp/string.h ****       damping_increment_ = 0.0f;
  64:mi/ringsX_MIDI/dsp/string.h ****       brightness_increment_ = 0.0f;
  65:mi/ringsX_MIDI/dsp/string.h ****     } else {
  66:mi/ringsX_MIDI/dsp/string.h ****       float step = 1.0f / static_cast<float>(size);
  67:mi/ringsX_MIDI/dsp/string.h ****       damping_increment_ = (damping - damping_) * step;
  68:mi/ringsX_MIDI/dsp/string.h ****       brightness_increment_ = (brightness - brightness_) * step;
  69:mi/ringsX_MIDI/dsp/string.h ****     }
  70:mi/ringsX_MIDI/dsp/string.h ****   }
  71:mi/ringsX_MIDI/dsp/string.h ****    
  72:mi/ringsX_MIDI/dsp/string.h ****   inline float Process(float x) {
  73:mi/ringsX_MIDI/dsp/string.h ****     float h0 = (1.0f + brightness_) * 0.5f;
  74:mi/ringsX_MIDI/dsp/string.h ****     float h1 = (1.0f - brightness_) * 0.25f;
  75:mi/ringsX_MIDI/dsp/string.h ****     float y = damping_ * (h0 * x_ + h1 * (x + x__));
  76:mi/ringsX_MIDI/dsp/string.h ****     x__ = x_;
  77:mi/ringsX_MIDI/dsp/string.h ****     x_ = x;
  78:mi/ringsX_MIDI/dsp/string.h ****     brightness_ += brightness_increment_;
  79:mi/ringsX_MIDI/dsp/string.h ****     damping_ += damping_increment_;
  80:mi/ringsX_MIDI/dsp/string.h ****     return y;
  81:mi/ringsX_MIDI/dsp/string.h ****   }
  82:mi/ringsX_MIDI/dsp/string.h ****  private:
  83:mi/ringsX_MIDI/dsp/string.h ****   float x_;
  84:mi/ringsX_MIDI/dsp/string.h ****   float x__;
  85:mi/ringsX_MIDI/dsp/string.h ****   float brightness_;
  86:mi/ringsX_MIDI/dsp/string.h ****   float brightness_increment_;
  87:mi/ringsX_MIDI/dsp/string.h ****   float damping_;
  88:mi/ringsX_MIDI/dsp/string.h ****   float damping_increment_;
  89:mi/ringsX_MIDI/dsp/string.h ****   
  90:mi/ringsX_MIDI/dsp/string.h ****   DISALLOW_COPY_AND_ASSIGN(DampingFilter);
  91:mi/ringsX_MIDI/dsp/string.h **** };
