  59:mi/stmlib/dsp/delay_line.h ****   inline void Write(const T sample) {
  60:mi/stmlib/dsp/delay_line.h ****     line_[write_ptr_] = sample;
  61:mi/stmlib/dsp/delay_line.h ****     write_ptr_ = (write_ptr_ - 1 + max_delay) % max_delay;
  62:mi/stmlib/dsp/delay_line.h ****   }
  63:mi/stmlib/dsp/delay_line.h ****   
  64:mi/stmlib/dsp/delay_line.h ****   inline const T Allpass(const T sample, size_t delay, const T coefficient) {
  65:mi/stmlib/dsp/delay_line.h ****     T read = line_[(write_ptr_ + delay) % max_delay];
  66:mi/stmlib/dsp/delay_line.h ****     T write = sample + coefficient * read;
  67:mi/stmlib/dsp/delay_line.h ****     Write(write);
  68:mi/stmlib/dsp/delay_line.h ****     return -write * coefficient + read;
  69:mi/stmlib/dsp/delay_line.h ****   }
