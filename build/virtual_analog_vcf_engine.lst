  26:mi/plaits/dsp/oscillator/variable_shape_oscillator.h **** //
  27:mi/plaits/dsp/oscillator/variable_shape_oscillator.h **** // Continuously variable waveform: triangle > saw > square. Both square and
  28:mi/plaits/dsp/oscillator/variable_shape_oscillator.h **** // triangle have variable slope / pulse-width. Additionally, the phase resets
  29:mi/plaits/dsp/oscillator/variable_shape_oscillator.h **** // can be locked to a master frequency.
  30:mi/plaits/dsp/oscillator/variable_shape_oscillator.h **** //
  31:mi/plaits/dsp/oscillator/variable_shape_oscillator.h **** // A template parameter allows the generation of a master + slave signal,
  32:mi/plaits/dsp/oscillator/variable_shape_oscillator.h **** // which can be used as the phase for phase distortion or modulation synthesis.
  33:mi/plaits/dsp/oscillator/variable_shape_oscillator.h **** 
