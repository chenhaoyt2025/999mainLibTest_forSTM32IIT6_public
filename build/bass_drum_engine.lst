  52:mi/plaits/dsp/drums/synthetic_bass_drum.h ****   }
  53:mi/plaits/dsp/drums/synthetic_bass_drum.h ****   
  54:mi/plaits/dsp/drums/synthetic_bass_drum.h ****   float Process(float in) {
  55:mi/plaits/dsp/drums/synthetic_bass_drum.h ****     SLOPE(lp_, in, 0.5f, 0.1f);
  56:mi/plaits/dsp/drums/synthetic_bass_drum.h ****     ONE_POLE(hp_, lp_, 0.04f);
  57:mi/plaits/dsp/drums/synthetic_bass_drum.h ****     return filter_.Process<stmlib::FILTER_MODE_LOW_PASS>(lp_ - hp_);
  58:mi/plaits/dsp/drums/synthetic_bass_drum.h ****   }
