 114:mi/plaits/dsp/drums/synthetic_bass_drum.h ****   inline float DistortedSine(float phase, float phase_noise, float dirtiness) {
 115:mi/plaits/dsp/drums/synthetic_bass_drum.h ****     phase += phase_noise * dirtiness;
 116:mi/plaits/dsp/drums/synthetic_bass_drum.h ****     MAKE_INTEGRAL_FRACTIONAL(phase);
 117:mi/plaits/dsp/drums/synthetic_bass_drum.h ****     phase = phase_fractional;
 118:mi/plaits/dsp/drums/synthetic_bass_drum.h ****     float triangle = (phase < 0.5f ? phase : 1.0f - phase) * 4.0f - 1.0f;
 119:mi/plaits/dsp/drums/synthetic_bass_drum.h ****     float sine = 2.0f * triangle / (1.0f + fabsf(triangle));
 120:mi/plaits/dsp/drums/synthetic_bass_drum.h ****     float clean_sine = Sine(phase + 0.75f);
 121:mi/plaits/dsp/drums/synthetic_bass_drum.h ****     return sine + (1.0f - dirtiness) * (clean_sine - sine);
 122:mi/plaits/dsp/drums/synthetic_bass_drum.h ****   }
 123:mi/plaits/dsp/drums/synthetic_bass_drum.h ****   
 124:mi/plaits/dsp/drums/synthetic_bass_drum.h ****   inline float TransistorVCA(float s, float gain) {
 125:mi/plaits/dsp/drums/synthetic_bass_drum.h ****     s = (s - 0.6f) * gain;
 126:mi/plaits/dsp/drums/synthetic_bass_drum.h ****     return 3.0f * s / (2.0f + fabsf(s)) + gain * 0.3f;
 127:mi/plaits/dsp/drums/synthetic_bass_drum.h ****   }
