  42:mi/plaits/dsp/oscillator/sine_oscillator.h ****   
  43:mi/plaits/dsp/oscillator/sine_oscillator.h **** const float kSineLUTSize = 512.0f;
  44:mi/plaits/dsp/oscillator/sine_oscillator.h **** const size_t kSineLUTQuadrature = 128;
  45:mi/plaits/dsp/oscillator/sine_oscillator.h **** const size_t kSineLUTBits = 9;
  46:mi/plaits/dsp/oscillator/sine_oscillator.h **** 
  47:mi/plaits/dsp/oscillator/sine_oscillator.h **** // Safe for phase >= 0.0f, will wrap.
  48:mi/plaits/dsp/oscillator/sine_oscillator.h **** inline float Sine(float phase) {
  49:mi/plaits/dsp/oscillator/sine_oscillator.h ****   return stmlib::InterpolateWrap(lut_sine, phase, kSineLUTSize);
  50:mi/plaits/dsp/oscillator/sine_oscillator.h **** }
  51:mi/plaits/dsp/oscillator/sine_oscillator.h **** 
  52:mi/plaits/dsp/oscillator/sine_oscillator.h **** // Potentially unsafe, if phase >= 1.25.
  53:mi/plaits/dsp/oscillator/sine_oscillator.h **** inline float SineNoWrap(float phase) {
  54:mi/plaits/dsp/oscillator/sine_oscillator.h ****   return stmlib::Interpolate(lut_sine, phase, kSineLUTSize);
  55:mi/plaits/dsp/oscillator/sine_oscillator.h **** }
  56:mi/plaits/dsp/oscillator/sine_oscillator.h **** 
  57:mi/plaits/dsp/oscillator/sine_oscillator.h **** // With positive of negative phase modulation up to an index of 32.
  58:mi/plaits/dsp/oscillator/sine_oscillator.h **** inline float SinePM(uint32_t phase, float pm) {
  59:mi/plaits/dsp/oscillator/sine_oscillator.h ****   const float max_uint32 = 4294967296.0f;
  60:mi/plaits/dsp/oscillator/sine_oscillator.h ****   const int max_index = 32;
  61:mi/plaits/dsp/oscillator/sine_oscillator.h ****   const float offset = float(max_index);
  62:mi/plaits/dsp/oscillator/sine_oscillator.h ****   const float scale = max_uint32 / float(max_index * 2);
  63:mi/plaits/dsp/oscillator/sine_oscillator.h **** 
  64:mi/plaits/dsp/oscillator/sine_oscillator.h ****   phase += static_cast<uint32_t>((pm + offset) * scale) * max_index * 2;
  65:mi/plaits/dsp/oscillator/sine_oscillator.h ****   
  66:mi/plaits/dsp/oscillator/sine_oscillator.h ****   uint32_t integral = phase >> (32 - kSineLUTBits);
  67:mi/plaits/dsp/oscillator/sine_oscillator.h ****   float fractional = static_cast<float>(phase << kSineLUTBits) / float(max_uint32);
  68:mi/plaits/dsp/oscillator/sine_oscillator.h ****   float a = lut_sine[integral];
  69:mi/plaits/dsp/oscillator/sine_oscillator.h ****   float b = lut_sine[integral + 1];
  70:mi/plaits/dsp/oscillator/sine_oscillator.h ****   return a + (b - a) * fractional;
  71:mi/plaits/dsp/oscillator/sine_oscillator.h **** }
  72:mi/plaits/dsp/oscillator/sine_oscillator.h **** 
  73:mi/plaits/dsp/oscillator/sine_oscillator.h **** // Direct lookup without interpolation.
  74:mi/plaits/dsp/oscillator/sine_oscillator.h **** inline float SineRaw(uint32_t phase) {
  75:mi/plaits/dsp/oscillator/sine_oscillator.h ****   return lut_sine[phase >> (32 - kSineLUTBits)];
  76:mi/plaits/dsp/oscillator/sine_oscillator.h **** }
