  47:mi/plaits/dsp/drums/synthetic_bass_drum.h ****   void Init() {
  48:mi/plaits/dsp/drums/synthetic_bass_drum.h ****     lp_ = 0.0f;
  49:mi/plaits/dsp/drums/synthetic_bass_drum.h ****     hp_ = 0.0f;
  50:mi/plaits/dsp/drums/synthetic_bass_drum.h ****     filter_.Init();
