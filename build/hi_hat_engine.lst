 147:mi/plaits/dsp/drums/hi_hat.h **** class SwingVCA {
 148:mi/plaits/dsp/drums/hi_hat.h ****  public:
 149:mi/plaits/dsp/drums/hi_hat.h ****   float operator()(float s, float gain) {
 150:mi/plaits/dsp/drums/hi_hat.h ****    s *= s > 0.0f ? 4.0f : 0.1f;
 151:mi/plaits/dsp/drums/hi_hat.h ****    s = s / (1.0f + fabsf(s));
 152:mi/plaits/dsp/drums/hi_hat.h ****    return (s + 0.1f) * gain;
 153:mi/plaits/dsp/drums/hi_hat.h ****   }
 154:mi/plaits/dsp/drums/hi_hat.h **** };
 155:mi/plaits/dsp/drums/hi_hat.h **** 
 156:mi/plaits/dsp/drums/hi_hat.h **** class LinearVCA {
 157:mi/plaits/dsp/drums/hi_hat.h ****  public:
 158:mi/plaits/dsp/drums/hi_hat.h ****   float operator()(float s, float gain) {
 159:mi/plaits/dsp/drums/hi_hat.h ****    return s * gain;
 160:mi/plaits/dsp/drums/hi_hat.h ****   }
 161:mi/plaits/dsp/drums/hi_hat.h **** };
