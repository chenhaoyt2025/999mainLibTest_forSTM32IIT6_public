 128:mi/plaits/dsp/drums/hi_hat.h ****  private:
 129:mi/plaits/dsp/drums/hi_hat.h ****   void RenderPair(
 130:mi/plaits/dsp/drums/hi_hat.h ****       Oscillator* osc,
 131:mi/plaits/dsp/drums/hi_hat.h ****       const float* f,
 132:mi/plaits/dsp/drums/hi_hat.h ****       float* temp_1,
 133:mi/plaits/dsp/drums/hi_hat.h ****       float* temp_2,
 134:mi/plaits/dsp/drums/hi_hat.h ****       float* out,
 135:mi/plaits/dsp/drums/hi_hat.h ****       size_t size) {
 136:mi/plaits/dsp/drums/hi_hat.h ****     osc[0].Render<OSCILLATOR_SHAPE_SQUARE>(f[0], 0.5f, temp_1, size);
 137:mi/plaits/dsp/drums/hi_hat.h ****     osc[1].Render<OSCILLATOR_SHAPE_SAW>(f[1], 0.5f, temp_2, size);
 138:mi/plaits/dsp/drums/hi_hat.h ****     while (size--) {
 139:mi/plaits/dsp/drums/hi_hat.h ****       *out++ += *temp_1++ * *temp_2++;
 140:mi/plaits/dsp/drums/hi_hat.h ****     }
 141:mi/plaits/dsp/drums/hi_hat.h ****   }
