  36:mi/stmlib/dsp/parameter_interpolator.h **** class ParameterInterpolator {
  37:mi/stmlib/dsp/parameter_interpolator.h ****  public:
  38:mi/stmlib/dsp/parameter_interpolator.h ****   ParameterInterpolator() { }
  39:mi/stmlib/dsp/parameter_interpolator.h ****   ParameterInterpolator(float* state, float new_value, size_t size) {
  40:mi/stmlib/dsp/parameter_interpolator.h ****     Init(state, new_value, size);
  41:mi/stmlib/dsp/parameter_interpolator.h ****   }
  42:mi/stmlib/dsp/parameter_interpolator.h **** 
  43:mi/stmlib/dsp/parameter_interpolator.h ****   ParameterInterpolator(float* state, float new_value, float step) {
  44:mi/stmlib/dsp/parameter_interpolator.h ****     state_ = state;
  45:mi/stmlib/dsp/parameter_interpolator.h ****     value_ = *state;
  46:mi/stmlib/dsp/parameter_interpolator.h ****     increment_ = (new_value - *state) * step;
  47:mi/stmlib/dsp/parameter_interpolator.h ****   }
  48:mi/stmlib/dsp/parameter_interpolator.h **** 
  49:mi/stmlib/dsp/parameter_interpolator.h ****   ~ParameterInterpolator() {
  50:mi/stmlib/dsp/parameter_interpolator.h ****     *state_ = value_;
  51:mi/stmlib/dsp/parameter_interpolator.h ****   }
  52:mi/stmlib/dsp/parameter_interpolator.h ****   
  53:mi/stmlib/dsp/parameter_interpolator.h ****   inline void Init(float* state, float new_value, size_t size) {
  54:mi/stmlib/dsp/parameter_interpolator.h ****     state_ = state;
  55:mi/stmlib/dsp/parameter_interpolator.h ****     value_ = *state;
  56:mi/stmlib/dsp/parameter_interpolator.h ****     increment_ = (new_value - *state) / static_cast<float>(size);
