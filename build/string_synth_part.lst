  65:mi/ringsX_MIDI/dsp/string_synth_envelope.h ****     } else if (flags & ENVELOPE_FLAG_FALLING_EDGE && sustain_point_) {
  66:mi/ringsX_MIDI/dsp/string_synth_envelope.h ****       start_value_ = value_;
