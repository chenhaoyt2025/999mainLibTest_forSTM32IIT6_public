  76:mi/ringsX_MIDI/dsp/string_synth_envelope.h ****     bool sustained = sustain_point_ && segment_ == sustain_point_ &&
  77:mi/ringsX_MIDI/dsp/string_synth_envelope.h ****         flags & ENVELOPE_FLAG_GATE;
  78:mi/ringsX_MIDI/dsp/string_synth_envelope.h ****   
