  62:mi/ringsX_MIDI/dsp/string_synth_envelope.h ****       start_value_ = segment_ == num_segments_ ? level_[0] : value_;
  63:mi/ringsX_MIDI/dsp/string_synth_envelope.h ****       segment_ = 0;
