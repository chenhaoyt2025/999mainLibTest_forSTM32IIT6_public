  85:mi/ringsX_MIDI/dsp/string_synth_envelope.h ****       t = 1.0f - t;
  86:mi/ringsX_MIDI/dsp/string_synth_envelope.h ****       t *= t;
  87:mi/ringsX_MIDI/dsp/string_synth_envelope.h ****       t *= t;
  88:mi/ringsX_MIDI/dsp/string_synth_envelope.h ****       t = 1.0f - t;
  89:mi/ringsX_MIDI/dsp/string_synth_envelope.h ****     }
  90:mi/ringsX_MIDI/dsp/string_synth_envelope.h ****     
  91:mi/ringsX_MIDI/dsp/string_synth_envelope.h ****     phase_ += phase_increment;
