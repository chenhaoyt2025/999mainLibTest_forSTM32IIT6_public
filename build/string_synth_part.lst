 228:mi/stmlib/dsp/filter.h ****   
 229:mi/stmlib/dsp/filter.h ****   template<FilterMode mode>
 230:mi/stmlib/dsp/filter.h ****   inline float Process(float in) {
 231:mi/stmlib/dsp/filter.h ****     float hp, bp, lp;
 232:mi/stmlib/dsp/filter.h ****     hp = (in - r_ * state_1_ - g_ * state_1_ - state_2_) * h_;
 233:mi/stmlib/dsp/filter.h ****     bp = g_ * hp + state_1_;
 234:mi/stmlib/dsp/filter.h ****     state_1_ = g_ * hp + bp;
 235:mi/stmlib/dsp/filter.h ****     lp = g_ * bp + state_2_;
 236:mi/stmlib/dsp/filter.h ****     state_2_ = g_ * bp + lp;
 237:mi/stmlib/dsp/filter.h ****     
 238:mi/stmlib/dsp/filter.h ****     if (mode == FILTER_MODE_LOW_PASS) {
 239:mi/stmlib/dsp/filter.h ****       return lp;
 240:mi/stmlib/dsp/filter.h ****     } else if (mode == FILTER_MODE_BAND_PASS) {
 241:mi/stmlib/dsp/filter.h ****       return bp;
 242:mi/stmlib/dsp/filter.h ****     } else if (mode == FILTER_MODE_BAND_PASS_NORMALIZED) {
 243:mi/stmlib/dsp/filter.h ****       return bp * r_;
 244:mi/stmlib/dsp/filter.h ****     } else if (mode == FILTER_MODE_HIGH_PASS) {
 245:mi/stmlib/dsp/filter.h ****       return hp;
 246:mi/stmlib/dsp/filter.h ****     }
 247:mi/stmlib/dsp/filter.h ****   }
 248:mi/stmlib/dsp/filter.h ****   
 249:mi/stmlib/dsp/filter.h ****   template<FilterMode mode_1, FilterMode mode_2>
 250:mi/stmlib/dsp/filter.h ****   inline void Process(float in, float* out_1, float* out_2) {
 251:mi/stmlib/dsp/filter.h ****     float hp, bp, lp;
 252:mi/stmlib/dsp/filter.h ****     hp = (in - r_ * state_1_ - g_ * state_1_ - state_2_) * h_;
 253:mi/stmlib/dsp/filter.h ****     bp = g_ * hp + state_1_;
 254:mi/stmlib/dsp/filter.h ****     state_1_ = g_ * hp + bp;
 255:mi/stmlib/dsp/filter.h ****     lp = g_ * bp + state_2_;
 256:mi/stmlib/dsp/filter.h ****     state_2_ = g_ * bp + lp;
 257:mi/stmlib/dsp/filter.h ****     
 258:mi/stmlib/dsp/filter.h ****     if (mode_1 == FILTER_MODE_LOW_PASS) {
 259:mi/stmlib/dsp/filter.h ****       *out_1 = lp;
 260:mi/stmlib/dsp/filter.h ****     } else if (mode_1 == FILTER_MODE_BAND_PASS) {
 261:mi/stmlib/dsp/filter.h ****       *out_1 = bp;
