 200:mi/plaits/dsp/fm/voice.h ****     // Compute frequencies and amplitudes.
 201:mi/plaits/dsp/fm/voice.h ****     float f[num_operators];
 202:mi/plaits/dsp/fm/voice.h ****     float a[num_operators];
 203:mi/plaits/dsp/fm/voice.h ****     for (int i = 0; i < num_operators; ++i) {
 204:mi/plaits/dsp/fm/voice.h ****       const Patch::Operator& op = patch_->op[i];
 205:mi/plaits/dsp/fm/voice.h ****       
 206:mi/plaits/dsp/fm/voice.h ****       f[i] = ratios_[i] * (ratios_[i] < 0.0f ? -one_hz_ : f0);
 207:mi/plaits/dsp/fm/voice.h **** 
 208:mi/plaits/dsp/fm/voice.h ****       const float rate_scaling = RateScaling(note_, op.rate_scaling);
 209:mi/plaits/dsp/fm/voice.h ****       float level = parameters.sustain
 210:mi/plaits/dsp/fm/voice.h ****           ? operator_envelope_[i].RenderAtSample(envelope_sample, gate_duration)
 211:mi/plaits/dsp/fm/voice.h ****           : operator_envelope_[i].Render(
 212:mi/plaits/dsp/fm/voice.h ****                 parameters.gate,
 213:mi/plaits/dsp/fm/voice.h ****                 envelope_rate * rate_scaling,
 214:mi/plaits/dsp/fm/voice.h ****                 ad_scale,
 215:mi/plaits/dsp/fm/voice.h ****                 r_scale);
 216:mi/plaits/dsp/fm/voice.h ****       const float kb_scaling = KeyboardScaling(note_, op.keyboard_scaling);
 217:mi/plaits/dsp/fm/voice.h ****       const float velocity_scaling = normalized_velocity_ * \
 218:mi/plaits/dsp/fm/voice.h ****           float(op.velocity_sensitivity);
 219:mi/plaits/dsp/fm/voice.h ****       const float brightness = algorithms_->is_modulator(patch_->algorithm, i)
 220:mi/plaits/dsp/fm/voice.h ****           ? (parameters.brightness - 0.5f) * 32.0f
 221:mi/plaits/dsp/fm/voice.h ****           : 0.0f;
 222:mi/plaits/dsp/fm/voice.h ****       
 223:mi/plaits/dsp/fm/voice.h ****       level += 0.125f * std::min(
 224:mi/plaits/dsp/fm/voice.h ****           kb_scaling + velocity_scaling + brightness,
 225:mi/plaits/dsp/fm/voice.h ****           level_headroom_[i]);
 226:mi/plaits/dsp/fm/voice.h ****       
 227:mi/plaits/dsp/fm/voice.h ****       level_[i] = level;
