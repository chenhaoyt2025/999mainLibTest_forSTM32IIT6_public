  26:mi/plaits/dsp/fm/envelope.h **** //
  27:mi/plaits/dsp/fm/envelope.h **** // Multi-segment envelope generator.
  28:mi/plaits/dsp/fm/envelope.h **** //
  29:mi/plaits/dsp/fm/envelope.h **** // The classic constant-time design (as found in many other MI products) might
  30:mi/plaits/dsp/fm/envelope.h **** // cause differences in behavior from the original DX-series envelopes, in
  31:mi/plaits/dsp/fm/envelope.h **** // particular when jumping to the last segment before having reached the sustain
  32:mi/plaits/dsp/fm/envelope.h **** // phase.
  33:mi/plaits/dsp/fm/envelope.h **** //
  34:mi/plaits/dsp/fm/envelope.h **** // The unusual RenderAtSample() method allows the evaluation of the envelope at
  35:mi/plaits/dsp/fm/envelope.h **** // an arbitrary point in time, used in Plaits' "envelope scrubbing" feature.
  36:mi/plaits/dsp/fm/envelope.h **** //
  37:mi/plaits/dsp/fm/envelope.h **** // A couple of quirks from the DX-series' operator envelopes are implemented,
  38:mi/plaits/dsp/fm/envelope.h **** // namely:
  39:mi/plaits/dsp/fm/envelope.h **** // - vaguely logarithmic shape for ascending segments.
  40:mi/plaits/dsp/fm/envelope.h **** // - direct jump above a threshold for ascending segments.
  41:mi/plaits/dsp/fm/envelope.h **** // - specific logic and rates for plateaus.
  42:mi/plaits/dsp/fm/envelope.h **** 
  43:mi/plaits/dsp/fm/envelope.h **** #ifndef PLAITS_DSP_FM_ENVELOPE_H_
  44:mi/plaits/dsp/fm/envelope.h **** #define PLAITS_DSP_FM_ENVELOPE_H_
