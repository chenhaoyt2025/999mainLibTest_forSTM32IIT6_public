  48:mi/plaits/dsp/fm/dx_units.h **** 
  49:mi/plaits/dsp/fm/dx_units.h **** // Computes 2^x by using a polynomial approximation of 2^frac(x) and directly
  50:mi/plaits/dsp/fm/dx_units.h **** // incrementing the exponent of the IEEE 754 representation of the result
  51:mi/plaits/dsp/fm/dx_units.h **** // by int(x). Depending on the use case, the order of the polynomial
  52:mi/plaits/dsp/fm/dx_units.h **** // approximation can be chosen.
  53:mi/plaits/dsp/fm/dx_units.h **** template<int order>
  54:mi/plaits/dsp/fm/dx_units.h **** inline float Pow2Fast(float x) {
  55:mi/plaits/dsp/fm/dx_units.h ****   union {
  56:mi/plaits/dsp/fm/dx_units.h ****     float f;
  57:mi/plaits/dsp/fm/dx_units.h ****     int32_t w;
  58:mi/plaits/dsp/fm/dx_units.h ****   } r;
  59:mi/plaits/dsp/fm/dx_units.h **** 
  60:mi/plaits/dsp/fm/dx_units.h ****   
  61:mi/plaits/dsp/fm/dx_units.h ****   if (order == 1) {
  62:mi/plaits/dsp/fm/dx_units.h ****     r.w = float(1 << 23) * (127.0f + x);
  63:mi/plaits/dsp/fm/dx_units.h ****     return r.f;
  64:mi/plaits/dsp/fm/dx_units.h ****   }
  65:mi/plaits/dsp/fm/dx_units.h ****   
  66:mi/plaits/dsp/fm/dx_units.h ****   int32_t x_integral = static_cast<int32_t>(x);
  67:mi/plaits/dsp/fm/dx_units.h ****   if (x < 0.0f) {
  68:mi/plaits/dsp/fm/dx_units.h ****     --x_integral;
  69:mi/plaits/dsp/fm/dx_units.h ****   }
  70:mi/plaits/dsp/fm/dx_units.h ****   x -= static_cast<float>(x_integral);
  71:mi/plaits/dsp/fm/dx_units.h **** 
  72:mi/plaits/dsp/fm/dx_units.h ****   if (order == 1) {
  73:mi/plaits/dsp/fm/dx_units.h ****     r.f = 1.0f + x;
  74:mi/plaits/dsp/fm/dx_units.h ****   } else if (order == 2) {
  75:mi/plaits/dsp/fm/dx_units.h ****     r.f = 1.0f + x * (0.6565f + x * 0.3435f);
  76:mi/plaits/dsp/fm/dx_units.h ****   } else if (order == 3) {
  77:mi/plaits/dsp/fm/dx_units.h ****     r.f = 1.0f + x * (0.6958f + x * (0.2251f + x * 0.0791f));
  78:mi/plaits/dsp/fm/dx_units.h ****   }
  79:mi/plaits/dsp/fm/dx_units.h ****   r.w += x_integral << 23;
  80:mi/plaits/dsp/fm/dx_units.h ****   return r.f;
  81:mi/plaits/dsp/fm/dx_units.h **** }
  82:mi/plaits/dsp/fm/dx_units.h **** 
  83:mi/plaits/dsp/fm/dx_units.h **** // Convert an operator (envelope) level from 0-99 to the complement of the
  84:mi/plaits/dsp/fm/dx_units.h **** // "TL" value.
  85:mi/plaits/dsp/fm/dx_units.h **** //   0 =   0  (TL = 127)
  86:mi/plaits/dsp/fm/dx_units.h **** //  20 =  48  (TL =  79)
  87:mi/plaits/dsp/fm/dx_units.h **** //  50 =  78  (TL =  49)
  88:mi/plaits/dsp/fm/dx_units.h **** //  99 = 127  (TL =   0)
  89:mi/plaits/dsp/fm/dx_units.h **** inline int OperatorLevel(int level) {
  90:mi/plaits/dsp/fm/dx_units.h ****   int tlc = int(level);
  91:mi/plaits/dsp/fm/dx_units.h ****   if (level < 20) {
  92:mi/plaits/dsp/fm/dx_units.h ****     tlc = tlc < 15 ? (tlc * (36 - tlc)) >> 3 : 27 + tlc;
ARM GAS  /var/folders/9k/zk1mgrrd7wg4__6zvxvr9w8m0000gn/T//ccTQtscz.s 			page 9


  93:mi/plaits/dsp/fm/dx_units.h ****   } else {
  94:mi/plaits/dsp/fm/dx_units.h ****     tlc += 28;
  95:mi/plaits/dsp/fm/dx_units.h ****   }
  96:mi/plaits/dsp/fm/dx_units.h ****   return tlc;
  97:mi/plaits/dsp/fm/dx_units.h **** }
  98:mi/plaits/dsp/fm/dx_units.h **** 
  99:mi/plaits/dsp/fm/dx_units.h **** // Convert an envelope level from 0-99 to an octave shift.
 100:mi/plaits/dsp/fm/dx_units.h **** //  0 = -4 octave
 101:mi/plaits/dsp/fm/dx_units.h **** // 18 = -1 octave
 102:mi/plaits/dsp/fm/dx_units.h **** // 50 =  0
 103:mi/plaits/dsp/fm/dx_units.h **** // 82 = +1 octave
 104:mi/plaits/dsp/fm/dx_units.h **** // 99 = +4 octave
 105:mi/plaits/dsp/fm/dx_units.h **** inline float PitchEnvelopeLevel(int level) {
 106:mi/plaits/dsp/fm/dx_units.h ****   float l = (float(level) - 50.0f) / 32.0f;
 107:mi/plaits/dsp/fm/dx_units.h ****   float tail = std::max(fabsf(l + 0.02f) - 1.0f, 0.0f);
 108:mi/plaits/dsp/fm/dx_units.h ****   return l * (1.0f + tail * tail * 5.3056f);
 109:mi/plaits/dsp/fm/dx_units.h **** }
 110:mi/plaits/dsp/fm/dx_units.h **** 
 111:mi/plaits/dsp/fm/dx_units.h **** // Convert an operator envelope rate from 0-99 to a frequency.
 112:mi/plaits/dsp/fm/dx_units.h **** inline float OperatorEnvelopeIncrement(int rate) {
 113:mi/plaits/dsp/fm/dx_units.h ****   int rate_scaled = (rate * 41) >> 6;
 114:mi/plaits/dsp/fm/dx_units.h ****   int mantissa = 4 + (rate_scaled & 3);
 115:mi/plaits/dsp/fm/dx_units.h ****   int exponent = 2 + (rate_scaled >> 2);
 116:mi/plaits/dsp/fm/dx_units.h ****   return float(mantissa << exponent) / float(1 << 24);
 117:mi/plaits/dsp/fm/dx_units.h **** }
 118:mi/plaits/dsp/fm/dx_units.h **** 
 119:mi/plaits/dsp/fm/dx_units.h **** // Convert a pitch envelope rate from 0-99 to a frequency.
 120:mi/plaits/dsp/fm/dx_units.h **** inline float PitchEnvelopeIncrement(int rate) {
 121:mi/plaits/dsp/fm/dx_units.h ****   float r = float(rate) * 0.01f;
 122:mi/plaits/dsp/fm/dx_units.h ****   return (1.0f + 192.0f * r * (r * r * r * r + 0.3333f)) / (21.3f * 44100.0f);
 123:mi/plaits/dsp/fm/dx_units.h **** }
 124:mi/plaits/dsp/fm/dx_units.h **** 
