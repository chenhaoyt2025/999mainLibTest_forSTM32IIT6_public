  26:mi/plaits/dsp/fm/algorithms.h **** //
  27:mi/plaits/dsp/fm/algorithms.h **** // FM Algorithms and how to render them.
  28:mi/plaits/dsp/fm/algorithms.h **** 
  29:mi/plaits/dsp/fm/algorithms.h **** #ifndef PLAITS_DSP_FM_ALGORITHMS_H_
  30:mi/plaits/dsp/fm/algorithms.h **** #define PLAITS_DSP_FM_ALGORITHMS_H_
  31:mi/plaits/dsp/fm/algorithms.h **** 
  32:mi/plaits/dsp/fm/algorithms.h **** #include "stmlib/dsp/dsp.h"
  33:mi/plaits/dsp/fm/algorithms.h **** 
  34:mi/plaits/dsp/fm/algorithms.h **** #include "plaits/dsp/fm/operator.h"
  35:mi/plaits/dsp/fm/algorithms.h **** 
  36:mi/plaits/dsp/fm/algorithms.h **** #include <algorithm>
  37:mi/plaits/dsp/fm/algorithms.h **** 
  38:mi/plaits/dsp/fm/algorithms.h **** namespace plaits {
  39:mi/plaits/dsp/fm/algorithms.h **** 
  40:mi/plaits/dsp/fm/algorithms.h **** namespace fm {
  41:mi/plaits/dsp/fm/algorithms.h **** 
  42:mi/plaits/dsp/fm/algorithms.h **** // Number of algorithms as a function of the number of operators.
  43:mi/plaits/dsp/fm/algorithms.h **** template<int num_operators> struct NumAlgorithms { enum { N = 1 }; };
  44:mi/plaits/dsp/fm/algorithms.h **** template<> struct NumAlgorithms<4> { enum { N = 8 }; };
  45:mi/plaits/dsp/fm/algorithms.h **** template<> struct NumAlgorithms<6> { enum { N = 32 }; };
  46:mi/plaits/dsp/fm/algorithms.h **** 
  47:mi/plaits/dsp/fm/algorithms.h **** // Store information about all FM algorithms, and which functions to call
  48:mi/plaits/dsp/fm/algorithms.h **** // to render them.
  49:mi/plaits/dsp/fm/algorithms.h **** // 
  50:mi/plaits/dsp/fm/algorithms.h **** // The raw structure of each algorithm is stored as a sequence of "opcodes",
  51:mi/plaits/dsp/fm/algorithms.h **** // where each opcode indicates, for each operator, from where does it get
  52:mi/plaits/dsp/fm/algorithms.h **** // its phase modulation signal and to which buffer it writes the result.
  53:mi/plaits/dsp/fm/algorithms.h **** // This data is compact - 1 byte / algorithm / operator.
  54:mi/plaits/dsp/fm/algorithms.h **** //
  55:mi/plaits/dsp/fm/algorithms.h **** // At run time, this data is "compiled" into a sequence of function calls
ARM GAS  /var/folders/9k/zk1mgrrd7wg4__6zvxvr9w8m0000gn/T//ccTQtscz.s 			page 51


  56:mi/plaits/dsp/fm/algorithms.h **** // to pre-compiled renderers. A renderer is specialized to efficiently render
  57:mi/plaits/dsp/fm/algorithms.h **** // (without any branching, and as much loop unrolling as possible) one
  58:mi/plaits/dsp/fm/algorithms.h **** // operator or a group of operators.
  59:mi/plaits/dsp/fm/algorithms.h **** //
  60:mi/plaits/dsp/fm/algorithms.h **** // Different code space and speed trade-off can be obtained by increasing the
  61:mi/plaits/dsp/fm/algorithms.h **** // palette of available renderers (for example by specializing the code for
  62:mi/plaits/dsp/fm/algorithms.h **** // a renderer rendering in a single pass a "tower" of 4 operators).
  63:mi/plaits/dsp/fm/algorithms.h **** template<int num_operators>
  64:mi/plaits/dsp/fm/algorithms.h **** class Algorithms {
  65:mi/plaits/dsp/fm/algorithms.h ****  public:
  66:mi/plaits/dsp/fm/algorithms.h ****   Algorithms() { }
  67:mi/plaits/dsp/fm/algorithms.h ****   ~Algorithms() { }
  68:mi/plaits/dsp/fm/algorithms.h ****   
  69:mi/plaits/dsp/fm/algorithms.h ****   enum {
  70:mi/plaits/dsp/fm/algorithms.h ****     NUM_ALGORITHMS = NumAlgorithms<num_operators>::N
  71:mi/plaits/dsp/fm/algorithms.h ****   };
  72:mi/plaits/dsp/fm/algorithms.h ****   
  73:mi/plaits/dsp/fm/algorithms.h ****   enum OpcodeFlags {
  74:mi/plaits/dsp/fm/algorithms.h ****     DESTINATION_MASK = 0x03,
  75:mi/plaits/dsp/fm/algorithms.h ****     SOURCE_MASK = 0x30,
  76:mi/plaits/dsp/fm/algorithms.h ****     SOURCE_FEEDBACK = 0x30,
  77:mi/plaits/dsp/fm/algorithms.h ****     ADDITIVE_FLAG = 0x04,
  78:mi/plaits/dsp/fm/algorithms.h ****     FEEDBACK_SOURCE_FLAG = 0x40,
  79:mi/plaits/dsp/fm/algorithms.h ****   };
  80:mi/plaits/dsp/fm/algorithms.h ****   
  81:mi/plaits/dsp/fm/algorithms.h ****   struct RenderCall {
  82:mi/plaits/dsp/fm/algorithms.h ****     RenderFn render_fn;
  83:mi/plaits/dsp/fm/algorithms.h ****     int n;
  84:mi/plaits/dsp/fm/algorithms.h ****     int input_index;
  85:mi/plaits/dsp/fm/algorithms.h ****     int output_index;
  86:mi/plaits/dsp/fm/algorithms.h ****   };
  87:mi/plaits/dsp/fm/algorithms.h ****   
  88:mi/plaits/dsp/fm/algorithms.h ****   inline void Init() {
  89:mi/plaits/dsp/fm/algorithms.h ****     for (int i = 0; i < NUM_ALGORITHMS; ++i) {
  90:mi/plaits/dsp/fm/algorithms.h ****       Compile(i);
  91:mi/plaits/dsp/fm/algorithms.h ****     }
  92:mi/plaits/dsp/fm/algorithms.h ****   }
  93:mi/plaits/dsp/fm/algorithms.h ****   
  94:mi/plaits/dsp/fm/algorithms.h ****   inline const RenderCall& render_call(int algorithm, int op) const {
  95:mi/plaits/dsp/fm/algorithms.h ****     return render_call_[algorithm][op];
  96:mi/plaits/dsp/fm/algorithms.h ****   }
  97:mi/plaits/dsp/fm/algorithms.h ****   
  98:mi/plaits/dsp/fm/algorithms.h ****   inline bool is_modulator(int algorithm, int op) const {
  99:mi/plaits/dsp/fm/algorithms.h ****     return opcodes_[algorithm][op] & DESTINATION_MASK;
 100:mi/plaits/dsp/fm/algorithms.h ****   }
 101:mi/plaits/dsp/fm/algorithms.h ****   
 102:mi/plaits/dsp/fm/algorithms.h ****  private:
 103:mi/plaits/dsp/fm/algorithms.h ****   struct RendererSpecs {
 104:mi/plaits/dsp/fm/algorithms.h ****     int n;
 105:mi/plaits/dsp/fm/algorithms.h ****     int modulation_source;
 106:mi/plaits/dsp/fm/algorithms.h ****     bool additive;
 107:mi/plaits/dsp/fm/algorithms.h ****     RenderFn render_fn;
 108:mi/plaits/dsp/fm/algorithms.h ****   };
 109:mi/plaits/dsp/fm/algorithms.h ****      
 110:mi/plaits/dsp/fm/algorithms.h ****   inline RenderFn GetRenderer(int n, int modulation_source, bool additive) {
 111:mi/plaits/dsp/fm/algorithms.h ****     for (const RendererSpecs* r = renderers_; r->n; ++r) {
 112:mi/plaits/dsp/fm/algorithms.h ****       if (r->n == n && \
ARM GAS  /var/folders/9k/zk1mgrrd7wg4__6zvxvr9w8m0000gn/T//ccTQtscz.s 			page 52


 113:mi/plaits/dsp/fm/algorithms.h ****           r->modulation_source == modulation_source && \
 114:mi/plaits/dsp/fm/algorithms.h ****           r->additive == additive) {
 115:mi/plaits/dsp/fm/algorithms.h ****         return r->render_fn;
 116:mi/plaits/dsp/fm/algorithms.h ****       }
 117:mi/plaits/dsp/fm/algorithms.h ****     }
 118:mi/plaits/dsp/fm/algorithms.h ****     return NULL;
 119:mi/plaits/dsp/fm/algorithms.h ****   }
