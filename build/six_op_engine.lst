 188:mi/plaits/dsp/fm/envelope.h **** class OperatorEnvelope : public Envelope<4, true> {
 189:mi/plaits/dsp/fm/envelope.h ****  public:
 190:mi/plaits/dsp/fm/envelope.h ****   void Set(const uint8_t rate[NUM_STAGES], const uint8_t level[NUM_STAGES],
 191:mi/plaits/dsp/fm/envelope.h ****            uint8_t global_level) {
 192:mi/plaits/dsp/fm/envelope.h ****     // Configure levels.
 193:mi/plaits/dsp/fm/envelope.h ****     for (int i = 0; i < NUM_STAGES; ++i) {
ARM GAS  /var/folders/9k/zk1mgrrd7wg4__6zvxvr9w8m0000gn/T//ccTQtscz.s 			page 74


 194:mi/plaits/dsp/fm/envelope.h ****       int level_scaled = OperatorLevel(level[i]);
 195:mi/plaits/dsp/fm/envelope.h ****       level_scaled = (level_scaled & ~1) + global_level - 133; // 125 ?
 196:mi/plaits/dsp/fm/envelope.h ****       level_[i] = 0.125f * \
 197:mi/plaits/dsp/fm/envelope.h ****           (level_scaled < 1 ? 0.5f : static_cast<float>(level_scaled));
 198:mi/plaits/dsp/fm/envelope.h ****     }
 199:mi/plaits/dsp/fm/envelope.h ****   
 200:mi/plaits/dsp/fm/envelope.h ****     // Configure increments.
 201:mi/plaits/dsp/fm/envelope.h ****     for (int i = 0; i < NUM_STAGES; ++i) {
 202:mi/plaits/dsp/fm/envelope.h ****       float increment = OperatorEnvelopeIncrement(rate[i]);
 203:mi/plaits/dsp/fm/envelope.h ****       float from = level_[(i - 1 + NUM_STAGES) % NUM_STAGES];
 204:mi/plaits/dsp/fm/envelope.h ****       float to = level_[i];
 205:mi/plaits/dsp/fm/envelope.h ****       
 206:mi/plaits/dsp/fm/envelope.h ****       if (from == to) {
 207:mi/plaits/dsp/fm/envelope.h ****         // Quirk: for plateaux, the increment is scaled.
 208:mi/plaits/dsp/fm/envelope.h ****         increment *= 0.6f;
 209:mi/plaits/dsp/fm/envelope.h ****         if (i == 0 && !level[i]) {
 210:mi/plaits/dsp/fm/envelope.h ****           // Quirk: the attack plateau is faster.
 211:mi/plaits/dsp/fm/envelope.h ****           increment *= 20.0f;
 212:mi/plaits/dsp/fm/envelope.h ****         }
 213:mi/plaits/dsp/fm/envelope.h ****       } else if (from < to) {
 214:mi/plaits/dsp/fm/envelope.h ****         from = std::max(6.7f, from);
 215:mi/plaits/dsp/fm/envelope.h ****         to = std::max(6.7f, to);
 216:mi/plaits/dsp/fm/envelope.h ****         if (from == to) {
 217:mi/plaits/dsp/fm/envelope.h ****           // Quirk: because of the jump, the attack might disappear.
 218:mi/plaits/dsp/fm/envelope.h ****           increment = 1.0f;
 219:mi/plaits/dsp/fm/envelope.h ****         } else {
 220:mi/plaits/dsp/fm/envelope.h ****           // Quirk: because of the weird shape, the rate is adjusted.
 221:mi/plaits/dsp/fm/envelope.h ****           increment *= 7.2f / (to - from);
 222:mi/plaits/dsp/fm/envelope.h ****         }
 223:mi/plaits/dsp/fm/envelope.h ****       } else {
 224:mi/plaits/dsp/fm/envelope.h ****         increment *= 1.0f / (from - to);
 225:mi/plaits/dsp/fm/envelope.h ****       }
 226:mi/plaits/dsp/fm/envelope.h ****       increment_[i] = increment * scale_;
 227:mi/plaits/dsp/fm/envelope.h ****     }
 228:mi/plaits/dsp/fm/envelope.h ****   }
 229:mi/plaits/dsp/fm/envelope.h **** };
