  66:mi/plaits/dsp/fm/patch.h **** 
  67:mi/plaits/dsp/fm/patch.h ****     uint8_t mode;
  68:mi/plaits/dsp/fm/patch.h ****     uint8_t coarse;
  69:mi/plaits/dsp/fm/patch.h ****     uint8_t fine;   // x frequency by 1 + 0.01 x fine
  70:mi/plaits/dsp/fm/patch.h ****     uint8_t detune; 
  71:mi/plaits/dsp/fm/patch.h ****   } op[6];
