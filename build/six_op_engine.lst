 170:mi/plaits/dsp/fm/dx_units.h **** // Keyboard tracking to TL adjustment.
 171:mi/plaits/dsp/fm/dx_units.h **** inline float KeyboardScaling(float note, const Patch::KeyboardScaling& ks) {
 172:mi/plaits/dsp/fm/dx_units.h ****   const float x = note - float(ks.break_point) - 15.0f;
 173:mi/plaits/dsp/fm/dx_units.h ****   const int curve = x > 0.0f ? ks.right_curve : ks.left_curve;
 174:mi/plaits/dsp/fm/dx_units.h **** 
 175:mi/plaits/dsp/fm/dx_units.h ****   float t = fabsf(x);
 176:mi/plaits/dsp/fm/dx_units.h ****   if (curve == 1 || curve == 2) {
 177:mi/plaits/dsp/fm/dx_units.h ****     t = std::min(t * 0.010467f, 1.0f);
 178:mi/plaits/dsp/fm/dx_units.h ****     t = t * t * t;
 179:mi/plaits/dsp/fm/dx_units.h ****     t *= 96.0f;
 180:mi/plaits/dsp/fm/dx_units.h ****   }
 181:mi/plaits/dsp/fm/dx_units.h ****   if (curve < 2) {
 182:mi/plaits/dsp/fm/dx_units.h ****     t = -t;
 183:mi/plaits/dsp/fm/dx_units.h ****   }
 184:mi/plaits/dsp/fm/dx_units.h **** 
 185:mi/plaits/dsp/fm/dx_units.h ****   float depth = float(x > 0.0f ? ks.right_depth : ks.left_depth);
 186:mi/plaits/dsp/fm/dx_units.h ****   return t * depth * 0.02677f;
 187:mi/plaits/dsp/fm/dx_units.h **** }
 188:mi/plaits/dsp/fm/dx_units.h **** 
