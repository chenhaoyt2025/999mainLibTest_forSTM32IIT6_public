  52:mi/plaits/dsp/fm/patch.h ****     uint8_t left_depth;
  53:mi/plaits/dsp/fm/patch.h ****     uint8_t right_depth;
  54:mi/plaits/dsp/fm/patch.h ****     uint8_t left_curve;
  55:mi/plaits/dsp/fm/patch.h ****     uint8_t right_curve;
  56:mi/plaits/dsp/fm/patch.h ****   };
  57:mi/plaits/dsp/fm/patch.h **** 
