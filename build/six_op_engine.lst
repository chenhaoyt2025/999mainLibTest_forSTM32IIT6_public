 145:mi/plaits/dsp/fm/dx_units.h **** 
 146:mi/plaits/dsp/fm/dx_units.h **** // Pre-process the velocity to easily compute the velocity scaling.
 147:mi/plaits/dsp/fm/dx_units.h **** inline float NormalizeVelocity(float velocity) {
 148:mi/plaits/dsp/fm/dx_units.h ****   // float cube_root = stmlib::Sqrt(
 149:mi/plaits/dsp/fm/dx_units.h ****   //     0.7f * stmlib::Sqrt(velocity) + 0.3f * velocity);
 150:mi/plaits/dsp/fm/dx_units.h ****   const float cube_root = stmlib::Interpolate(lut_cube_root, velocity, 16);
 151:mi/plaits/dsp/fm/dx_units.h ****   return 16.0f * (cube_root - 0.918f);
 152:mi/plaits/dsp/fm/dx_units.h **** }
 153:mi/plaits/dsp/fm/dx_units.h **** 
 154:mi/plaits/dsp/fm/dx_units.h **** // MIDI note to envelope increment ratio.
 155:mi/plaits/dsp/fm/dx_units.h **** inline float RateScaling(float note, int rate_scaling) {
 156:mi/plaits/dsp/fm/dx_units.h ****   return Pow2Fast<1>(
 157:mi/plaits/dsp/fm/dx_units.h ****       float(rate_scaling) * (note * 0.33333f - 7.0f) * 0.03125f);
 158:mi/plaits/dsp/fm/dx_units.h **** }
 159:mi/plaits/dsp/fm/dx_units.h **** 
 160:mi/plaits/dsp/fm/dx_units.h **** // Operator amplitude modulation sensitivity (0-3).
 161:mi/plaits/dsp/fm/dx_units.h **** inline float AmpModSensitivity(int amp_mod_sensitivity) {
 162:mi/plaits/dsp/fm/dx_units.h ****   return lut_amp_mod_sensitivity[amp_mod_sensitivity];
 163:mi/plaits/dsp/fm/dx_units.h **** }
 164:mi/plaits/dsp/fm/dx_units.h **** 
 165:mi/plaits/dsp/fm/dx_units.h **** // Pitch modulation sensitivity (0-7).
 166:mi/plaits/dsp/fm/dx_units.h **** inline float PitchModSensitivity(int pitch_mod_sensitivity) {
 167:mi/plaits/dsp/fm/dx_units.h ****   return lut_pitch_mod_sensitivity[pitch_mod_sensitivity];
