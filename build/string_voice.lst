 176:mi/stmlib/dsp/filter.h **** 
 177:mi/stmlib/dsp/filter.h **** class Svf {
 178:mi/stmlib/dsp/filter.h ****  public:
 179:mi/stmlib/dsp/filter.h ****   Svf() { }
 180:mi/stmlib/dsp/filter.h ****   ~Svf() { }
 181:mi/stmlib/dsp/filter.h ****   
 182:mi/stmlib/dsp/filter.h ****   void Init() {
 183:mi/stmlib/dsp/filter.h ****     set_f_q<FREQUENCY_DIRTY>(0.01f, 100.0f);
 184:mi/stmlib/dsp/filter.h ****     Reset();
 185:mi/stmlib/dsp/filter.h ****   }
 186:mi/stmlib/dsp/filter.h ****   
 187:mi/stmlib/dsp/filter.h ****   void Reset() {
 188:mi/stmlib/dsp/filter.h ****     state_1_ = state_2_ = 0.0f;
 189:mi/stmlib/dsp/filter.h ****   }
 190:mi/stmlib/dsp/filter.h ****   
 191:mi/stmlib/dsp/filter.h ****   // Copy settings from another filter.
 192:mi/stmlib/dsp/filter.h ****   inline void set(const Svf& f) {
 193:mi/stmlib/dsp/filter.h ****     g_ = f.g();
 194:mi/stmlib/dsp/filter.h ****     r_ = f.r();
 195:mi/stmlib/dsp/filter.h ****     h_ = f.h();
 196:mi/stmlib/dsp/filter.h ****   }
 197:mi/stmlib/dsp/filter.h **** 
 198:mi/stmlib/dsp/filter.h ****   // Set all parameters from LUT.
 199:mi/stmlib/dsp/filter.h ****   inline void set_g_r_h(float g, float r, float h) {
 200:mi/stmlib/dsp/filter.h ****     g_ = g;
 201:mi/stmlib/dsp/filter.h ****     r_ = r;
 202:mi/stmlib/dsp/filter.h ****     h_ = h;
 203:mi/stmlib/dsp/filter.h ****   }
 204:mi/stmlib/dsp/filter.h ****   
ARM GAS  /var/folders/9k/zk1mgrrd7wg4__6zvxvr9w8m0000gn/T//ccUrAnV6.s 			page 6


 205:mi/stmlib/dsp/filter.h ****   // Set frequency and resonance coefficients from LUT, adjust remaining
 206:mi/stmlib/dsp/filter.h ****   // parameter.
 207:mi/stmlib/dsp/filter.h ****   inline void set_g_r(float g, float r) {
 208:mi/stmlib/dsp/filter.h ****     g_ = g;
 209:mi/stmlib/dsp/filter.h ****     r_ = r;
 210:mi/stmlib/dsp/filter.h ****     h_ = 1.0f / (1.0f + r_ * g_ + g_ * g_);
 211:mi/stmlib/dsp/filter.h ****   }
 212:mi/stmlib/dsp/filter.h **** 
 213:mi/stmlib/dsp/filter.h ****   // Set frequency from LUT, resonance in true units, adjust the rest.
 214:mi/stmlib/dsp/filter.h ****   inline void set_g_q(float g, float resonance) {
 215:mi/stmlib/dsp/filter.h ****     g_ = g;
 216:mi/stmlib/dsp/filter.h ****     r_ = 1.0f / resonance;
 217:mi/stmlib/dsp/filter.h ****     h_ = 1.0f / (1.0f + r_ * g_ + g_ * g_);
