   8:../libdaisy_IIT6/libDaisy/src/per/dac.h **** {
   9:../libdaisy_IIT6/libDaisy/src/per/dac.h **** /** @brief DAC handle for Built-in DAC Peripheral 
  10:../libdaisy_IIT6/libDaisy/src/per/dac.h ****  *  @ingroup per_analog
  11:../libdaisy_IIT6/libDaisy/src/per/dac.h ****  ** 
  12:../libdaisy_IIT6/libDaisy/src/per/dac.h ****  ** For now only Normal Mode is supported,
  13:../libdaisy_IIT6/libDaisy/src/per/dac.h ****  ** Sample and hold mode provides reduced power consumption, but requires a bit more setup.
  14:../libdaisy_IIT6/libDaisy/src/per/dac.h ****  **
  15:../libdaisy_IIT6/libDaisy/src/per/dac.h ****  ** For now connecting the DAC through other internal peripherals is also not supported.
  16:../libdaisy_IIT6/libDaisy/src/per/dac.h ****  **
  17:../libdaisy_IIT6/libDaisy/src/per/dac.h ****  ** Since the DAC channels have dedicated pins we don't need to pass in a pin config like with
  18:../libdaisy_IIT6/libDaisy/src/per/dac.h ****  ** other modules. However, it is still important to not try to use the DAC pins for anything else.
  19:../libdaisy_IIT6/libDaisy/src/per/dac.h ****  ** DAC Channel 1 is on PA4, and DAC Channel 2 is on PA5
  20:../libdaisy_IIT6/libDaisy/src/per/dac.h ****  ***/
ARM GAS  /var/folders/9k/zk1mgrrd7wg4__6zvxvr9w8m0000gn/T//ccuDf5uE.s 			page 484


  21:../libdaisy_IIT6/libDaisy/src/per/dac.h **** class DacHandle
  22:../libdaisy_IIT6/libDaisy/src/per/dac.h **** {
  23:../libdaisy_IIT6/libDaisy/src/per/dac.h ****   public:
