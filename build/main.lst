  45:../libdaisy_IIT6/libDaisy/src/per/i2c.h ****         };
  46:../libdaisy_IIT6/libDaisy/src/per/i2c.h **** 
  47:../libdaisy_IIT6/libDaisy/src/per/i2c.h ****         /** Rate at which the clock/data will be sent/received. The device being used will have max
