  30:../libdaisy_IIT6/libDaisy/src/per/dac.h **** 
  31:../libdaisy_IIT6/libDaisy/src/per/dac.h ****     /** Selects which channel(s) will be configured for use. */
  32:../libdaisy_IIT6/libDaisy/src/per/dac.h ****     enum class Channel
  33:../libdaisy_IIT6/libDaisy/src/per/dac.h ****     {
  34:../libdaisy_IIT6/libDaisy/src/per/dac.h ****         ONE,
  35:../libdaisy_IIT6/libDaisy/src/per/dac.h ****         TWO,
  36:../libdaisy_IIT6/libDaisy/src/per/dac.h ****         BOTH,
  37:../libdaisy_IIT6/libDaisy/src/per/dac.h ****     };
  38:../libdaisy_IIT6/libDaisy/src/per/dac.h **** 
  39:../libdaisy_IIT6/libDaisy/src/per/dac.h ****     /** Sets the Mode for the DAC channels.
  40:../libdaisy_IIT6/libDaisy/src/per/dac.h ****      **
  41:../libdaisy_IIT6/libDaisy/src/per/dac.h ****      ** Polling mode uses the blocking mode to transmit a single value at a time.
  42:../libdaisy_IIT6/libDaisy/src/per/dac.h ****      **
  43:../libdaisy_IIT6/libDaisy/src/per/dac.h ****      ** DMA mode uses a buffer, and periodically transmits it triggering a 
  44:../libdaisy_IIT6/libDaisy/src/per/dac.h ****      ** callback to fill the buffer when it is ready for more samples.
  45:../libdaisy_IIT6/libDaisy/src/per/dac.h ****      ***/
  46:../libdaisy_IIT6/libDaisy/src/per/dac.h ****     enum class Mode
  47:../libdaisy_IIT6/libDaisy/src/per/dac.h ****     {
