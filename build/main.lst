   9:../libdaisy_IIT6/libDaisy/src/per/sai.h **** {
  10:../libdaisy_IIT6/libDaisy/src/per/sai.h **** /** 
  11:../libdaisy_IIT6/libDaisy/src/per/sai.h ****  * Support for I2S Audio Protocol with different bit-depth, samplerate options
  12:../libdaisy_IIT6/libDaisy/src/per/sai.h ****  * Allows for master or slave, as well as freedom of selecting direction, 
  13:../libdaisy_IIT6/libDaisy/src/per/sai.h ****  * and other behavior for each peripheral, and block.
  14:../libdaisy_IIT6/libDaisy/src/per/sai.h ****  * 
  15:../libdaisy_IIT6/libDaisy/src/per/sai.h ****  * DMA Transfer commands must use buffers located within non-cached memory or use cache maintenance
  16:../libdaisy_IIT6/libDaisy/src/per/sai.h ****  * To declare an unitialized global element in the DMA memory section:
  17:../libdaisy_IIT6/libDaisy/src/per/sai.h ****  *    int32_t DSY_DMA_BUFFER_SECTOR my_buffer[96];
  18:../libdaisy_IIT6/libDaisy/src/per/sai.h ****  *
  19:../libdaisy_IIT6/libDaisy/src/per/sai.h ****  * Callback functions will be called once per half of the buffer. In the above example, 
  20:../libdaisy_IIT6/libDaisy/src/per/sai.h ****  * the callback function would be called once for every 48 samples.
  21:../libdaisy_IIT6/libDaisy/src/per/sai.h ****  * 
  22:../libdaisy_IIT6/libDaisy/src/per/sai.h ****  * Use SAI Handle like this:
  23:../libdaisy_IIT6/libDaisy/src/per/sai.h ****  * 
  24:../libdaisy_IIT6/libDaisy/src/per/sai.h ****  *  SaiHandle::Config sai_config;
  25:../libdaisy_IIT6/libDaisy/src/per/sai.h ****  *  sai_config.periph          = SaiHandle::Config::Peripheral::SAI_1;
  26:../libdaisy_IIT6/libDaisy/src/per/sai.h ****  *  sai_config.sr              = SaiHandle::Config::SampleRate::SAI_48KHZ;
  27:../libdaisy_IIT6/libDaisy/src/per/sai.h ****  *  sai_config.bit_depth       = SaiHandle::Config::BitDepth::SAI_24BIT;
  28:../libdaisy_IIT6/libDaisy/src/per/sai.h ****  *  sai_config.a_sync          = SaiHandle::Config::Sync::MASTER;
  29:../libdaisy_IIT6/libDaisy/src/per/sai.h ****  *  sai_config.b_sync          = SaiHandle::Config::Sync::SLAVE;
  30:../libdaisy_IIT6/libDaisy/src/per/sai.h ****  *  sai_config.a_dir           = SaiHandle::Config::Direction::RECEIVE;
  31:../libdaisy_IIT6/libDaisy/src/per/sai.h ****  *  sai_config.b_dir           = SaiHandle::Config::Direction::TRANSMIT;
  32:../libdaisy_IIT6/libDaisy/src/per/sai.h ****  *  sai_config.pin_config.fs   = {DSY_GPIOE, 4};
  33:../libdaisy_IIT6/libDaisy/src/per/sai.h ****  *  sai_config.pin_config.mclk = {DSY_GPIOE, 2};
  34:../libdaisy_IIT6/libDaisy/src/per/sai.h ****  *  sai_config.pin_config.sck  = {DSY_GPIOE, 5};
  35:../libdaisy_IIT6/libDaisy/src/per/sai.h ****  *  sai_config.pin_config.sa   = {DSY_GPIOE, 6};
  36:../libdaisy_IIT6/libDaisy/src/per/sai.h ****  *  sai_config.pin_config.sb   = {DSY_GPIOE, 3};
  37:../libdaisy_IIT6/libDaisy/src/per/sai.h ****  *  // Then Initialize
  38:../libdaisy_IIT6/libDaisy/src/per/sai.h ****  *  SaiHandle sai;
  39:../libdaisy_IIT6/libDaisy/src/per/sai.h ****  *  sai.Init(sai_config);
  40:../libdaisy_IIT6/libDaisy/src/per/sai.h ****  *  // Now you can use it:
  41:../libdaisy_IIT6/libDaisy/src/per/sai.h ****  *  sai.StartDma(. . .);
  42:../libdaisy_IIT6/libDaisy/src/per/sai.h ****  */
  43:../libdaisy_IIT6/libDaisy/src/per/sai.h **** class SaiHandle
