  16:../libdaisy_IIT6/libDaisy/src/per/i2c.h ****  *      i2c_conf.mode   = I2CHandle::Config::Mode::Master;
  17:../libdaisy_IIT6/libDaisy/src/per/i2c.h ****  *      i2c_conf.pin_config.scl  = {DSY_GPIOB, 8};
  18:../libdaisy_IIT6/libDaisy/src/per/i2c.h ****  *      i2c_conf.pin_config.sda  = {DSY_GPIOB, 9};
  19:../libdaisy_IIT6/libDaisy/src/per/i2c.h ****  *      // initialise the peripheral
  20:../libdaisy_IIT6/libDaisy/src/per/i2c.h ****  *      I2CHandle i2c;
  21:../libdaisy_IIT6/libDaisy/src/per/i2c.h ****  *      i2c.Init(i2c_conf);
  22:../libdaisy_IIT6/libDaisy/src/per/i2c.h ****  *      // now i2c points to the corresponding peripheral and can be used.
  23:../libdaisy_IIT6/libDaisy/src/per/i2c.h ****  *      i2c.TransmitBlocking( ... );
  24:../libdaisy_IIT6/libDaisy/src/per/i2c.h ****  */
  25:../libdaisy_IIT6/libDaisy/src/per/i2c.h **** class I2CHandle
  26:../libdaisy_IIT6/libDaisy/src/per/i2c.h **** {
  27:../libdaisy_IIT6/libDaisy/src/per/i2c.h ****   public:
  28:../libdaisy_IIT6/libDaisy/src/per/i2c.h ****     /** Contains settings for initialising an I2C interface. */
  29:../libdaisy_IIT6/libDaisy/src/per/i2c.h ****     struct Config
  30:../libdaisy_IIT6/libDaisy/src/per/i2c.h ****     {
  31:../libdaisy_IIT6/libDaisy/src/per/i2c.h ****         /** Specifies whether the interface will operate in master or slave mode. */
