 429:main.cpp      **** static uint16_t Rgb332To565(uint8_t c)
 430:main.cpp      **** {
 431:main.cpp      ****     const uint8_t r = static_cast<uint8_t>((c >> 5) & 0x07u);
 432:main.cpp      ****     const uint8_t g = static_cast<uint8_t>((c >> 2) & 0x07u);
 433:main.cpp      ****     const uint8_t b = static_cast<uint8_t>(c & 0x03u);
 434:main.cpp      ****     const uint16_t rr = static_cast<uint16_t>((r * 31u + 3u) / 7u);
 435:main.cpp      ****     const uint16_t gg = static_cast<uint16_t>((g * 63u + 3u) / 7u);
 436:main.cpp      ****     const uint16_t bb = static_cast<uint16_t>((b * 31u + 1u) / 3u);
 437:main.cpp      ****     return static_cast<uint16_t>((rr << 11) | (gg << 5) | bb);
 438:main.cpp      **** }
