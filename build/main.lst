  36:../libdaisy_IIT6/libDaisy/src/per/i2c.h ****         };
  37:../libdaisy_IIT6/libDaisy/src/per/i2c.h **** 
  38:../libdaisy_IIT6/libDaisy/src/per/i2c.h ****         /** Specifices the internal peripheral to use (these are mapped to different pins on the ha
