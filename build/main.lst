  52:mi/ringsX_MIDI/dsp/fx/reverb.h ****     // This is the Griesinger topology described in the Dattorro paper
  53:mi/ringsX_MIDI/dsp/fx/reverb.h ****     // (4 AP diffusers on the input, then a loop of 2x 2AP+1Delay).
  54:mi/ringsX_MIDI/dsp/fx/reverb.h ****     // Modulation is applied in the loop of the first diffuser AP for additional
  55:mi/ringsX_MIDI/dsp/fx/reverb.h ****     // smearing; and to the two long delays for a slow shimmer/chorus effect.
  56:mi/ringsX_MIDI/dsp/fx/reverb.h ****     typedef E::Reserve<150,
