  49:../libdaisy_IIT6/libDaisy/src/per/dac.h ****         DMA,
  50:../libdaisy_IIT6/libDaisy/src/per/dac.h ****     };
  51:../libdaisy_IIT6/libDaisy/src/per/dac.h **** 
  52:../libdaisy_IIT6/libDaisy/src/per/dac.h ****     /** Sets the number of bits per sample transmitted out of the DAC.
  53:../libdaisy_IIT6/libDaisy/src/per/dac.h ****      ** The output range will be: 0V - VDDA
  54:../libdaisy_IIT6/libDaisy/src/per/dac.h ****      ** The resolution will be roughly: bitdepth / (VDDA - 0V) 
  55:../libdaisy_IIT6/libDaisy/src/per/dac.h ****      ***/
