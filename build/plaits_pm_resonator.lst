  60:mi/plaits/dsp/physical_modelling/resonator.cpp ****   float stretch_factor = 1.0f;
  61:mi/plaits/dsp/physical_modelling/resonator.cpp ****   for (int i = 0; i < n - 1; ++i) {
  62:mi/plaits/dsp/physical_modelling/resonator.cpp ****     stretch_factor += stiffness;
  63:mi/plaits/dsp/physical_modelling/resonator.cpp ****     if (stiffness < 0.0f) {
