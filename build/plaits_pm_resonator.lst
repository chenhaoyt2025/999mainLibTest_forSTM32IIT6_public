  67:mi/plaits/dsp/physical_modelling/resonator.cpp ****     }
  68:mi/plaits/dsp/physical_modelling/resonator.cpp ****   }
  69:mi/plaits/dsp/physical_modelling/resonator.cpp ****   return 1.0f / stretch_factor;
  70:mi/plaits/dsp/physical_modelling/resonator.cpp **** }
