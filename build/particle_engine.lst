  65:mi/stmlib/dsp/cosine_oscillator.h ****     } else {
  66:mi/stmlib/dsp/cosine_oscillator.h ****       if (frequency > 0.5f) {
  67:mi/stmlib/dsp/cosine_oscillator.h ****         frequency -= 0.5f;
  68:mi/stmlib/dsp/cosine_oscillator.h ****       } else {
  69:mi/stmlib/dsp/cosine_oscillator.h ****         sign = -16.0f;
  70:mi/stmlib/dsp/cosine_oscillator.h ****       }
  71:mi/stmlib/dsp/cosine_oscillator.h ****     }
