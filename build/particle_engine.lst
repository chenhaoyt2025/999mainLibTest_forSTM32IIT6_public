  62:mi/stmlib/dsp/filter.h **** class DCBlocker {
  63:mi/stmlib/dsp/filter.h ****  public:
  64:mi/stmlib/dsp/filter.h ****   DCBlocker() { }
  65:mi/stmlib/dsp/filter.h ****   ~DCBlocker() { }
  66:mi/stmlib/dsp/filter.h ****   
  67:mi/stmlib/dsp/filter.h ****   void Init(float pole) {
  68:mi/stmlib/dsp/filter.h ****     x_ = 0.0f;
  69:mi/stmlib/dsp/filter.h ****     y_ = 0.0f;
  70:mi/stmlib/dsp/filter.h ****     pole_ = pole;
  71:mi/stmlib/dsp/filter.h ****   }
  72:mi/stmlib/dsp/filter.h ****   
  73:mi/stmlib/dsp/filter.h ****   inline void Process(float* in_out, size_t size) {
  74:mi/stmlib/dsp/filter.h ****     float x = x_;
ARM GAS  /var/folders/9k/zk1mgrrd7wg4__6zvxvr9w8m0000gn/T//ccrPCefT.s 			page 6


  75:mi/stmlib/dsp/filter.h ****     float y = y_;
  76:mi/stmlib/dsp/filter.h ****     const float pole = pole_;
  77:mi/stmlib/dsp/filter.h ****     while (size--) {
  78:mi/stmlib/dsp/filter.h ****       float old_x = x;
  79:mi/stmlib/dsp/filter.h ****       x = *in_out;
  80:mi/stmlib/dsp/filter.h ****       *in_out++ = y = y * pole + x - old_x;
  81:mi/stmlib/dsp/filter.h ****     }
  82:mi/stmlib/dsp/filter.h ****     x_ = x;
  83:mi/stmlib/dsp/filter.h ****     y_ = y;
  84:mi/stmlib/dsp/filter.h ****   }
  85:mi/stmlib/dsp/filter.h ****   
  86:mi/stmlib/dsp/filter.h ****  private:
  87:mi/stmlib/dsp/filter.h ****   float pole_;
  88:mi/stmlib/dsp/filter.h ****   float x_;
  89:mi/stmlib/dsp/filter.h ****   float y_;
  90:mi/stmlib/dsp/filter.h **** };
