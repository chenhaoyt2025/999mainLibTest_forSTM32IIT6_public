  49:mi/stmlib/dsp/cosine_oscillator.h ****   template<CosineOscillatorMode mode>
  50:mi/stmlib/dsp/cosine_oscillator.h ****   inline void Init(float frequency) {
  51:mi/stmlib/dsp/cosine_oscillator.h ****     if (mode == COSINE_OSCILLATOR_APPROXIMATE) {
  52:mi/stmlib/dsp/cosine_oscillator.h ****       InitApproximate(frequency);
  53:mi/stmlib/dsp/cosine_oscillator.h ****     } else {
  54:mi/stmlib/dsp/cosine_oscillator.h ****       iir_coefficient_ = 2.0f * cosf(2.0f * float(M_PI) * frequency);
