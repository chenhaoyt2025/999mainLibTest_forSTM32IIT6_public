  51:mi/plaits/dsp/oscillator/variable_shape_oscillator.h **** 
  52:mi/plaits/dsp/oscillator/variable_shape_oscillator.h ****   void Init() {
  53:mi/plaits/dsp/oscillator/variable_shape_oscillator.h ****     master_phase_ = 0.0f;
  54:mi/plaits/dsp/oscillator/variable_shape_oscillator.h ****     slave_phase_ = 0.0f;
  55:mi/plaits/dsp/oscillator/variable_shape_oscillator.h ****     next_sample_ = 0.0f;
  56:mi/plaits/dsp/oscillator/variable_shape_oscillator.h ****     previous_pw_ = 0.5f;
  57:mi/plaits/dsp/oscillator/variable_shape_oscillator.h ****     high_ = false;
  58:mi/plaits/dsp/oscillator/variable_shape_oscillator.h ****   
  59:mi/plaits/dsp/oscillator/variable_shape_oscillator.h ****     master_frequency_ = 0.0f;
  60:mi/plaits/dsp/oscillator/variable_shape_oscillator.h ****     slave_frequency_ = 0.01f;
  61:mi/plaits/dsp/oscillator/variable_shape_oscillator.h ****     pw_ = 0.5f;
  62:mi/plaits/dsp/oscillator/variable_shape_oscillator.h ****     waveshape_ = 0.0f;
  63:mi/plaits/dsp/oscillator/variable_shape_oscillator.h ****     phase_modulation_ = 0.0f;
  64:mi/plaits/dsp/oscillator/variable_shape_oscillator.h ****   }
  65:mi/plaits/dsp/oscillator/variable_shape_oscillator.h **** 
  66:mi/plaits/dsp/oscillator/variable_shape_oscillator.h ****   void Render(
