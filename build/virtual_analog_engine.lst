 122:mi/plaits/dsp/engine/virtual_analog_engine.cpp ****   // 1 = variable waveshape controlled by MORPH.
 123:mi/plaits/dsp/engine/virtual_analog_engine.cpp ****   // 2 = variable waveshape controlled by MORPH.
 124:mi/plaits/dsp/engine/virtual_analog_engine.cpp ****   // OUT = crossfade between 1 + 2, 1, 1 sync 2 controlled by TIMBRE.
 125:mi/plaits/dsp/engine/virtual_analog_engine.cpp ****   // AUX = 2.
