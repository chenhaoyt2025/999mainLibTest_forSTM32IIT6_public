  86:mi/plaits/dsp/engine/virtual_analog_engine.cpp ****   
  87:mi/plaits/dsp/engine/virtual_analog_engine.cpp ****   // 1 = variable waveshape controlled by TIMBRE.
  88:mi/plaits/dsp/engine/virtual_analog_engine.cpp ****   // 2 = variable waveshape controlled by MORPH, detuned by HARMONICS.
  89:mi/plaits/dsp/engine/virtual_analog_engine.cpp ****   // OUT = 1 + 2.
  90:mi/plaits/dsp/engine/virtual_analog_engine.cpp ****   // AUX = 1 + sync 2.
