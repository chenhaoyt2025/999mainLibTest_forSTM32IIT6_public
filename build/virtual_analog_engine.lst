  89:mi/plaits/dsp/oscillator/variable_shape_oscillator.h ****   }
  90:mi/plaits/dsp/oscillator/variable_shape_oscillator.h ****   
  91:mi/plaits/dsp/oscillator/variable_shape_oscillator.h ****   template<bool enable_sync, bool output_phase>
  92:mi/plaits/dsp/oscillator/variable_shape_oscillator.h ****   void Render(
  93:mi/plaits/dsp/oscillator/variable_shape_oscillator.h ****       float master_frequency,
  94:mi/plaits/dsp/oscillator/variable_shape_oscillator.h ****       float frequency,
  95:mi/plaits/dsp/oscillator/variable_shape_oscillator.h ****       float pw,
  96:mi/plaits/dsp/oscillator/variable_shape_oscillator.h ****       float waveshape,
  97:mi/plaits/dsp/oscillator/variable_shape_oscillator.h ****       float phase_modulation_amount,
  98:mi/plaits/dsp/oscillator/variable_shape_oscillator.h ****       float* out,
  99:mi/plaits/dsp/oscillator/variable_shape_oscillator.h ****       size_t size) {
 100:mi/plaits/dsp/oscillator/variable_shape_oscillator.h ****     if (master_frequency >= kMaxFrequency) {
 101:mi/plaits/dsp/oscillator/variable_shape_oscillator.h ****       master_frequency = kMaxFrequency;
 102:mi/plaits/dsp/oscillator/variable_shape_oscillator.h ****     }
 103:mi/plaits/dsp/oscillator/variable_shape_oscillator.h ****     if (frequency >= kMaxFrequency) {
