  54:mi/plaits/dsp/physical_modelling/delay_line.h ****   inline void Write(const T sample) {
  55:mi/plaits/dsp/physical_modelling/delay_line.h ****     line_[write_ptr_] = sample;
  56:mi/plaits/dsp/physical_modelling/delay_line.h ****     write_ptr_ = (write_ptr_ - 1 + max_delay) % max_delay;
  57:mi/plaits/dsp/physical_modelling/delay_line.h ****   }
  58:mi/plaits/dsp/physical_modelling/delay_line.h ****   
  59:mi/plaits/dsp/physical_modelling/delay_line.h ****   inline const T Allpass(const T sample, size_t delay, const T coefficient) {
  60:mi/plaits/dsp/physical_modelling/delay_line.h ****     T read = line_[(write_ptr_ + delay) % max_delay];
  61:mi/plaits/dsp/physical_modelling/delay_line.h ****     T write = sample + coefficient * read;
  62:mi/plaits/dsp/physical_modelling/delay_line.h ****     Write(write);
  63:mi/plaits/dsp/physical_modelling/delay_line.h ****     return -write * coefficient + read;
  64:mi/plaits/dsp/physical_modelling/delay_line.h ****   }
  65:mi/plaits/dsp/physical_modelling/delay_line.h **** 
  66:mi/plaits/dsp/physical_modelling/delay_line.h ****   inline const T WriteRead(const T sample, float delay) {
