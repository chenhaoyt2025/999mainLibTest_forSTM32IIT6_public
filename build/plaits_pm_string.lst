  81:mi/stmlib/dsp/dsp.h **** #define ONE_POLE(out, in, coefficient) out += (coefficient) * ((in) - out);
  82:mi/stmlib/dsp/dsp.h **** #define SLOPE(out, in, positive, negative) { \
  83:mi/stmlib/dsp/dsp.h ****   float error = (in) - out; \
  84:mi/stmlib/dsp/dsp.h ****   out += (error > 0 ? positive : negative) * error; \
  85:mi/stmlib/dsp/dsp.h **** }
  86:mi/stmlib/dsp/dsp.h **** #define SLEW(out, in, delta) { \
  87:mi/stmlib/dsp/dsp.h ****   float error = (in) - out; \
  88:mi/stmlib/dsp/dsp.h ****   float d = (delta); \
  89:mi/stmlib/dsp/dsp.h ****   if (error > d) { \
  90:mi/stmlib/dsp/dsp.h ****     error = d; \
  91:mi/stmlib/dsp/dsp.h ****   } else if (error < -d) { \
  92:mi/stmlib/dsp/dsp.h ****     error = -d; \
  93:mi/stmlib/dsp/dsp.h ****   } \
  94:mi/stmlib/dsp/dsp.h ****   out += error; \
  95:mi/stmlib/dsp/dsp.h **** }
