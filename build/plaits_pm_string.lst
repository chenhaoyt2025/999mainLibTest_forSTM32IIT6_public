  52:mi/stmlib/dsp/dsp.h **** inline float InterpolateHermite(const float* table, float index, float size) {
ARM GAS  /var/folders/9k/zk1mgrrd7wg4__6zvxvr9w8m0000gn/T//ccXXoDHF.s 			page 58


  53:mi/stmlib/dsp/dsp.h ****   index *= size;
  54:mi/stmlib/dsp/dsp.h ****   MAKE_INTEGRAL_FRACTIONAL(index)
  55:mi/stmlib/dsp/dsp.h ****   const float xm1 = table[index_integral - 1];
  56:mi/stmlib/dsp/dsp.h ****   const float x0 = table[index_integral + 0];
  57:mi/stmlib/dsp/dsp.h ****   const float x1 = table[index_integral + 1];
  58:mi/stmlib/dsp/dsp.h ****   const float x2 = table[index_integral + 2];
  59:mi/stmlib/dsp/dsp.h ****   const float c = (x1 - xm1) * 0.5f;
  60:mi/stmlib/dsp/dsp.h ****   const float v = x0 - x1;
  61:mi/stmlib/dsp/dsp.h ****   const float w = c + v;
  62:mi/stmlib/dsp/dsp.h ****   const float a = w + v + (x2 - x0) * 0.5f;
  63:mi/stmlib/dsp/dsp.h ****   const float b_neg = w + a;
  64:mi/stmlib/dsp/dsp.h ****   const float f = index_fractional;
  65:mi/stmlib/dsp/dsp.h ****   return (((a * f) - b_neg) * f + c) * f + x0;
  66:mi/stmlib/dsp/dsp.h **** }
  67:mi/stmlib/dsp/dsp.h **** 
  68:mi/stmlib/dsp/dsp.h **** inline float InterpolateWrap(const float* table, float index, float size) {
  69:mi/stmlib/dsp/dsp.h ****   index -= static_cast<float>(static_cast<int32_t>(index));
  70:mi/stmlib/dsp/dsp.h ****   index *= size;
  71:mi/stmlib/dsp/dsp.h ****   MAKE_INTEGRAL_FRACTIONAL(index)
  72:mi/stmlib/dsp/dsp.h ****   float a = table[index_integral];
  73:mi/stmlib/dsp/dsp.h ****   float b = table[index_integral + 1];
  74:mi/stmlib/dsp/dsp.h ****   return a + (b - a) * index_fractional;
  75:mi/stmlib/dsp/dsp.h **** }
