 188:mi/stmlib/dsp/filter.h ****     state_1_ = state_2_ = 0.0f;
 189:mi/stmlib/dsp/filter.h ****   }
 190:mi/stmlib/dsp/filter.h ****   
 191:mi/stmlib/dsp/filter.h ****   // Copy settings from another filter.
 192:mi/stmlib/dsp/filter.h ****   inline void set(const Svf& f) {
 193:mi/stmlib/dsp/filter.h ****     g_ = f.g();
 194:mi/stmlib/dsp/filter.h ****     r_ = f.r();
