  34:mi/stmlib/dsp/hysteresis_quantizer.h **** 
  35:mi/stmlib/dsp/hysteresis_quantizer.h **** namespace stmlib {
ARM GAS  /var/folders/9k/zk1mgrrd7wg4__6zvxvr9w8m0000gn/T//ccOb8x3j.s 			page 5


  36:mi/stmlib/dsp/hysteresis_quantizer.h **** 
  37:mi/stmlib/dsp/hysteresis_quantizer.h **** class HysteresisQuantizer {
  38:mi/stmlib/dsp/hysteresis_quantizer.h ****  public:
  39:mi/stmlib/dsp/hysteresis_quantizer.h ****   HysteresisQuantizer() { }
  40:mi/stmlib/dsp/hysteresis_quantizer.h ****   ~HysteresisQuantizer() { }
  41:mi/stmlib/dsp/hysteresis_quantizer.h **** 
  42:mi/stmlib/dsp/hysteresis_quantizer.h ****   void Init() {
  43:mi/stmlib/dsp/hysteresis_quantizer.h ****     quantized_value_ = 0;
  44:mi/stmlib/dsp/hysteresis_quantizer.h ****   }
  45:mi/stmlib/dsp/hysteresis_quantizer.h **** 
  46:mi/stmlib/dsp/hysteresis_quantizer.h ****   inline int Process(float value, int num_steps) {
  47:mi/stmlib/dsp/hysteresis_quantizer.h ****     return Process(value, num_steps, 0.25f);
  48:mi/stmlib/dsp/hysteresis_quantizer.h ****   }
  49:mi/stmlib/dsp/hysteresis_quantizer.h **** 
  50:mi/stmlib/dsp/hysteresis_quantizer.h ****   inline int Process(float value, int num_steps, float hysteresis) {
  51:mi/stmlib/dsp/hysteresis_quantizer.h ****     return Process(0, value, num_steps, hysteresis);
  52:mi/stmlib/dsp/hysteresis_quantizer.h ****   }
  53:mi/stmlib/dsp/hysteresis_quantizer.h **** 
  54:mi/stmlib/dsp/hysteresis_quantizer.h ****   inline int Process(int base, float value, int num_steps, float hysteresis) {
  55:mi/stmlib/dsp/hysteresis_quantizer.h ****     value *= static_cast<float>(num_steps - 1);
  56:mi/stmlib/dsp/hysteresis_quantizer.h ****     value += static_cast<float>(base);
  57:mi/stmlib/dsp/hysteresis_quantizer.h ****     float hysteresis_feedback = value > static_cast<float>(quantized_value_)
  58:mi/stmlib/dsp/hysteresis_quantizer.h ****         ? -hysteresis
  59:mi/stmlib/dsp/hysteresis_quantizer.h ****         : hysteresis;
  60:mi/stmlib/dsp/hysteresis_quantizer.h ****     int q = static_cast<int>(value + hysteresis_feedback + 0.5f);
  61:mi/stmlib/dsp/hysteresis_quantizer.h ****     CONSTRAIN(q, 0, num_steps - 1);
  62:mi/stmlib/dsp/hysteresis_quantizer.h ****     quantized_value_ = q;
  63:mi/stmlib/dsp/hysteresis_quantizer.h ****     return q;
  64:mi/stmlib/dsp/hysteresis_quantizer.h ****   }
  65:mi/stmlib/dsp/hysteresis_quantizer.h **** 
  66:mi/stmlib/dsp/hysteresis_quantizer.h ****   template<typename T>
  67:mi/stmlib/dsp/hysteresis_quantizer.h ****   const T& Lookup(const T* array, float value, int num_steps) {
  68:mi/stmlib/dsp/hysteresis_quantizer.h ****     return array[Process(value, num_steps)];
  69:mi/stmlib/dsp/hysteresis_quantizer.h ****   }
  70:mi/stmlib/dsp/hysteresis_quantizer.h **** 
  71:mi/stmlib/dsp/hysteresis_quantizer.h ****  private:
  72:mi/stmlib/dsp/hysteresis_quantizer.h ****   int quantized_value_;
  73:mi/stmlib/dsp/hysteresis_quantizer.h ****   
  74:mi/stmlib/dsp/hysteresis_quantizer.h ****   DISALLOW_COPY_AND_ASSIGN(HysteresisQuantizer);
  75:mi/stmlib/dsp/hysteresis_quantizer.h **** };
