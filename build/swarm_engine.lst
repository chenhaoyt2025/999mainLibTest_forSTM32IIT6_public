 189:mi/plaits/dsp/engine/swarm_engine.h **** class SwarmVoice {
 190:mi/plaits/dsp/engine/swarm_engine.h ****  public:
 191:mi/plaits/dsp/engine/swarm_engine.h ****   SwarmVoice() { }
 192:mi/plaits/dsp/engine/swarm_engine.h ****   ~SwarmVoice() { }
 193:mi/plaits/dsp/engine/swarm_engine.h ****   
 194:mi/plaits/dsp/engine/swarm_engine.h ****   void Init(float rank) {
 195:mi/plaits/dsp/engine/swarm_engine.h ****     rank_ = rank;
 196:mi/plaits/dsp/engine/swarm_engine.h ****     envelope_.Init();
 197:mi/plaits/dsp/engine/swarm_engine.h ****     saw_.Init();
 198:mi/plaits/dsp/engine/swarm_engine.h ****     sine_.Init();
 199:mi/plaits/dsp/engine/swarm_engine.h ****   }
 200:mi/plaits/dsp/engine/swarm_engine.h ****   
ARM GAS  /var/folders/9k/zk1mgrrd7wg4__6zvxvr9w8m0000gn/T//ccnOQsWh.s 			page 5


 201:mi/plaits/dsp/engine/swarm_engine.h ****   void Render(
 202:mi/plaits/dsp/engine/swarm_engine.h ****       float f0,
 203:mi/plaits/dsp/engine/swarm_engine.h ****       float density,
 204:mi/plaits/dsp/engine/swarm_engine.h ****       bool burst_mode,
 205:mi/plaits/dsp/engine/swarm_engine.h ****       bool start_burst,
 206:mi/plaits/dsp/engine/swarm_engine.h ****       float spread,
 207:mi/plaits/dsp/engine/swarm_engine.h ****       float size_ratio,
 208:mi/plaits/dsp/engine/swarm_engine.h ****       float* saw,
 209:mi/plaits/dsp/engine/swarm_engine.h ****       float* sine,
 210:mi/plaits/dsp/engine/swarm_engine.h ****       size_t size) {
 211:mi/plaits/dsp/engine/swarm_engine.h ****     envelope_.Step(density, burst_mode, start_burst);
 212:mi/plaits/dsp/engine/swarm_engine.h ****     
 213:mi/plaits/dsp/engine/swarm_engine.h ****     const float scale = 1.0f / kNumSwarmVoices;
 214:mi/plaits/dsp/engine/swarm_engine.h ****     const float amplitude = envelope_.amplitude(size_ratio) * scale;
 215:mi/plaits/dsp/engine/swarm_engine.h **** 
 216:mi/plaits/dsp/engine/swarm_engine.h ****     const float expo_amount = envelope_.frequency(size_ratio);
 217:mi/plaits/dsp/engine/swarm_engine.h ****     f0 *= stmlib::SemitonesToRatio(48.0f * expo_amount * spread * rank_);
 218:mi/plaits/dsp/engine/swarm_engine.h ****     
 219:mi/plaits/dsp/engine/swarm_engine.h ****     const float linear_amount = rank_ * (rank_ + 0.01f) * spread * 0.25f;
 220:mi/plaits/dsp/engine/swarm_engine.h ****     f0 *= 1.0f + linear_amount;
 221:mi/plaits/dsp/engine/swarm_engine.h **** 
 222:mi/plaits/dsp/engine/swarm_engine.h ****     saw_.Render(f0, amplitude, saw, size);
 223:mi/plaits/dsp/engine/swarm_engine.h ****     sine_.Render(f0, amplitude, sine, size);
 224:mi/plaits/dsp/engine/swarm_engine.h ****   };
 225:mi/plaits/dsp/engine/swarm_engine.h ****   
 226:mi/plaits/dsp/engine/swarm_engine.h ****  private:
 227:mi/plaits/dsp/engine/swarm_engine.h ****   float rank_;
 228:mi/plaits/dsp/engine/swarm_engine.h **** 
 229:mi/plaits/dsp/engine/swarm_engine.h ****   GrainEnvelope envelope_;
 230:mi/plaits/dsp/engine/swarm_engine.h ****   AdditiveSawOscillator saw_;
 231:mi/plaits/dsp/engine/swarm_engine.h ****   FastSineOscillator sine_;
 232:mi/plaits/dsp/engine/swarm_engine.h **** };
