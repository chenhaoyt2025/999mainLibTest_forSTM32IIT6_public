 175:mi/plaits/dsp/oscillator/sine_oscillator.h ****   
 176:mi/plaits/dsp/oscillator/sine_oscillator.h ****   static inline float Fast2Sin(float f) {
 177:mi/plaits/dsp/oscillator/sine_oscillator.h ****     // In theory, epsilon = 2 sin(pi f)
 178:mi/plaits/dsp/oscillator/sine_oscillator.h ****     // Here, to avoid the call to sinf, we use a 3rd order polynomial
 179:mi/plaits/dsp/oscillator/sine_oscillator.h ****     // approximation, which looks like a Taylor expansion, but with a
 180:mi/plaits/dsp/oscillator/sine_oscillator.h ****     // correction term to give a good trade-off between average error
 181:mi/plaits/dsp/oscillator/sine_oscillator.h ****     // (1.13 cents) and maximum error (7.33 cents) when generating sinewaves
 182:mi/plaits/dsp/oscillator/sine_oscillator.h ****     // in the 16 Hz to 16kHz range (with sr = 48kHz).
 183:mi/plaits/dsp/oscillator/sine_oscillator.h ****     const float f_pi = f * float(M_PI);
 184:mi/plaits/dsp/oscillator/sine_oscillator.h ****     return f_pi * (2.0f - (2.0f * 0.96f / 6.0f) * f_pi * f_pi);
 185:mi/plaits/dsp/oscillator/sine_oscillator.h ****   }
 186:mi/plaits/dsp/oscillator/sine_oscillator.h ****   
 187:mi/plaits/dsp/oscillator/sine_oscillator.h ****   void Render(float frequency, float* out, size_t size) {
 188:mi/plaits/dsp/oscillator/sine_oscillator.h ****     RenderInternal<NORMAL>(frequency, 1.0f, out, NULL, size);
 189:mi/plaits/dsp/oscillator/sine_oscillator.h ****   }
 190:mi/plaits/dsp/oscillator/sine_oscillator.h ****   
 191:mi/plaits/dsp/oscillator/sine_oscillator.h ****   void Render(float frequency, float amplitude, float* out, size_t size) {
 192:mi/plaits/dsp/oscillator/sine_oscillator.h ****     RenderInternal<ADDITIVE>(frequency, amplitude, out, NULL, size);
 193:mi/plaits/dsp/oscillator/sine_oscillator.h ****   }
 194:mi/plaits/dsp/oscillator/sine_oscillator.h **** 
 195:mi/plaits/dsp/oscillator/sine_oscillator.h ****   void RenderQuadrature(
 196:mi/plaits/dsp/oscillator/sine_oscillator.h ****       float frequency, float amplitude, float* x, float* y, size_t size) {
 197:mi/plaits/dsp/oscillator/sine_oscillator.h ****     RenderInternal<QUADRATURE>(frequency, amplitude, x, y, size);
 198:mi/plaits/dsp/oscillator/sine_oscillator.h ****   }
