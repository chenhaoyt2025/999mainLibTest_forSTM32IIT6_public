  26:mi/plaits/dsp/oscillator/sine_oscillator.h **** //
  27:mi/plaits/dsp/oscillator/sine_oscillator.h **** // Simple sine oscillator (wavetable) + fast sine oscillator (magic circle).
  28:mi/plaits/dsp/oscillator/sine_oscillator.h **** //
  29:mi/plaits/dsp/oscillator/sine_oscillator.h **** // The fast implementation might glitch a bit under heavy modulations of the
  30:mi/plaits/dsp/oscillator/sine_oscillator.h **** // frequency.
  31:mi/plaits/dsp/oscillator/sine_oscillator.h **** 
  32:mi/plaits/dsp/oscillator/sine_oscillator.h **** #ifndef PLAITS_DSP_OSCILLATOR_SINE_OSCILLATOR_H_
  33:mi/plaits/dsp/oscillator/sine_oscillator.h **** #define PLAITS_DSP_OSCILLATOR_SINE_OSCILLATOR_H_
  34:mi/plaits/dsp/oscillator/sine_oscillator.h **** 
  35:mi/plaits/dsp/oscillator/sine_oscillator.h **** #include "stmlib/dsp/dsp.h"
  36:mi/plaits/dsp/oscillator/sine_oscillator.h **** #include "stmlib/dsp/parameter_interpolator.h"
  37:mi/plaits/dsp/oscillator/sine_oscillator.h **** #include "stmlib/dsp/rsqrt.h"
ARM GAS  /var/folders/9k/zk1mgrrd7wg4__6zvxvr9w8m0000gn/T//ccnOQsWh.s 			page 13


  38:mi/plaits/dsp/oscillator/sine_oscillator.h **** 
  39:mi/plaits/dsp/oscillator/sine_oscillator.h **** #include "plaits/resources.h"
  40:mi/plaits/dsp/oscillator/sine_oscillator.h **** 
  41:mi/plaits/dsp/oscillator/sine_oscillator.h **** namespace plaits {
  42:mi/plaits/dsp/oscillator/sine_oscillator.h ****   
  43:mi/plaits/dsp/oscillator/sine_oscillator.h **** const float kSineLUTSize = 512.0f;
  44:mi/plaits/dsp/oscillator/sine_oscillator.h **** const size_t kSineLUTQuadrature = 128;
  45:mi/plaits/dsp/oscillator/sine_oscillator.h **** const size_t kSineLUTBits = 9;
  46:mi/plaits/dsp/oscillator/sine_oscillator.h **** 
  47:mi/plaits/dsp/oscillator/sine_oscillator.h **** // Safe for phase >= 0.0f, will wrap.
  48:mi/plaits/dsp/oscillator/sine_oscillator.h **** inline float Sine(float phase) {
  49:mi/plaits/dsp/oscillator/sine_oscillator.h ****   return stmlib::InterpolateWrap(lut_sine, phase, kSineLUTSize);
  50:mi/plaits/dsp/oscillator/sine_oscillator.h **** }
  51:mi/plaits/dsp/oscillator/sine_oscillator.h **** 
  52:mi/plaits/dsp/oscillator/sine_oscillator.h **** // Potentially unsafe, if phase >= 1.25.
  53:mi/plaits/dsp/oscillator/sine_oscillator.h **** inline float SineNoWrap(float phase) {
  54:mi/plaits/dsp/oscillator/sine_oscillator.h ****   return stmlib::Interpolate(lut_sine, phase, kSineLUTSize);
  55:mi/plaits/dsp/oscillator/sine_oscillator.h **** }
  56:mi/plaits/dsp/oscillator/sine_oscillator.h **** 
  57:mi/plaits/dsp/oscillator/sine_oscillator.h **** // With positive of negative phase modulation up to an index of 32.
  58:mi/plaits/dsp/oscillator/sine_oscillator.h **** inline float SinePM(uint32_t phase, float pm) {
  59:mi/plaits/dsp/oscillator/sine_oscillator.h ****   const float max_uint32 = 4294967296.0f;
  60:mi/plaits/dsp/oscillator/sine_oscillator.h ****   const int max_index = 32;
  61:mi/plaits/dsp/oscillator/sine_oscillator.h ****   const float offset = float(max_index);
  62:mi/plaits/dsp/oscillator/sine_oscillator.h ****   const float scale = max_uint32 / float(max_index * 2);
  63:mi/plaits/dsp/oscillator/sine_oscillator.h **** 
  64:mi/plaits/dsp/oscillator/sine_oscillator.h ****   phase += static_cast<uint32_t>((pm + offset) * scale) * max_index * 2;
  65:mi/plaits/dsp/oscillator/sine_oscillator.h ****   
  66:mi/plaits/dsp/oscillator/sine_oscillator.h ****   uint32_t integral = phase >> (32 - kSineLUTBits);
  67:mi/plaits/dsp/oscillator/sine_oscillator.h ****   float fractional = static_cast<float>(phase << kSineLUTBits) / float(max_uint32);
  68:mi/plaits/dsp/oscillator/sine_oscillator.h ****   float a = lut_sine[integral];
  69:mi/plaits/dsp/oscillator/sine_oscillator.h ****   float b = lut_sine[integral + 1];
  70:mi/plaits/dsp/oscillator/sine_oscillator.h ****   return a + (b - a) * fractional;
  71:mi/plaits/dsp/oscillator/sine_oscillator.h **** }
  72:mi/plaits/dsp/oscillator/sine_oscillator.h **** 
  73:mi/plaits/dsp/oscillator/sine_oscillator.h **** // Direct lookup without interpolation.
  74:mi/plaits/dsp/oscillator/sine_oscillator.h **** inline float SineRaw(uint32_t phase) {
  75:mi/plaits/dsp/oscillator/sine_oscillator.h ****   return lut_sine[phase >> (32 - kSineLUTBits)];
  76:mi/plaits/dsp/oscillator/sine_oscillator.h **** }
  77:mi/plaits/dsp/oscillator/sine_oscillator.h **** 
  78:mi/plaits/dsp/oscillator/sine_oscillator.h **** class SineOscillator {
  79:mi/plaits/dsp/oscillator/sine_oscillator.h ****  public:
  80:mi/plaits/dsp/oscillator/sine_oscillator.h ****   SineOscillator() { }
  81:mi/plaits/dsp/oscillator/sine_oscillator.h ****   ~SineOscillator() { }
  82:mi/plaits/dsp/oscillator/sine_oscillator.h **** 
  83:mi/plaits/dsp/oscillator/sine_oscillator.h ****   void Init() {
  84:mi/plaits/dsp/oscillator/sine_oscillator.h ****     phase_ = 0.0f;
  85:mi/plaits/dsp/oscillator/sine_oscillator.h ****     frequency_ = 0.0f;
  86:mi/plaits/dsp/oscillator/sine_oscillator.h ****     amplitude_ = 0.0f;
  87:mi/plaits/dsp/oscillator/sine_oscillator.h ****   }
  88:mi/plaits/dsp/oscillator/sine_oscillator.h ****   
  89:mi/plaits/dsp/oscillator/sine_oscillator.h ****   inline float Next(float frequency) {
  90:mi/plaits/dsp/oscillator/sine_oscillator.h ****     if (frequency >= 0.5f) {
  91:mi/plaits/dsp/oscillator/sine_oscillator.h ****       frequency = 0.5f;
  92:mi/plaits/dsp/oscillator/sine_oscillator.h ****     }
  93:mi/plaits/dsp/oscillator/sine_oscillator.h ****     
  94:mi/plaits/dsp/oscillator/sine_oscillator.h ****     phase_ += frequency;
ARM GAS  /var/folders/9k/zk1mgrrd7wg4__6zvxvr9w8m0000gn/T//ccnOQsWh.s 			page 14


  95:mi/plaits/dsp/oscillator/sine_oscillator.h ****     if (phase_ >= 1.0f) {
  96:mi/plaits/dsp/oscillator/sine_oscillator.h ****       phase_ -= 1.0f;
  97:mi/plaits/dsp/oscillator/sine_oscillator.h ****     }
  98:mi/plaits/dsp/oscillator/sine_oscillator.h ****     
  99:mi/plaits/dsp/oscillator/sine_oscillator.h ****     return SineNoWrap(phase_);
 100:mi/plaits/dsp/oscillator/sine_oscillator.h ****   }
 101:mi/plaits/dsp/oscillator/sine_oscillator.h ****   
 102:mi/plaits/dsp/oscillator/sine_oscillator.h ****   inline void Next(float frequency, float amplitude, float* sin, float* cos) {
 103:mi/plaits/dsp/oscillator/sine_oscillator.h ****     if (frequency >= 0.5f) {
 104:mi/plaits/dsp/oscillator/sine_oscillator.h ****       frequency = 0.5f;
 105:mi/plaits/dsp/oscillator/sine_oscillator.h ****     }
 106:mi/plaits/dsp/oscillator/sine_oscillator.h ****     
 107:mi/plaits/dsp/oscillator/sine_oscillator.h ****     phase_ += frequency;
 108:mi/plaits/dsp/oscillator/sine_oscillator.h ****     if (phase_ >= 1.0f) {
 109:mi/plaits/dsp/oscillator/sine_oscillator.h ****       phase_ -= 1.0f;
 110:mi/plaits/dsp/oscillator/sine_oscillator.h ****     }
 111:mi/plaits/dsp/oscillator/sine_oscillator.h ****     
 112:mi/plaits/dsp/oscillator/sine_oscillator.h ****     *sin = amplitude * SineNoWrap(phase_);
 113:mi/plaits/dsp/oscillator/sine_oscillator.h ****     *cos = amplitude * SineNoWrap(phase_ + 0.25f);
 114:mi/plaits/dsp/oscillator/sine_oscillator.h ****   }
 115:mi/plaits/dsp/oscillator/sine_oscillator.h ****   
 116:mi/plaits/dsp/oscillator/sine_oscillator.h ****   void Render(float frequency, float amplitude, float* out, size_t size) {
 117:mi/plaits/dsp/oscillator/sine_oscillator.h ****     RenderInternal<true>(frequency, amplitude, out, size);
 118:mi/plaits/dsp/oscillator/sine_oscillator.h ****   }
 119:mi/plaits/dsp/oscillator/sine_oscillator.h ****   
 120:mi/plaits/dsp/oscillator/sine_oscillator.h ****   void Render(float frequency, float* out, size_t size) {
 121:mi/plaits/dsp/oscillator/sine_oscillator.h ****     RenderInternal<false>(frequency, 1.0f, out, size);
 122:mi/plaits/dsp/oscillator/sine_oscillator.h ****   }
 123:mi/plaits/dsp/oscillator/sine_oscillator.h **** 
 124:mi/plaits/dsp/oscillator/sine_oscillator.h ****  private:
 125:mi/plaits/dsp/oscillator/sine_oscillator.h ****   template<bool additive>
 126:mi/plaits/dsp/oscillator/sine_oscillator.h ****   void RenderInternal(
 127:mi/plaits/dsp/oscillator/sine_oscillator.h ****       float frequency, float amplitude, float* out, size_t size) {
 128:mi/plaits/dsp/oscillator/sine_oscillator.h ****     if (frequency >= 0.5f) {
 129:mi/plaits/dsp/oscillator/sine_oscillator.h ****       frequency = 0.5f;
 130:mi/plaits/dsp/oscillator/sine_oscillator.h ****     }
 131:mi/plaits/dsp/oscillator/sine_oscillator.h ****     stmlib::ParameterInterpolator fm(&frequency_, frequency, size);
 132:mi/plaits/dsp/oscillator/sine_oscillator.h ****     stmlib::ParameterInterpolator am(&amplitude_, amplitude, size);
 133:mi/plaits/dsp/oscillator/sine_oscillator.h **** 
 134:mi/plaits/dsp/oscillator/sine_oscillator.h ****     while (size--) {
 135:mi/plaits/dsp/oscillator/sine_oscillator.h ****       phase_ += fm.Next();
 136:mi/plaits/dsp/oscillator/sine_oscillator.h ****       if (phase_ >= 1.0f) {
 137:mi/plaits/dsp/oscillator/sine_oscillator.h ****         phase_ -= 1.0f;
 138:mi/plaits/dsp/oscillator/sine_oscillator.h ****       }
 139:mi/plaits/dsp/oscillator/sine_oscillator.h ****       float s = SineNoWrap(phase_);
 140:mi/plaits/dsp/oscillator/sine_oscillator.h ****       if (additive) {
 141:mi/plaits/dsp/oscillator/sine_oscillator.h ****         *out++ += am.Next() * s;
 142:mi/plaits/dsp/oscillator/sine_oscillator.h ****       } else {
 143:mi/plaits/dsp/oscillator/sine_oscillator.h ****         *out++ = s;
 144:mi/plaits/dsp/oscillator/sine_oscillator.h ****       }
 145:mi/plaits/dsp/oscillator/sine_oscillator.h ****     }
 146:mi/plaits/dsp/oscillator/sine_oscillator.h ****   }
 147:mi/plaits/dsp/oscillator/sine_oscillator.h ****   
 148:mi/plaits/dsp/oscillator/sine_oscillator.h ****   // Oscillator state.
 149:mi/plaits/dsp/oscillator/sine_oscillator.h ****   float phase_;
 150:mi/plaits/dsp/oscillator/sine_oscillator.h **** 
