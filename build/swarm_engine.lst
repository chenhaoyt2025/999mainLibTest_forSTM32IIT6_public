  43:mi/plaits/dsp/engine/swarm_engine.h **** 
  44:mi/plaits/dsp/engine/swarm_engine.h **** const int kNumSwarmVoices = 8;
  45:mi/plaits/dsp/engine/swarm_engine.h **** 
  46:mi/plaits/dsp/engine/swarm_engine.h **** class GrainEnvelope {
  47:mi/plaits/dsp/engine/swarm_engine.h ****  public:
  48:mi/plaits/dsp/engine/swarm_engine.h ****   GrainEnvelope() { }
  49:mi/plaits/dsp/engine/swarm_engine.h ****   ~GrainEnvelope() { }
  50:mi/plaits/dsp/engine/swarm_engine.h ****   
  51:mi/plaits/dsp/engine/swarm_engine.h ****   void Init() {
  52:mi/plaits/dsp/engine/swarm_engine.h ****     from_ = 0.0f;
  53:mi/plaits/dsp/engine/swarm_engine.h ****     interval_ = 1.0f;
  54:mi/plaits/dsp/engine/swarm_engine.h ****     phase_ = 1.0f;
  55:mi/plaits/dsp/engine/swarm_engine.h ****     fm_ = 0.0f;
  56:mi/plaits/dsp/engine/swarm_engine.h ****     amplitude_ = 0.5f;
  57:mi/plaits/dsp/engine/swarm_engine.h ****     previous_size_ratio_ = 0.0f;
  58:mi/plaits/dsp/engine/swarm_engine.h ****     filter_coefficient_ = 0.0f;
  59:mi/plaits/dsp/engine/swarm_engine.h ****   }
  60:mi/plaits/dsp/engine/swarm_engine.h ****   
  61:mi/plaits/dsp/engine/swarm_engine.h ****   inline void Step(float rate, bool burst_mode, bool start_burst) {
  62:mi/plaits/dsp/engine/swarm_engine.h ****     bool randomize = false;
  63:mi/plaits/dsp/engine/swarm_engine.h ****     if (start_burst) {
  64:mi/plaits/dsp/engine/swarm_engine.h ****       phase_ = 0.5f;
  65:mi/plaits/dsp/engine/swarm_engine.h ****       fm_ = 16.0f;
  66:mi/plaits/dsp/engine/swarm_engine.h ****       randomize = true;
  67:mi/plaits/dsp/engine/swarm_engine.h ****     } else {
  68:mi/plaits/dsp/engine/swarm_engine.h ****       phase_ += rate * fm_;
  69:mi/plaits/dsp/engine/swarm_engine.h ****       if (phase_ >= 1.0f) {
  70:mi/plaits/dsp/engine/swarm_engine.h ****         phase_ -= static_cast<float>(static_cast<int>(phase_));
  71:mi/plaits/dsp/engine/swarm_engine.h ****         randomize = true;
  72:mi/plaits/dsp/engine/swarm_engine.h ****       }
  73:mi/plaits/dsp/engine/swarm_engine.h ****     }
  74:mi/plaits/dsp/engine/swarm_engine.h ****     
  75:mi/plaits/dsp/engine/swarm_engine.h ****     if (randomize) {
  76:mi/plaits/dsp/engine/swarm_engine.h ****       from_ += interval_;
  77:mi/plaits/dsp/engine/swarm_engine.h ****       interval_ = stmlib::Random::GetFloat() - from_;
  78:mi/plaits/dsp/engine/swarm_engine.h ****       // Randomize the duration of the grain.
  79:mi/plaits/dsp/engine/swarm_engine.h ****       if (burst_mode) {
  80:mi/plaits/dsp/engine/swarm_engine.h ****         fm_ *= 0.8f + 0.2f * stmlib::Random::GetFloat();
  81:mi/plaits/dsp/engine/swarm_engine.h ****       } else {
  82:mi/plaits/dsp/engine/swarm_engine.h ****         fm_ = 0.5f + 1.5f * stmlib::Random::GetFloat();
  83:mi/plaits/dsp/engine/swarm_engine.h ****       }
  84:mi/plaits/dsp/engine/swarm_engine.h ****     }
  85:mi/plaits/dsp/engine/swarm_engine.h ****   }
  86:mi/plaits/dsp/engine/swarm_engine.h ****   
ARM GAS  /var/folders/9k/zk1mgrrd7wg4__6zvxvr9w8m0000gn/T//ccnOQsWh.s 			page 3


  87:mi/plaits/dsp/engine/swarm_engine.h ****   inline float frequency(float size_ratio) const {
  88:mi/plaits/dsp/engine/swarm_engine.h ****     // We approximate two overlapping grains of frequencies f1 and f2
  89:mi/plaits/dsp/engine/swarm_engine.h ****     // By a continuous tone ramping from f1 to f2. This allows a continuous
  90:mi/plaits/dsp/engine/swarm_engine.h ****     // transition between the "grain cloud" and "swarm of glissandi" textures.
  91:mi/plaits/dsp/engine/swarm_engine.h ****     if (size_ratio < 1.0f) {
  92:mi/plaits/dsp/engine/swarm_engine.h ****       return 2.0f * (from_ + interval_ * phase_) - 1.0f;
  93:mi/plaits/dsp/engine/swarm_engine.h ****     } else {
  94:mi/plaits/dsp/engine/swarm_engine.h ****       return from_;
  95:mi/plaits/dsp/engine/swarm_engine.h ****     }
  96:mi/plaits/dsp/engine/swarm_engine.h ****   }
  97:mi/plaits/dsp/engine/swarm_engine.h ****   
  98:mi/plaits/dsp/engine/swarm_engine.h ****   inline float amplitude(float size_ratio) {
  99:mi/plaits/dsp/engine/swarm_engine.h ****     float target_amplitude = 1.0f;
 100:mi/plaits/dsp/engine/swarm_engine.h ****     if (size_ratio >= 1.0f) {
 101:mi/plaits/dsp/engine/swarm_engine.h ****       float phase = (phase_ - 0.5f) * size_ratio;
 102:mi/plaits/dsp/engine/swarm_engine.h ****       CONSTRAIN(phase, -1.0f, 1.0f);
 103:mi/plaits/dsp/engine/swarm_engine.h ****       float e = Sine(0.5f * phase + 1.25f);
 104:mi/plaits/dsp/engine/swarm_engine.h ****       target_amplitude = 0.5f * (e + 1.0f);
 105:mi/plaits/dsp/engine/swarm_engine.h ****     }
 106:mi/plaits/dsp/engine/swarm_engine.h ****     
 107:mi/plaits/dsp/engine/swarm_engine.h ****     if ((size_ratio >= 1.0f) ^ (previous_size_ratio_ >= 1.0f)) {
 108:mi/plaits/dsp/engine/swarm_engine.h ****       filter_coefficient_ = 0.5f;
 109:mi/plaits/dsp/engine/swarm_engine.h ****     }
 110:mi/plaits/dsp/engine/swarm_engine.h ****     filter_coefficient_ *= 0.95f;
 111:mi/plaits/dsp/engine/swarm_engine.h ****     
 112:mi/plaits/dsp/engine/swarm_engine.h ****     previous_size_ratio_ = size_ratio;
 113:mi/plaits/dsp/engine/swarm_engine.h ****     ONE_POLE(amplitude_, target_amplitude, 0.5f - filter_coefficient_);
 114:mi/plaits/dsp/engine/swarm_engine.h ****     return amplitude_;
 115:mi/plaits/dsp/engine/swarm_engine.h ****   }
 116:mi/plaits/dsp/engine/swarm_engine.h ****   
 117:mi/plaits/dsp/engine/swarm_engine.h ****  private:
 118:mi/plaits/dsp/engine/swarm_engine.h ****   float from_;
 119:mi/plaits/dsp/engine/swarm_engine.h ****   float interval_;
 120:mi/plaits/dsp/engine/swarm_engine.h ****   float phase_;
 121:mi/plaits/dsp/engine/swarm_engine.h ****   float fm_;
 122:mi/plaits/dsp/engine/swarm_engine.h ****   float amplitude_;
 123:mi/plaits/dsp/engine/swarm_engine.h ****   float previous_size_ratio_;
 124:mi/plaits/dsp/engine/swarm_engine.h ****   float filter_coefficient_;
 125:mi/plaits/dsp/engine/swarm_engine.h ****   
 126:mi/plaits/dsp/engine/swarm_engine.h ****   DISALLOW_COPY_AND_ASSIGN(GrainEnvelope);
 127:mi/plaits/dsp/engine/swarm_engine.h **** };
 128:mi/plaits/dsp/engine/swarm_engine.h **** 
 129:mi/plaits/dsp/engine/swarm_engine.h **** class AdditiveSawOscillator {
 130:mi/plaits/dsp/engine/swarm_engine.h ****  public:
 131:mi/plaits/dsp/engine/swarm_engine.h ****   AdditiveSawOscillator() { }
 132:mi/plaits/dsp/engine/swarm_engine.h ****   ~AdditiveSawOscillator() { }
 133:mi/plaits/dsp/engine/swarm_engine.h **** 
 134:mi/plaits/dsp/engine/swarm_engine.h ****   inline void Init() {
 135:mi/plaits/dsp/engine/swarm_engine.h ****     phase_ = 0.0f;
 136:mi/plaits/dsp/engine/swarm_engine.h ****     next_sample_ = 0.0f;
 137:mi/plaits/dsp/engine/swarm_engine.h ****     frequency_ = 0.01f;
 138:mi/plaits/dsp/engine/swarm_engine.h ****     gain_ = 0.0f;
 139:mi/plaits/dsp/engine/swarm_engine.h ****   }
 140:mi/plaits/dsp/engine/swarm_engine.h **** 
 141:mi/plaits/dsp/engine/swarm_engine.h ****   inline void Render(
 142:mi/plaits/dsp/engine/swarm_engine.h ****       float frequency,
 143:mi/plaits/dsp/engine/swarm_engine.h ****       float level,
ARM GAS  /var/folders/9k/zk1mgrrd7wg4__6zvxvr9w8m0000gn/T//ccnOQsWh.s 			page 4


 144:mi/plaits/dsp/engine/swarm_engine.h ****       float* out,
 145:mi/plaits/dsp/engine/swarm_engine.h ****       size_t size) {
 146:mi/plaits/dsp/engine/swarm_engine.h ****     if (frequency >= kMaxFrequency) {
 147:mi/plaits/dsp/engine/swarm_engine.h ****       frequency = kMaxFrequency;
 148:mi/plaits/dsp/engine/swarm_engine.h ****     }
 149:mi/plaits/dsp/engine/swarm_engine.h ****     stmlib::ParameterInterpolator fm(&frequency_, frequency, size);
 150:mi/plaits/dsp/engine/swarm_engine.h ****     stmlib::ParameterInterpolator gain(&gain_, level, size);
 151:mi/plaits/dsp/engine/swarm_engine.h **** 
 152:mi/plaits/dsp/engine/swarm_engine.h ****     float next_sample = next_sample_;
 153:mi/plaits/dsp/engine/swarm_engine.h ****     float phase = phase_;
 154:mi/plaits/dsp/engine/swarm_engine.h **** 
 155:mi/plaits/dsp/engine/swarm_engine.h ****     while (size--) {
 156:mi/plaits/dsp/engine/swarm_engine.h ****       float this_sample = next_sample;
 157:mi/plaits/dsp/engine/swarm_engine.h ****       next_sample = 0.0f;
 158:mi/plaits/dsp/engine/swarm_engine.h **** 
 159:mi/plaits/dsp/engine/swarm_engine.h ****       const float frequency = fm.Next();
 160:mi/plaits/dsp/engine/swarm_engine.h **** 
 161:mi/plaits/dsp/engine/swarm_engine.h ****       phase += frequency;
 162:mi/plaits/dsp/engine/swarm_engine.h ****   
 163:mi/plaits/dsp/engine/swarm_engine.h ****       if (phase >= 1.0f) {
 164:mi/plaits/dsp/engine/swarm_engine.h ****         phase -= 1.0f;
 165:mi/plaits/dsp/engine/swarm_engine.h ****         float t = phase / frequency;
 166:mi/plaits/dsp/engine/swarm_engine.h ****         this_sample -= stmlib::ThisBlepSample(t);
 167:mi/plaits/dsp/engine/swarm_engine.h ****         next_sample -= stmlib::NextBlepSample(t);
 168:mi/plaits/dsp/engine/swarm_engine.h ****       }
 169:mi/plaits/dsp/engine/swarm_engine.h **** 
 170:mi/plaits/dsp/engine/swarm_engine.h ****       next_sample += phase;
 171:mi/plaits/dsp/engine/swarm_engine.h ****       *out++ += (2.0f * this_sample - 1.0f) * gain.Next();
 172:mi/plaits/dsp/engine/swarm_engine.h ****     }
 173:mi/plaits/dsp/engine/swarm_engine.h ****     phase_ = phase;
 174:mi/plaits/dsp/engine/swarm_engine.h ****     next_sample_ = next_sample;
 175:mi/plaits/dsp/engine/swarm_engine.h ****   }
 176:mi/plaits/dsp/engine/swarm_engine.h **** 
 177:mi/plaits/dsp/engine/swarm_engine.h ****  private:
 178:mi/plaits/dsp/engine/swarm_engine.h ****   // Oscillator state.
 179:mi/plaits/dsp/engine/swarm_engine.h ****   float phase_;
 180:mi/plaits/dsp/engine/swarm_engine.h ****   float next_sample_;
 181:mi/plaits/dsp/engine/swarm_engine.h **** 
 182:mi/plaits/dsp/engine/swarm_engine.h ****   // For interpolation of parameters.
 183:mi/plaits/dsp/engine/swarm_engine.h ****   float frequency_;
 184:mi/plaits/dsp/engine/swarm_engine.h ****   float gain_;
 185:mi/plaits/dsp/engine/swarm_engine.h **** 
 186:mi/plaits/dsp/engine/swarm_engine.h ****   DISALLOW_COPY_AND_ASSIGN(AdditiveSawOscillator);
 187:mi/plaits/dsp/engine/swarm_engine.h **** };
