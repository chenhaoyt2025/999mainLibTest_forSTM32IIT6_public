  62:mi/plaits/dsp/chords/chord_bank.h ****   inline void Sort() {
  63:mi/plaits/dsp/chords/chord_bank.h ****     for (int i = 0; i < kChordNumNotes; ++i) {
  64:mi/plaits/dsp/chords/chord_bank.h ****       float r = ratio(i);
  65:mi/plaits/dsp/chords/chord_bank.h ****       while (r > 2.0f) {
  66:mi/plaits/dsp/chords/chord_bank.h ****         r *= 0.5f;
  67:mi/plaits/dsp/chords/chord_bank.h ****       }
  68:mi/plaits/dsp/chords/chord_bank.h ****       sorted_ratios_[i] = r;
  69:mi/plaits/dsp/chords/chord_bank.h ****     }
  70:mi/plaits/dsp/chords/chord_bank.h ****     std::sort(&sorted_ratios_[0], &sorted_ratios_[kChordNumNotes]);
  71:mi/plaits/dsp/chords/chord_bank.h ****   }
