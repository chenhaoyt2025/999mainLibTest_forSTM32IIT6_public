  51:mi/plaits/dsp/chords/chord_bank.h **** class ChordBank {
  52:mi/plaits/dsp/chords/chord_bank.h ****  public:
  53:mi/plaits/dsp/chords/chord_bank.h ****   ChordBank() { }
  54:mi/plaits/dsp/chords/chord_bank.h ****   ~ChordBank() { }
  55:mi/plaits/dsp/chords/chord_bank.h ****   
  56:mi/plaits/dsp/chords/chord_bank.h ****   void Init(stmlib::BufferAllocator* allocator);
  57:mi/plaits/dsp/chords/chord_bank.h ****   void Reset();
