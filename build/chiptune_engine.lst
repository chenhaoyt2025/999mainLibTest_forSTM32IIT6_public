  82:mi/stmlib/dsp/hysteresis_quantizer.h **** class HysteresisQuantizer2 {
  83:mi/stmlib/dsp/hysteresis_quantizer.h ****  public:
  84:mi/stmlib/dsp/hysteresis_quantizer.h ****   HysteresisQuantizer2() { }
  85:mi/stmlib/dsp/hysteresis_quantizer.h ****   ~HysteresisQuantizer2() { }
