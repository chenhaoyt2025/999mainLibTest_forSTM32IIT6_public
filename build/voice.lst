  27:mi/stmlib/utils/buffer_allocator.h **** // Stream buffer for serialization.
  28:mi/stmlib/utils/buffer_allocator.h **** 
  29:mi/stmlib/utils/buffer_allocator.h **** #ifndef STMLIB_UTILS_BUFFER_ALLOCATOR_H_
  30:mi/stmlib/utils/buffer_allocator.h **** #define STMLIB_UTILS_BUFFER_ALLOCATOR_H_
  31:mi/stmlib/utils/buffer_allocator.h **** 
  32:mi/stmlib/utils/buffer_allocator.h **** #include "stmlib/stmlib.h"
  33:mi/stmlib/utils/buffer_allocator.h **** 
  34:mi/stmlib/utils/buffer_allocator.h **** namespace stmlib {
  35:mi/stmlib/utils/buffer_allocator.h **** 
  36:mi/stmlib/utils/buffer_allocator.h **** class BufferAllocator {
  37:mi/stmlib/utils/buffer_allocator.h ****  public:
  38:mi/stmlib/utils/buffer_allocator.h ****   BufferAllocator() { }
  39:mi/stmlib/utils/buffer_allocator.h ****   ~BufferAllocator() { }
  40:mi/stmlib/utils/buffer_allocator.h ****   
  41:mi/stmlib/utils/buffer_allocator.h ****   BufferAllocator(void* buffer, size_t size) {
  42:mi/stmlib/utils/buffer_allocator.h ****     Init(buffer, size);
  43:mi/stmlib/utils/buffer_allocator.h ****   }
  44:mi/stmlib/utils/buffer_allocator.h ****   
  45:mi/stmlib/utils/buffer_allocator.h ****   inline void Init(void* buffer, size_t size) {
  46:mi/stmlib/utils/buffer_allocator.h ****     buffer_ = static_cast<uint8_t*>(buffer);
  47:mi/stmlib/utils/buffer_allocator.h ****     size_ = size;
  48:mi/stmlib/utils/buffer_allocator.h ****     Free();
