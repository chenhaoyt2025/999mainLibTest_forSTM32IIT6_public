  50:mi/stmlib/utils/buffer_allocator.h **** 
  51:mi/stmlib/utils/buffer_allocator.h ****   template<typename T>
  52:mi/stmlib/utils/buffer_allocator.h ****   inline T* Allocate() {
  53:mi/stmlib/utils/buffer_allocator.h ****     return Allocate<T>(1);
