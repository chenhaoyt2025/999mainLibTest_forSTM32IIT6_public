  53:mi/plaits/dsp/envelope.h ****   inline void ProcessPing(
  54:mi/plaits/dsp/envelope.h ****       float attack,
  55:mi/plaits/dsp/envelope.h ****       float short_decay,
  56:mi/plaits/dsp/envelope.h ****       float decay_tail,
  57:mi/plaits/dsp/envelope.h ****       float hf) {
  58:mi/plaits/dsp/envelope.h ****     if (ramp_up_) {
  59:mi/plaits/dsp/envelope.h ****       vactrol_state_ += attack;
  60:mi/plaits/dsp/envelope.h ****       if (vactrol_state_ >= 1.0f) {
  61:mi/plaits/dsp/envelope.h ****         vactrol_state_ = 1.0f;
  62:mi/plaits/dsp/envelope.h ****         ramp_up_ = false;
  63:mi/plaits/dsp/envelope.h ****       }
  64:mi/plaits/dsp/envelope.h ****     }
  65:mi/plaits/dsp/envelope.h ****     ProcessLP(ramp_up_ ? vactrol_state_ : 0.0f, short_decay, decay_tail, hf);
  66:mi/plaits/dsp/envelope.h ****   }
  67:mi/plaits/dsp/envelope.h ****   
  68:mi/plaits/dsp/envelope.h ****   inline void ProcessLP(
  69:mi/plaits/dsp/envelope.h ****       float level,
  70:mi/plaits/dsp/envelope.h ****       float short_decay,
  71:mi/plaits/dsp/envelope.h ****       float decay_tail,
  72:mi/plaits/dsp/envelope.h ****       float hf) {
  73:mi/plaits/dsp/envelope.h ****     float vactrol_input = level;
  74:mi/plaits/dsp/envelope.h ****     float vactrol_error = (vactrol_input - vactrol_state_);
  75:mi/plaits/dsp/envelope.h ****     float vactrol_state_2 = vactrol_state_ * vactrol_state_;
  76:mi/plaits/dsp/envelope.h ****     float vactrol_state_4 = vactrol_state_2 * vactrol_state_2;
  77:mi/plaits/dsp/envelope.h ****     float tail = 1.0f - vactrol_state_;
  78:mi/plaits/dsp/envelope.h ****     float tail_2 = tail * tail;
  79:mi/plaits/dsp/envelope.h ****     float vactrol_coefficient = (vactrol_error > 0.0f)
