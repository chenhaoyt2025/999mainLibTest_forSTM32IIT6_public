  81:mi/plaits/dsp/envelope.h ****         : short_decay + (1.0f - vactrol_state_4) * decay_tail;
  82:mi/plaits/dsp/envelope.h ****     vactrol_state_ += vactrol_coefficient * vactrol_error;
