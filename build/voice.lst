  66:mi/plaits/dsp/engine/engine.h ****   // When this flag is set to true, the engine declares that it will 
  67:mi/plaits/dsp/engine/engine.h ****   // render a signal that already has an envelope (eg: modal drum, 808 kick).
  68:mi/plaits/dsp/engine/engine.h ****   // By reporting this information, the synthesis voice upstream will
  69:mi/plaits/dsp/engine/engine.h ****   // bypass the internal envelope/LPG.
  70:mi/plaits/dsp/engine/engine.h ****   //
  71:mi/plaits/dsp/engine/engine.h ****   // This parameter can be changed on a per-call basis when calling Render()
  72:mi/plaits/dsp/engine/engine.h ****   // This is used by the speech synthesis engine, which renders either
  73:mi/plaits/dsp/engine/engine.h ****   // a continuous vowel sound (which needs to be enveloped by the LPG)
  74:mi/plaits/dsp/engine/engine.h ****   // or a word/sentence (which is already enveloped).
  75:mi/plaits/dsp/engine/engine.h ****   bool already_enveloped;
  76:mi/plaits/dsp/engine/engine.h **** };
  77:mi/plaits/dsp/engine/engine.h **** 
