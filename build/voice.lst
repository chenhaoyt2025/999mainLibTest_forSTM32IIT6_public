  41:mi/plaits/dsp/fx/low_pass_gate.h ****  public:
  42:mi/plaits/dsp/fx/low_pass_gate.h ****   LowPassGate() { }
  43:mi/plaits/dsp/fx/low_pass_gate.h ****   ~LowPassGate() { }
  44:mi/plaits/dsp/fx/low_pass_gate.h ****   
  45:mi/plaits/dsp/fx/low_pass_gate.h ****   void Init() {
  46:mi/plaits/dsp/fx/low_pass_gate.h ****     previous_gain_ = 0.0f;
  47:mi/plaits/dsp/fx/low_pass_gate.h ****     filter_.Init();
  48:mi/plaits/dsp/fx/low_pass_gate.h ****   }
  49:mi/plaits/dsp/fx/low_pass_gate.h ****   
  50:mi/plaits/dsp/fx/low_pass_gate.h ****   void Process(
  51:mi/plaits/dsp/fx/low_pass_gate.h ****       float gain,
  52:mi/plaits/dsp/fx/low_pass_gate.h ****       float frequency,
  53:mi/plaits/dsp/fx/low_pass_gate.h ****       float hf_bleed,
  54:mi/plaits/dsp/fx/low_pass_gate.h ****       float* in_out,
  55:mi/plaits/dsp/fx/low_pass_gate.h ****       size_t size) {
  56:mi/plaits/dsp/fx/low_pass_gate.h ****     stmlib::ParameterInterpolator gain_modulation(&previous_gain_, gain, size);
  57:mi/plaits/dsp/fx/low_pass_gate.h ****     filter_.set_f_q<stmlib::FREQUENCY_DIRTY>(frequency, 0.4f);
  58:mi/plaits/dsp/fx/low_pass_gate.h ****     while (size--) {
  59:mi/plaits/dsp/fx/low_pass_gate.h ****       const float s = *in_out * gain_modulation.Next();
  60:mi/plaits/dsp/fx/low_pass_gate.h ****       const float lp = filter_.Process<stmlib::FILTER_MODE_LOW_PASS>(s);
  61:mi/plaits/dsp/fx/low_pass_gate.h ****       *in_out++ = lp + (s - lp) * hf_bleed;
  62:mi/plaits/dsp/fx/low_pass_gate.h ****     }
  63:mi/plaits/dsp/fx/low_pass_gate.h ****   }
