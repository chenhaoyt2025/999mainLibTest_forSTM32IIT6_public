 119:mi/plaits/dsp/engine2/wave_terrain_engine.cpp **** #endif  // DIFFERENTIATE_WAVE_DATA
 120:mi/plaits/dsp/engine2/wave_terrain_engine.cpp ****   return (xy[0] + (xy[1] - xy[0]) * wt_fractional) * value_scale;
 121:mi/plaits/dsp/engine2/wave_terrain_engine.cpp **** }
