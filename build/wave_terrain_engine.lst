 110:mi/plaits/dsp/engine2/wave_terrain_engine.cpp ****   xy[0] = InterpolateIntegratedWave(waves, sample_integral, sample_fractional);
 111:mi/plaits/dsp/engine2/wave_terrain_engine.cpp ****   waves += table_size_full;
 112:mi/plaits/dsp/engine2/wave_terrain_engine.cpp ****   xy[1] = InterpolateIntegratedWave(waves, sample_integral, sample_fractional);
 113:mi/plaits/dsp/engine2/wave_terrain_engine.cpp **** #else
