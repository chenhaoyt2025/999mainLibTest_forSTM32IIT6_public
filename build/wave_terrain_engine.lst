  74:mi/plaits/dsp/engine2/wave_terrain_engine.cpp **** inline float InterpolateIntegratedWave(
  75:mi/plaits/dsp/engine2/wave_terrain_engine.cpp ****     const T* table,
  76:mi/plaits/dsp/engine2/wave_terrain_engine.cpp ****     int32_t index_integral,
  77:mi/plaits/dsp/engine2/wave_terrain_engine.cpp ****     float index_fractional) {
