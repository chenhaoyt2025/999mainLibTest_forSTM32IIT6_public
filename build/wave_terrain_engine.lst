 105:mi/plaits/dsp/engine2/wave_terrain_engine.cpp ****   
 106:mi/plaits/dsp/engine2/wave_terrain_engine.cpp ****   float xy[2];
 107:mi/plaits/dsp/engine2/wave_terrain_engine.cpp **** #ifdef DIFFERENTIATE_WAVE_DATA
 108:mi/plaits/dsp/engine2/wave_terrain_engine.cpp ****   const float value_scale = 1.0f / 1024.0f;
