  96:mi/plaits/dsp/engine2/wave_terrain_engine.cpp ****   const int num_waves = 64;
  97:mi/plaits/dsp/engine2/wave_terrain_engine.cpp ****   const float sample = (y + 1.0f) * 0.5f * float(table_size);
  98:mi/plaits/dsp/engine2/wave_terrain_engine.cpp ****   const float wt = (x + 1.0f) * 0.5f * float(num_waves - 1);
  99:mi/plaits/dsp/engine2/wave_terrain_engine.cpp ****   
 100:mi/plaits/dsp/engine2/wave_terrain_engine.cpp ****   const int16_t* waves = wav_integrated_waves + \
 101:mi/plaits/dsp/engine2/wave_terrain_engine.cpp ****       bank * num_waves * table_size_full;
 102:mi/plaits/dsp/engine2/wave_terrain_engine.cpp ****   
 103:mi/plaits/dsp/engine2/wave_terrain_engine.cpp ****   MAKE_INTEGRAL_FRACTIONAL(sample);
