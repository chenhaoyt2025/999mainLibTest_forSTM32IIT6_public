 142:mi/plaits/dsp/oscillator/sine_oscillator.h ****       } else {
 143:mi/plaits/dsp/oscillator/sine_oscillator.h ****         *out++ = s;
 144:mi/plaits/dsp/oscillator/sine_oscillator.h ****       }
 145:mi/plaits/dsp/oscillator/sine_oscillator.h ****     }
 146:mi/plaits/dsp/oscillator/sine_oscillator.h ****   }
