  79:mi/plaits/dsp/engine2/wave_terrain_engine.cpp ****   float b = static_cast<float>(table[index_integral + 1]);
  80:mi/plaits/dsp/engine2/wave_terrain_engine.cpp ****   float c = static_cast<float>(table[index_integral + 2]);
  81:mi/plaits/dsp/engine2/wave_terrain_engine.cpp ****   float t = index_fractional;
