  39:mi/plaits/dsp/oscillator/wavetable_oscillator.h **** namespace plaits {
  40:mi/plaits/dsp/oscillator/wavetable_oscillator.h **** 
  41:mi/plaits/dsp/oscillator/wavetable_oscillator.h **** class Differentiator {
  42:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****  public:
  43:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****   Differentiator() { }
  44:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****   ~Differentiator() { }
  45:mi/plaits/dsp/oscillator/wavetable_oscillator.h **** 
  46:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****   void Init() {
  47:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****     previous_ = 0.0f;
  48:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****     lp_ = 0.0f;
  49:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****   }
  50:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****   
  51:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****   float Process(float coefficient, float s) {
  52:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****     ONE_POLE(lp_, s - previous_, coefficient);
  53:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****     previous_ = s;
  54:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****     return lp_;
  55:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****   }
  56:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****  private:
  57:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****   float lp_;
  58:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****   float previous_;
  59:mi/plaits/dsp/oscillator/wavetable_oscillator.h **** 
  60:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****   DISALLOW_COPY_AND_ASSIGN(Differentiator);
  61:mi/plaits/dsp/oscillator/wavetable_oscillator.h **** };
