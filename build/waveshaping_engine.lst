  27:mi/stmlib/dsp/polyblep.h **** // Polynomial approximation of band-limited step for band-limited waveform
  28:mi/stmlib/dsp/polyblep.h **** // synthesis.
  29:mi/stmlib/dsp/polyblep.h **** 
  30:mi/stmlib/dsp/polyblep.h **** #ifndef STMLIB_DSP_POLYBLEP_H_
  31:mi/stmlib/dsp/polyblep.h **** #define STMLIB_DSP_POLYBLEP_H_
  32:mi/stmlib/dsp/polyblep.h **** 
  33:mi/stmlib/dsp/polyblep.h **** #include "stmlib/stmlib.h"
  34:mi/stmlib/dsp/polyblep.h **** 
  35:mi/stmlib/dsp/polyblep.h **** namespace stmlib {
  36:mi/stmlib/dsp/polyblep.h **** 
  37:mi/stmlib/dsp/polyblep.h **** inline float ThisBlepSample(float t) {
  38:mi/stmlib/dsp/polyblep.h ****   return 0.5f * t * t;
  39:mi/stmlib/dsp/polyblep.h **** }
  40:mi/stmlib/dsp/polyblep.h **** 
  41:mi/stmlib/dsp/polyblep.h **** inline float NextBlepSample(float t) {
  42:mi/stmlib/dsp/polyblep.h ****   t = 1.0f - t;
  43:mi/stmlib/dsp/polyblep.h ****   return -0.5f * t * t;
  44:mi/stmlib/dsp/polyblep.h **** }
