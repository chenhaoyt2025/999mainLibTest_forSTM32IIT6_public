 100:mi/stmlib/dsp/hysteresis_quantizer.h **** 
 101:mi/stmlib/dsp/hysteresis_quantizer.h ****   inline int Process(int base, float value) {
 102:mi/stmlib/dsp/hysteresis_quantizer.h ****     value *= scale_;
 103:mi/stmlib/dsp/hysteresis_quantizer.h ****     value += offset_;
 104:mi/stmlib/dsp/hysteresis_quantizer.h ****     value += static_cast<float>(base);
 105:mi/stmlib/dsp/hysteresis_quantizer.h **** 
 106:mi/stmlib/dsp/hysteresis_quantizer.h ****     float hysteresis_sign = value > static_cast<float>(quantized_value_)
 107:mi/stmlib/dsp/hysteresis_quantizer.h ****         ? -1.0f
 108:mi/stmlib/dsp/hysteresis_quantizer.h ****         : +1.0f;
 109:mi/stmlib/dsp/hysteresis_quantizer.h ****     int q = static_cast<int>(value + hysteresis_sign * hysteresis_ + 0.5f);
 110:mi/stmlib/dsp/hysteresis_quantizer.h ****     CONSTRAIN(q, 0, num_steps_ - 1);
 111:mi/stmlib/dsp/hysteresis_quantizer.h ****     quantized_value_ = q;
 112:mi/stmlib/dsp/hysteresis_quantizer.h ****     return q;
 113:mi/stmlib/dsp/hysteresis_quantizer.h ****   }
 114:mi/stmlib/dsp/hysteresis_quantizer.h **** 
 115:mi/stmlib/dsp/hysteresis_quantizer.h ****   template<typename T>
 116:mi/stmlib/dsp/hysteresis_quantizer.h ****   const T& Lookup(const T* array, float value) {
 117:mi/stmlib/dsp/hysteresis_quantizer.h ****     return array[Process(value)];
