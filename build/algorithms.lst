  26:mi/plaits/dsp/oscillator/sine_oscillator.h **** //
  27:mi/plaits/dsp/oscillator/sine_oscillator.h **** // Simple sine oscillator (wavetable) + fast sine oscillator (magic circle).
  28:mi/plaits/dsp/oscillator/sine_oscillator.h **** //
  29:mi/plaits/dsp/oscillator/sine_oscillator.h **** // The fast implementation might glitch a bit under heavy modulations of the
  30:mi/plaits/dsp/oscillator/sine_oscillator.h **** // frequency.
  31:mi/plaits/dsp/oscillator/sine_oscillator.h **** 
  32:mi/plaits/dsp/oscillator/sine_oscillator.h **** #ifndef PLAITS_DSP_OSCILLATOR_SINE_OSCILLATOR_H_
  33:mi/plaits/dsp/oscillator/sine_oscillator.h **** #define PLAITS_DSP_OSCILLATOR_SINE_OSCILLATOR_H_
  34:mi/plaits/dsp/oscillator/sine_oscillator.h **** 
  35:mi/plaits/dsp/oscillator/sine_oscillator.h **** #include "stmlib/dsp/dsp.h"
ARM GAS  /var/folders/9k/zk1mgrrd7wg4__6zvxvr9w8m0000gn/T//ccWZw7sc.s 			page 12


  36:mi/plaits/dsp/oscillator/sine_oscillator.h **** #include "stmlib/dsp/parameter_interpolator.h"
  37:mi/plaits/dsp/oscillator/sine_oscillator.h **** #include "stmlib/dsp/rsqrt.h"
  38:mi/plaits/dsp/oscillator/sine_oscillator.h **** 
