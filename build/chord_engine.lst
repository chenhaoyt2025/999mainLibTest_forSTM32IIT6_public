  26:mi/plaits/dsp/oscillator/string_synth_oscillator.h **** //
  27:mi/plaits/dsp/oscillator/string_synth_oscillator.h **** // A mixture of 7 sawtooth and square waveforms in the style of divide-down
  28:mi/plaits/dsp/oscillator/string_synth_oscillator.h **** // organs:
  29:mi/plaits/dsp/oscillator/string_synth_oscillator.h **** //
  30:mi/plaits/dsp/oscillator/string_synth_oscillator.h **** // [0]     [1]        [2]     [3]        [4]     [5]        [6]
  31:mi/plaits/dsp/oscillator/string_synth_oscillator.h **** // Saw 8', Square 8', Saw 4', Square 4', Saw 2', Square 2', Saw 1'
  32:mi/plaits/dsp/oscillator/string_synth_oscillator.h **** //
  33:mi/plaits/dsp/oscillator/string_synth_oscillator.h **** // Internally, this renders 4 band-limited sawtooths, from 8' to 1' from a
  34:mi/plaits/dsp/oscillator/string_synth_oscillator.h **** // single phase counter. The square waveforms are obtained by algebraic
  35:mi/plaits/dsp/oscillator/string_synth_oscillator.h **** // manipulations on the sawtooths, using the identity:
  36:mi/plaits/dsp/oscillator/string_synth_oscillator.h **** // Square 16' = 2 Sawtooth 16' - Sawtooth 8'
  37:mi/plaits/dsp/oscillator/string_synth_oscillator.h **** 
