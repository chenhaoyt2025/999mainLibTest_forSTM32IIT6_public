  63:mi/plaits/dsp/oscillator/wavetable_oscillator.h **** template<typename T>
  64:mi/plaits/dsp/oscillator/wavetable_oscillator.h **** inline float InterpolateWave(
  65:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****     const T* table,
  66:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****     int32_t index_integral,
  67:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****     float index_fractional) {
  68:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****   float a = static_cast<float>(table[index_integral]);
  69:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****   float b = static_cast<float>(table[index_integral + 1]);
  70:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****   float t = index_fractional;
  71:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****   return a + (b - a) * t;
  72:mi/plaits/dsp/oscillator/wavetable_oscillator.h **** }
  73:mi/plaits/dsp/oscillator/wavetable_oscillator.h **** 
  74:mi/plaits/dsp/oscillator/wavetable_oscillator.h **** template<typename T>
  75:mi/plaits/dsp/oscillator/wavetable_oscillator.h **** inline float InterpolateWaveHermite(
  76:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****     const T* table,
  77:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****     int32_t index_integral,
  78:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****     float index_fractional) {
  79:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****   const float xm1 = static_cast<float>(table[index_integral]);
  80:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****   const float x0 = static_cast<float>(table[index_integral + 1]);
  81:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****   const float x1 = static_cast<float>(table[index_integral + 2]);
  82:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****   const float x2 = static_cast<float>(table[index_integral + 3]);
  83:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****   const float c = (x1 - xm1) * 0.5f;
  84:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****   const float v = x0 - x1;
  85:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****   const float w = c + v;
  86:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****   const float a = w + v + (x2 - x0) * 0.5f;
  87:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****   const float b_neg = w + a;
  88:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****   const float f = index_fractional;
  89:mi/plaits/dsp/oscillator/wavetable_oscillator.h ****   return (((a * f) - b_neg) * f + c) * f + x0;
  90:mi/plaits/dsp/oscillator/wavetable_oscillator.h **** }
