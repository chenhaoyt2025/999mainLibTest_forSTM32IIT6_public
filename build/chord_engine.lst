  27:mi/stmlib/dsp/hysteresis_quantizer.h **** // Quantize a float in [0, 1] to an integer in [0, num_steps[. Apply hysteresis
  28:mi/stmlib/dsp/hysteresis_quantizer.h **** // to prevent jumps near the decision boundary.
  29:mi/stmlib/dsp/hysteresis_quantizer.h **** 
  30:mi/stmlib/dsp/hysteresis_quantizer.h **** #ifndef STMLIB_DSP_HYSTERESIS_QUANTIZER_H_
